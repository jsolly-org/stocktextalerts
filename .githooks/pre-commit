#!/usr/bin/env bash
set -e

error_handler() {
  printf '\n\033[0;31m✗ Commit aborted: One or more checks failed.\033[0m\n'
  printf 'Check the output above for details. Fix the issues, then try committing again.\n'
}
trap error_handler ERR

echo "Ensuring staged files are linted/formatted..."
npx lint-staged

staged=$(git diff --cached --name-only)
non_agent=0
while IFS= read -r f; do
  [[ -z "$f" ]] && continue
  case "$f" in
    .cursor/hooks.json | .githooks/pre-commit) ;;
    *) non_agent=1; break ;;
  esac
done <<< "$staged"

if [[ "$non_agent" -eq 0 && -n "$staged" ]]; then
  echo "Agent hooks/config only — skipping app test suite."
  exit 0
fi

echo "Running checks..."
bash .agents/scripts/check-biome-rules.sh biome.jsonc
# Strict Biome gate: unresolved warnings or errors must block the commit.
npx biome ci . --error-on-warnings
npm run check:yaml
npm run check:md
if git diff --cached --name-only | grep -q '^aws/template\.yaml$'; then
  echo "Validating SAM template..."
  sam validate --lint --template-file aws/template.yaml
fi
npm run check:ts
npm run check:knip
npm run check:sql
npm run test
npm run test:e2e
