{
	"compilerOptions": {
		"target": "ES2024",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"strictNullChecks": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": ".",
		"baseUrl": "..",
		"declaration": false
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
