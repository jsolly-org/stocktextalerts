version = 0.1

[default.build.parameters]
# CodeUri paths in aws/template.yaml are relative to repo root so SAM's
# native esbuild integration can find the shared src/ modules and the
# root node_modules.
base_dir = ".."

[default.deploy.parameters]
stack_name = "stocktextalerts-crons"
region = "us-east-1"
confirm_changeset = false
capabilities = "CAPABILITY_IAM"
resolve_s3 = true
s3_prefix = "stocktextalerts-crons"
image_repositories = []

# Copy to aws/samconfig.toml (gitignored). Local credentials: export AWS_PROFILE in shell or .env.local.
# Cursor cloud: CURSOR_AWS_ASSUME_IAM_ROLE_ARN + SAMCONFIG_TOML secret (no profile=). See .agents/docs/cloud-agents.md.
