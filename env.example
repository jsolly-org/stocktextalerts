# Site Configuration
# Local only. Vercel sets VERCEL_URL automatically for hosted deployments.
VERCEL_URL=http://localhost:4321
# Required for `npm run deploy:infra` (maps to SAM SiteUrl).
PRODUCTION_SITE_URL=https://<your-domain>

# Supabase (local dev — after `npm run db:start`, copy from `supabase status`)
# Production values go on Vercel (or the Vercel↔Supabase integration) and in SSM under <ssm-prefix>/.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-key>
SUPABASE_SECRET_KEY=<supabase-secret-key>
# Local only. Do not add this local pooled connection string to Vercel.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Email unsubscribe token signing (must match between Vercel and Lambda/SSM)
UNSUBSCRIBE_TOKEN_SECRET=<unsubscribe-token-secret>

# Email (local dev / tests)
# Dev and tests route through Mailpit when EMAIL_SMTP_HOST is set (see docs/tooling-setup.md).
# Production notification email is sent by AWS Lambda (SES via execution role), not Vercel.
# Lambda reads the From header from SSM (EMAIL_FROM_SSM_PARAM); keep EMAIL_FROM here
# aligned with that value for local runs that exercise createEmailSender.
EMAIL_FROM="StockTextAlerts <notifications@updates.<your-domain>>"
# Comma-separated email allowlist for the pending-user approval page (Vercel + SAM).
ADMIN_EMAILS=<admin-email>
# Shared HMAC secret for Vercel -> AWS email dispatch. Generate with `openssl rand -hex 32`.
EMAIL_DISPATCH_SECRET=<email-dispatch-secret>
# Production Vercel only, after deploying AWS email dispatch Lambda Function URL.
# EMAIL_DISPATCH_URL=<email-dispatch-function-url>
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
# EMAIL_REPLY_TO=<reply-to-email>

# Massive (quotes / bars / calendar / movers / reference / branding / news / corporate actions)
# Local + Vercel (logo proxy) + Lambda SSM
MASSIVE_API_KEY=<massive-api-key>

# Finnhub (earnings / recommendations / insider — Lambda only; stub locally)
FINNHUB_API_KEY=<finnhub-api-key>

# xAI (Grok) — optional; News/Rumors add-ons. Lambda SSM; omit to disable.
# XAI_API_KEY=<xai-api-key>

# Telegram (BotFather). Required on Vercel for webhook/link; token also in Lambda SSM.
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
TELEGRAM_BOT_USERNAME=<telegram-bot-username>
TELEGRAM_WEBHOOK_SECRET=<telegram-webhook-secret>
TELEGRAM_LINK_TOKEN_SECRET=<telegram-link-token-secret>
# Optional override for `npm run telegram:set-webhook`. Prefer an explicit production HTTPS URL;
# otherwise the script derives from SITE_URL / Vercel URL vars (local VERCEL_URL is localhost and will fail).
# TELEGRAM_WEBHOOK_URL=https://<your-domain>/api/messaging/telegram

# AWS SAM injectables (optional — defaults match this repo's production stack)
# Used by aws/sam-params.sh on `npm run deploy:infra`. Unset = stocktextalerts defaults.
# SES_IDENTITY_DOMAIN=<ses-verified-domain>
# SSM_PREFIX=/<app-name>
# ALERT_TOPIC_SSM_PARAM=/<alert-topic-ssm-path>
# EMAIL_FROM_SSM_PARAM=/<app-name>/email-from
# BACKUP_CONNECTION_SSM_PARAM=/<app-name>/backup/connection-string

# Logging
# LOG_MASK_PII defaults to true when unset.
LOG_MASK_PII=true

# Auth rate limits (optional; defaults in astro.config.ts env.schema)
# CHANGE_PASSWORD_RATE_LIMIT_ATTEMPTS=5
# CHANGE_PASSWORD_RATE_LIMIT_MINUTES=15
# CHANGE_EMAIL_RATE_LIMIT_ATTEMPTS=5
# CHANGE_EMAIL_RATE_LIMIT_MINUTES=15
# DELETE_ACCOUNT_RATE_LIMIT_ATTEMPTS=5
# DELETE_ACCOUNT_RATE_LIMIT_MINUTES=15
# PASSWORD_RESET_RATE_LIMIT_SECONDS=60

# Local only. Used by seed generation; do not add to Vercel.
DEFAULT_PASSWORD=<local-seed-password>
