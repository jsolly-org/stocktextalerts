# Site Configuration
# VERCEL_URL is automatically set by Vercel for all deployments.
# For local development, set it manually:
VERCEL_URL=http://localhost:4321

# Supabase (local dev only — production values are injected by the Vercel Supabase integration)
# Run `supabase start` then copy values from `supabase status`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Optional: production creds for `npm run db:reset:prod`.
# SUPABASE_URL_PROD=https://your-project.supabase.co
# SUPABASE_SECRET_KEY_PROD=your-prod-secret-key
# DATABASE_URL_PROD=postgresql://postgres:password@host:5432/database

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=your-verify-service-sid

# Vercel
CRON_SECRET=your-random-secret-string

# Email (RESEND_API_KEY is injected by the Vercel Resend integration)
EMAIL_FROM="Your Project Name <notifications@updates.example.com>"

# Finnhub (asset prices / market hours)
FINNHUB_API_KEY=your-finnhub-api-key

# xAI (Grok) - optional, only needed for News/Rumors add-ons
XAI_API_KEY=your-xai-api-key

# Logging
# LOG_MASK_PII defaults to true when unset.
LOG_MASK_PII=true

DEFAULT_PASSWORD=your-strong-local-seed-password
