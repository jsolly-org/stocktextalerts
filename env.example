# Site Configuration
# VERCEL_URL is automatically set by Vercel for all deployments.
# For local development, set it manually:
VERCEL_URL=http://localhost:4321

# Supabase (local dev only — production values are injected by the Vercel Supabase integration)
# Run `supabase start` then copy values from `supabase status`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Vercel
CRON_SECRET=your-random-secret-string  # Minimum 12 characters; use `openssl rand -hex 32` for production

# AWS (shared across SES email + SMS + Pinpoint OTP)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
EMAIL_FROM="Your Project Name <notifications@updates.example.com>"

# AWS End User Messaging (SMS)
AWS_SMS_ORIGINATION_IDENTITY=+1234567890  # Registered phone number, short code, or sender ID
AWS_PINPOINT_APP_ID=your-pinpoint-application-id  # For OTP verification

# Massive (asset prices / dividends / splits / news)
MASSIVE_API_KEY=your-massive-api-key

# Finnhub (earnings / market hours)
FINNHUB_API_KEY=your-finnhub-api-key

# xAI (Grok) - optional, only needed for News/Rumors add-ons
XAI_API_KEY=your-xai-api-key

# Logging
# LOG_MASK_PII defaults to true when unset.
LOG_MASK_PII=true

DEFAULT_PASSWORD=your-strong-local-seed-password
