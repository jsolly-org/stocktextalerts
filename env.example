# Site Configuration
# Local only. Vercel sets VERCEL_URL automatically for hosted deployments.
VERCEL_URL=http://localhost:4321

# Supabase (local dev only — production values are injected by the Vercel Supabase integration)
# Run `supabase start` then copy values from `supabase status`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
# Local only. Do not add this local pooled connection string to Vercel.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=your-verify-service-sid

# Email unsubscribe token signing
UNSUBSCRIBE_TOKEN_SECRET=your-random-secret-string  # Minimum 12 characters; use `openssl rand -hex 32`

# Email (AWS SES)
# AWS credentials are required locally and on Vercel for SES email sending.
# In Lambda, the execution role provides credentials automatically.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
EMAIL_FROM="Your Project Name <notifications@updates.example.com>"
# EMAIL_REPLY_TO=support@example.com  # Optional reply-to address for outbound emails

# Massive (asset prices / dividends / splits / news)
MASSIVE_API_KEY=your-massive-api-key

# Finnhub (earnings / market hours)
FINNHUB_API_KEY=your-finnhub-api-key

# xAI (Grok) - optional, only needed for News/Rumors add-ons
XAI_API_KEY=your-xai-api-key

# Logging
# LOG_MASK_PII defaults to true when unset.
LOG_MASK_PII=true

# Local only. Used by seed generation; do not add to Vercel.
DEFAULT_PASSWORD=your-strong-local-seed-password
