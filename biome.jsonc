{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"root": true,
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false,
		"defaultBranch": "main"
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"src/**/*.{ts,tsx,json,css,html,md,vue}",
			"tests/**/*.{ts,tsx,json}",
			"{package.json,tsconfig.json,vercel.json,biome.jsonc,vitest.config.ts,vite.config.ts,playwright.config.ts,astro.config.ts,*.md}",
			"!src/lib/db/generated/database.types.ts",
			"!**/.claude",
			"!**/.worktrees",
			"!**/worktrees"
		]
	},
	"html": {
		"experimentalFullSupportEnabled": true
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error"
			},
			"suspicious": {
				"noConsole": "error",
				"noEmptyBlockStatements": "error"
			},
			"style": {
				"useThrowOnlyError": "error",
				"noNonNullAssertion": "off"
			},
			"nursery": {
				"noFloatingPromises": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/components/**/*.vue"],
			"linter": {
				"rules": {
					"a11y": {
						"useAriaPropsForRole": "off"
					},
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.d.ts"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		},
		{
			"includes": ["src/lib/logging/**/*.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		},
		{
			"includes": ["tests/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off",
						"noEmptyBlockStatements": "off"
					}
				}
			}
		},
		{
			"includes": ["src/global.css"],
			"css": {
				"parser": {
					"tailwindDirectives": true
				}
			}
		}
	]
}
