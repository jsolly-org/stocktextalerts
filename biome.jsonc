{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"root": true,
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false,
		"defaultBranch": "main"
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"src/**/*.{ts,tsx,json,css,html,md,vue}",
			"tests/**/*.{ts,tsx,json}",
			"{package.json,tsconfig.json,vercel.json,biome.jsonc,vitest.config.ts,vite.config.ts,playwright.config.ts,astro.config.ts,*.md}",
			"!src/lib/db/generated/database.types.ts",
			// Root-anchored, NOT `!**/.claude` — over-broad form silently
			// no-ops `biome ci .` from inside a worktree. See docs/tooling-setup.md "Worktrees".
			"!.claude",
			"!.worktrees",
			"!worktrees"
		]
	},
	"html": {
		"experimentalFullSupportEnabled": true
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			// a11y rules newly added to Biome's "recommended" preset in 2.5.1. The dashboard
			// Vue components violate them in ~28 places that each need real semantic markup
			// changes (roles, keyboard handlers, label/control wiring). Deferred from this
			// version bump to a dedicated accessibility pass so the upgrade stays a clean,
			// non-behavioral tooling change. Re-enable as the components are remediated.
			"a11y": {
				"noNoninteractiveElementToInteractiveRole": "off",
				"noRedundantRoles": "off",
				"noStaticElementInteractions": "off",
				"useAriaPropsSupportedByRole": "off",
				"useFocusableInteractive": "off",
				"useKeyWithClickEvents": "off",
				"noLabelWithoutControl": "off",
				"useSemanticElements": "off",
				"useValidAnchor": "off"
			},
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error"
			},
			"suspicious": {
				"noConsole": "error",
				"noEmptyBlockStatements": "error"
			},
			"style": {
				"useThrowOnlyError": "error",
				"noNonNullAssertion": "off"
			},
			"nursery": {
				"noFloatingPromises": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/components/**/*.vue"],
			"linter": {
				"rules": {
					"a11y": {
						"useAriaPropsForRole": "off"
					},
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.d.ts"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		},
		{
			"includes": ["src/lib/logging/**/*.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		},
		{
			"includes": ["tests/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off",
						"noEmptyBlockStatements": "off"
					}
				}
			}
		},
		{
			"includes": ["src/global.css"],
			"css": {
				"parser": {
					"tailwindDirectives": true
				}
			}
		}
	]
}
