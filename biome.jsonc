{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"root": true,
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false,
		"defaultBranch": "main"
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"src/**/*.{ts,tsx,json,css,html,md,vue}",
			"tests/**/*.{ts,tsx,json}",
			"{package.json,tsconfig.json,vercel.json,biome.jsonc,vitest.config.ts,vite.config.ts,playwright.config.ts,astro.config.ts,*.md}",
			"!src/lib/db/generated/database.types.ts",
			// Root-anchored, NOT `!**/.claude` — over-broad form silently
			// no-ops `biome ci .` from inside a worktree. See docs/tooling-setup.md "Worktrees".
			"!.claude",
			"!.worktrees",
			"!worktrees"
		]
	},
	"html": {
		"experimentalFullSupportEnabled": true
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error"
			},
			"suspicious": {
				"noConsole": "error",
				"noEmptyBlockStatements": "error"
			},
			"style": {
				"useThrowOnlyError": "error",
				"noNonNullAssertion": "off",
				// Biome defaults this Vue rule to info; promote it to error so kebab-case
				// template attributes are enforced (not just reported) in the gate + CI.
				"useVueHyphenatedAttributes": "error"
			},
			"nursery": {
				"noFloatingPromises": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/components/**/*.vue"],
			"linter": {
				"rules": {
					"a11y": {
						"useAriaPropsForRole": "off",
						// biome's Vue analyzer lints <template> as HTML but does not resolve
						// v-bind attributes (:href, :for, :id) to their static names, so these
						// two rules false-positive on every correct Vue anchor / label binding.
						// Template-level suppression comments are not honored in 2.5.1, so the
						// exception must live here in config.
						"useValidAnchor": "off",
						"noLabelWithoutControl": "off"
					},
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		},
		{
			// AssetInput (combobox) and ChannelMultiSelect (multi-select listbox) implement
			// the W3C APG aria-activedescendant pattern: <ul role="listbox"> / <li role="option">
			// where the input/listbox owns keyboard handling and options are intentionally NOT
			// individually focusable. Biome's generic a11y rules don't model this pattern.
			"includes": ["**/AssetInput.vue", "**/ChannelMultiSelect.vue"],
			"linter": {
				"rules": {
					"a11y": {
						"noNoninteractiveElementToInteractiveRole": "off",
						"useFocusableInteractive": "off",
						"useKeyWithClickEvents": "off"
					}
				}
			}
		},
		{
			// <ul role="list">: Safari + VoiceOver drop list semantics when list markers are
			// removed (Tailwind's reset sets list-style: none). The explicit role restores
			// them, so it is NOT redundant here despite biome's noRedundantRoles.
			"includes": ["**/WatchlistPanel.vue"],
			"linter": {
				"rules": {
					"a11y": {
						"noRedundantRoles": "off"
					}
				}
			}
		},
		{
			// The carousel track is a swipe-gesture + in-page-anchor-click-delegation container,
			// not a widget. Keyboard navigation is provided by the real <button> tab bar and by
			// the anchors themselves; the div handlers only enhance touch scrolling.
			"includes": ["**/DashboardCarousel.vue"],
			"linter": {
				"rules": {
					"a11y": {
						"noStaticElementInteractions": "off",
						"useKeyWithClickEvents": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.d.ts"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		},
		{
			"includes": ["src/lib/logging/**/*.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		},
		{
			"includes": ["tests/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off",
						"noEmptyBlockStatements": "off"
					}
				}
			}
		},
		{
			"includes": ["src/global.css"],
			"css": {
				"parser": {
					"tailwindDirectives": true
				}
			}
		}
	]
}
