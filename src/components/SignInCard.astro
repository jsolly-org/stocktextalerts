---

import StatusMessage from "./StatusMessage.astro";
import EmailInput from "./EmailInput.vue";
import { REGISTRATION_ENABLED } from "../lib/auth-constants";

interface Props {
	emailPrefill?: string;
	errorCode?: string | null;
	errorMessage?: string | null;
	successMessage?: string | null;
	redirectPath?: string | null;
}
const {
	emailPrefill = "",
	errorCode = null,
	errorMessage = null,
	successMessage = null,
	redirectPath = null,
} = Astro.props;
---
<section
	class="card max-w-md mx-auto p-8 mb-20"
	aria-labelledby="signin-heading"
>
  <h2 id="signin-heading" class="text-2xl font-bold text-heading mb-6 text-center">Sign in to your account</h2>
  {successMessage && (
    <StatusMessage class="mb-4" tone="success" message={successMessage} />
  )}
  {errorMessage && (
    <StatusMessage class="mb-4" tone="error">
      {errorMessage}
      {errorCode === "invalid_credentials" && REGISTRATION_ENABLED && (
        <> You can <a href="/auth/register" class="underline hover:no-underline">create an account</a> or <a href="/auth/forgot" class="underline hover:no-underline">reset your password</a>.</>
      )}
      {errorCode === "invalid_credentials" && !REGISTRATION_ENABLED && (
        <> You can <a href="/auth/forgot" class="underline hover:no-underline">reset your password</a>.</>
      )}
    </StatusMessage>
  )}
  <form class="space-y-6" action="/api/auth/signin" method="post">
		{redirectPath && (
			<input type="hidden" name="redirect" value={redirectPath} />
		)}
    <fieldset class="space-y-4">
      <legend class="sr-only">Sign in credentials</legend>
      <div>
        <label for="email" class="block text-sm font-medium text-label mb-2">Email</label>
        <EmailInput
          client:load
          type="email"
          name="email"
          id="email"
          required
          autocomplete="email"
          class="input input-lg"
          placeholder="you@example.com&hellip;"
          value={emailPrefill}
        />
      </div>
      <div>
        <label for="password" class="block text-sm font-medium text-label mb-2">Password</label>
        <input
          type="password"
          name="password"
          id="password"
          required
          autocomplete="current-password"
          spellcheck="false"
          class="input input-lg"
          placeholder="••••••••"
        />
      </div>
    </fieldset>
    <div class="flex items-center justify-between">
      <div class="text-sm">
        <a href="/auth/forgot" class="link-primary">Forgot your password?</a>
      </div>
    </div>
    <button
      type="submit"
      class="btn btn-lg btn-primary w-full"
      data-submit-loading
    >
      <span>Sign In</span>
    </button>
  </form>
  {REGISTRATION_ENABLED && (
    <p class="mt-6 text-center text-sm text-body-secondary">
      New here? <a href="/auth/register" class="link-primary">Create an account</a>
    </p>
  )}
</section>
