---

import { Icon } from "astro-icon/components";
---
<section id="features" class="py-20 bg-gray-50" aria-labelledby="features-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <header class="text-center">
      <h2 id="features-heading" class="text-3xl leading-10 font-extrabold tracking-tight text-gray-900 sm:text-4xl md:text-5xl">
        Everything you need to stay informed
      </h2>
      <p class="mt-6 max-w-2xl text-xl text-gray-500 mx-auto lg:text-2xl lg:leading-relaxed">
        A daily digest of your tracked stocks—delivered via email and optional SMS.
      </p>
    </header>

    <div class="mt-12">
      <ul class="space-y-12 md:space-y-0 md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-x-8 md:gap-y-12">
        <li class="relative pl-16 sm:pl-20">
          <article>
            <div aria-hidden="true" class="absolute left-0 top-0 flex items-center justify-center h-12 w-12 sm:h-14 sm:w-14 rounded-lg bg-primary text-white shadow-lg">
              <Icon name="bell-alert" class="h-6 w-6 sm:h-7 sm:w-7" aria-hidden="true" />
            </div>
            <h3 class="text-lg sm:text-xl leading-6 sm:leading-8 font-semibold text-gray-900">Daily Digest</h3>
            <p class="mt-2 sm:mt-3 text-base sm:text-lg text-gray-500 leading-relaxed">
              A once-per-day snapshot of your tracked stocks, at the time you choose.
            </p>
          </article>
        </li>

        <li class="relative pl-16 sm:pl-20">
          <article>
            <div aria-hidden="true" class="absolute left-0 top-0 flex items-center justify-center h-12 w-12 sm:h-14 sm:w-14 rounded-lg bg-success-strong text-white shadow-lg">
              <Icon name="chat-bubble-left-right" class="h-6 w-6 sm:h-7 sm:w-7" aria-hidden="true" />
            </div>
            <h3 class="text-lg sm:text-xl leading-6 sm:leading-8 font-semibold text-gray-900">Email + SMS</h3>
            <p class="mt-2 sm:mt-3 text-base sm:text-lg text-gray-500 leading-relaxed">
              Get your daily digest via email, with optional SMS delivery.
            </p>
          </article>
        </li>

        <li class="relative pl-16 sm:pl-20">
          <article>
            <div aria-hidden="true" class="absolute left-0 top-0 flex items-center justify-center h-12 w-12 sm:h-14 sm:w-14 rounded-lg bg-warning-strong text-white shadow-lg">
              <Icon name="globe-alt" class="h-6 w-6 sm:h-7 sm:w-7" aria-hidden="true" />
            </div>
            <h3 class="text-lg sm:text-xl leading-6 sm:leading-8 font-semibold text-gray-900">Timezone Aware</h3>
            <p class="mt-2 sm:mt-3 text-base sm:text-lg text-gray-500 leading-relaxed">
              Schedule the daily digest using your timezone so delivery matches your day.
            </p>
          </article>
        </li>

        <li class="relative pl-16 sm:pl-20">
          <article>
            <div aria-hidden="true" class="absolute left-0 top-0 flex items-center justify-center h-12 w-12 sm:h-14 sm:w-14 rounded-lg bg-indigo-600 text-white shadow-lg">
              <Icon name="device-phone-mobile" class="h-6 w-6 sm:h-7 sm:w-7" aria-hidden="true" />
            </div>
            <h3 class="text-lg sm:text-xl leading-6 sm:leading-8 font-semibold text-gray-900">Direct to Your Phone</h3>
            <p class="mt-2 sm:mt-3 text-base sm:text-lg text-gray-500 leading-relaxed">
              No app to install. Everything comes straight to your native messaging app.
            </p>
          </article>
        </li>

        <li class="relative pl-16 sm:pl-20">
          <article>
            <div aria-hidden="true" class="absolute left-0 top-0 flex items-center justify-center h-12 w-12 sm:h-14 sm:w-14 rounded-lg bg-teal-600 text-white shadow-lg">
              <Icon name="chart-bar" class="h-6 w-6 sm:h-7 sm:w-7" aria-hidden="true" />
            </div>
            <h3 class="text-lg sm:text-xl leading-6 sm:leading-8 font-semibold text-gray-900">Track What You Care About</h3>
            <p class="mt-2 sm:mt-3 text-base sm:text-lg text-gray-500 leading-relaxed">
              Pick the tickers you want and we’ll include them in your daily digest.
            </p>
          </article>
        </li>

        <li class="relative pl-16 sm:pl-20">
          <article>
            <div aria-hidden="true" class="absolute left-0 top-0 flex items-center justify-center h-12 w-12 sm:h-14 sm:w-14 rounded-lg bg-rose-600 text-white shadow-lg">
              <Icon name="shield-check" class="h-6 w-6 sm:h-7 sm:w-7" aria-hidden="true" />
            </div>
            <h3 class="text-lg sm:text-xl leading-6 sm:leading-8 font-semibold text-gray-900">Simple & Secure</h3>
            <p class="mt-2 sm:mt-3 text-base sm:text-lg text-gray-500 leading-relaxed">
              Easy account setup. Your data is encrypted and secure.
            </p>
          </article>
        </li>
      </ul>
    </div>
  </div>
</section>
