---

import { Icon } from "astro-icon/components";
---
<section id="features" class="py-20 bg-surface-alt" aria-labelledby="features-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <header class="text-center">
      <h2 id="features-heading" class="text-3xl leading-10 font-extrabold tracking-tight text-heading sm:text-4xl md:text-5xl">
        Everything you need to stay informed
      </h2>
    </header>

    <div class="mt-12">
      <ul class="space-y-12 md:space-y-0 md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-x-8 md:gap-y-12">
          <li class="relative pl-16 sm:pl-20">
          <article>
            <div aria-hidden="true" class="absolute left-0 top-0 flex items-center justify-center h-12 w-12 sm:h-14 sm:w-14 rounded-lg bg-primary text-white shadow-lg">
              <Icon name="bell-alert" class="h-6 w-6 sm:h-7 sm:w-7" />
            </div>
            <h3 class="text-lg sm:text-xl leading-6 sm:leading-8 font-semibold text-heading">Scheduled Updates</h3>
            <p class="mt-2 sm:mt-3 text-base sm:text-lg text-muted leading-relaxed">
              Concise snapshots of your tracked assets, at the times you choose.
            </p>
          </article>
        </li>

        <li class="relative pl-16 sm:pl-20">
          <article>
            <div aria-hidden="true" class="absolute left-0 top-0 flex items-center justify-center h-12 w-12 sm:h-14 sm:w-14 rounded-lg bg-feature-phone text-white shadow-lg">
              <Icon name="device-phone-mobile" class="h-6 w-6 sm:h-7 sm:w-7" />
            </div>
            <h3 class="text-lg sm:text-xl leading-6 sm:leading-8 font-semibold text-heading">Direct to Your Phone</h3>
            <p class="mt-2 sm:mt-3 text-base sm:text-lg text-muted leading-relaxed">
              No app to install. Everything comes straight to your native messaging app.
            </p>
          </article>
        </li>

        <li class="relative pl-16 sm:pl-20">
          <article>
            <div aria-hidden="true" class="absolute left-0 top-0 flex items-center justify-center h-12 w-12 sm:h-14 sm:w-14 rounded-lg bg-feature-track text-white shadow-lg">
              <Icon name="chart-bar" class="h-6 w-6 sm:h-7 sm:w-7" />
            </div>
            <h3 class="text-lg sm:text-xl leading-6 sm:leading-8 font-semibold text-heading">Track What You Care About</h3>
            <p class="mt-2 sm:mt-3 text-base sm:text-lg text-muted leading-relaxed">
              Pick the tickers you want and we'll include them in your updates.
            </p>
          </article>
        </li>

      </ul>
    </div>
  </div>
</section>
