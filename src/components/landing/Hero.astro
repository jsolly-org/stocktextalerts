---
import NotificationPreview from "./NotificationPreview.astro";

interface Props {
	isAuthenticated: boolean;
}
const { isAuthenticated } = Astro.props;
---
<section
  class="relative overflow-hidden bg-linear-to-b from-blue-50 dark:from-blue-950 via-surface to-surface"
  aria-labelledby="hero-heading"
>
  <!-- Decorative background elements -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -top-40 -right-32 w-80 h-80 bg-blue-100 dark:bg-blue-900 rounded-full opacity-50 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-32 w-80 h-80 bg-primary/10 rounded-full opacity-50 blur-3xl"></div>
  </div>
  
  <div class="relative max-w-7xl mx-auto">
    <div class="mt-16 mx-auto max-w-7xl px-4 sm:mt-20 sm:px-6 md:mt-24 lg:px-8 pb-16 sm:pb-20 lg:pb-24">
      <div class="lg:grid lg:grid-cols-2 lg:gap-12 lg:items-start">
        <!-- Left column: text + CTA -->
        <div class="text-center lg:text-left animate-fade-in">
          <h1 id="hero-heading" class="text-4xl tracking-tight font-extrabold text-heading sm:text-5xl md:text-6xl lg:text-7xl">
            <span class="block xl:inline">Stock & ETF alerts on your schedule</span>
            <span class="block bg-linear-to-r from-primary to-blue-500 bg-clip-text text-transparent xl:inline">delivered how you want them</span>
          </h1>
          <p class="mt-6 text-lg text-body-secondary sm:mt-8 sm:text-xl sm:max-w-2xl sm:mx-auto lg:mx-0 md:mt-10 md:text-2xl md:leading-relaxed">
            Get updates on your tracked assets—delivered via email or text messages. Simple, reliable, and distraction-free.
          </p>
          <div class="mt-8 sm:mt-12">
              {isAuthenticated ? (
                <div class="flex flex-col items-center lg:items-start gap-4">
                  <p class="text-lg text-body-secondary">You&rsquo;re already logged in.</p>
                  <a
                    href="/dashboard"
                    class="btn btn-lg btn-primary shadow-lg hover:shadow-xl md:py-4 md:text-lg md:px-10"
                  >
                    Go to Dashboard
                  </a>
                </div>
              ) : (
                <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
                  <a
                    href="/auth/register"
                    class="btn btn-lg btn-primary shadow-lg hover:shadow-xl md:py-4 md:text-lg md:px-10"
                  >
                    Start Tracking for Free
                  </a>
                  <a
                    href="/auth/signin"
                    class="btn btn-lg btn-ghost md:py-4 md:text-lg md:px-10"
                  >
                    Sign In
                  </a>
                </div>
              )}
          </div>
        </div>

        <!-- Right column: phone animation -->
        <div class="animate-fade-in">
          <NotificationPreview />
        </div>
      </div>
    </div>
  </div>
</section>
