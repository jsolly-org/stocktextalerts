---
import phoneFrame from "../../assets/phone-frame.svg";
---
<div class="phone-preview-container" id="iphone-animation-demo" aria-hidden="true">
  <div class="phone-frame">
    <img src={phoneFrame.src} alt="Phone showing asset alert notification preview" width="260" height="536" class="phone-frame-svg" />

    <!-- Message bubbles inside the phone screen -->
    <div class="messages-container">
      <div class="messages-scroll">
        <div class="messages-wrapper">
          <div class="message-bubble received" data-index="0">
            <p class="font-bold uppercase text-blue-600">Scheduled Update</p>
            <p>AAPL $195.50 (+2.4%), GOOGL $178.20 (+1.8%), TSLA $248.30 (-0.5%)</p>
          </div>
          <div class="message-bubble received" data-index="1">
            <p class="font-bold uppercase text-blue-600">🗞️ Breaking News</p>
            <p>Fed holds rates steady at 5.25%. Markets rally on dovish guidance.</p>
          </div>
          <div class="message-bubble received" data-index="2">
            <p class="font-bold uppercase text-blue-600">🤫 Rumor</p>
            <p>TSLA chatter: leaked photos suggest a lower-cost model. Unverified.</p>
          </div>
          <div class="message-bubble received" data-index="3">
            <p class="font-bold uppercase text-blue-600">🗞️ Breaking News</p>
            <p>NVDA announces next-gen AI chip. Stock surges 4.1% to new 52-week high of $142.60.</p>
          </div>
          <div class="message-bubble received" data-index="4">
            <p class="font-bold uppercase text-blue-600">🤫 Rumor</p>
            <p>AAPL chatter: supply chain talk hints at a foldable prototype. Unverified.</p>
          </div>
          <div class="message-bubble received" data-index="5">
            <p class="font-bold uppercase text-blue-600">Scheduled Update</p>
            <p>Market Close: S&P 500 +0.8%, NASDAQ +1.2%, DOW +0.3%.</p>
          </div>
          <div class="message-bubble received" data-index="6">
            <p class="font-bold uppercase text-blue-600">🗞️ Breaking News</p>
            <p>MSFT earnings beat estimates. Revenue up 17% YoY. After-hours +3.2%.</p>
          </div>
          <div class="message-bubble received" data-index="7">
            <p class="font-bold uppercase text-blue-600">🤫 Rumor</p>
            <p>GOOGL chatter: talk of insider buying ahead of a product launch. Unverified.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative glow -->
  <div class="absolute -inset-4 bg-primary/5 rounded-[3rem] -z-10 blur-xl"></div>
</div>

<style>
  .phone-preview-container {
    position: relative;
    margin-left: auto;
    margin-right: auto;
    margin-top: 3rem;
    margin-bottom: 2rem;
    max-width: 160px;
  }

  @media (min-width: 640px) {
    .phone-preview-container {
      margin-top: 4rem;
      max-width: 180px;
    }
  }

  /* In the two-column hero, reduce top margin and allow a larger phone */
  @media (min-width: 1024px) {
    .phone-preview-container {
      margin-top: 0;
      margin-bottom: 0;
      max-width: 300px;
    }
  }

  .phone-frame {
    position: relative;
  }

  .phone-frame-svg {
    width: 100%;
    height: auto;
  }

  .messages-container {
    position: absolute;
    top: 15%;
    left: 4%;
    right: 4%;
    bottom: 7.5%;
    border-radius: 28px;
    overflow: hidden;
    background-color: var(--color-slate-50);
    pointer-events: none;
  }

  .messages-scroll {
    height: 100%;
    padding: 0.5rem;
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .messages-scroll::-webkit-scrollbar {
    display: none;
  }

  .messages-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .message-bubble {
    max-width: 85%;
    padding: 0.4rem;
    font-size: 0.48rem;
    line-height: 1.25;
    transform-origin: bottom;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    opacity: 0;
    display: none;
  }

  .message-bubble p {
    margin: 0;
  }

  .message-bubble p:first-child {
    font-size: 0.34rem;
    letter-spacing: 0.03em;
    margin-bottom: 0.2rem;
    line-height: 1.2;
  }

  .message-bubble p:last-child {
    font-size: 0.48rem;
    line-height: 1.35;
  }

  @media (min-width: 1024px) {
    .message-bubble {
      padding: 0.55rem;
      font-size: 0.62rem;
    }

    .message-bubble p:first-child {
      font-size: 0.44rem;
      margin-bottom: 0.24rem;
    }

    .message-bubble p:last-child {
      font-size: 0.62rem;
      line-height: 1.4;
    }
  }

  .message-bubble.received {
    background-color: var(--color-slate-100);
    color: var(--color-slate-800);
    border-radius: 0.5rem 0.5rem 0.5rem 0;
  }

  .message-bubble.visible {
    display: block;
    opacity: 1;
    animation: messageFadeIn 0.3s ease-out forwards;
  }

  @keyframes messageFadeIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .message-bubble.visible {
      animation: none;
    }
  }
</style>

<script>
  function initIphoneMessageAnimation() {
    const containerId = 'iphone-animation-demo';
    const container = document.getElementById(containerId);
    if (!container) return;

    const messages = Array.from(container.querySelectorAll('.message-bubble'));
    if (!messages.length) return;

    const maybeScrollContainer = container.querySelector('.messages-scroll');
    if (!(maybeScrollContainer instanceof HTMLElement)) return;
    const scrollContainer: HTMLElement = maybeScrollContainer;

    // Respect prefers-reduced-motion
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      messages.forEach((msg) => {
        if (!(msg instanceof HTMLElement)) return;
        msg.style.display = 'block';
        msg.style.opacity = '1';
        msg.classList.add('visible');
        msg.style.animation = 'none';
      });
      return;
    }

    let currentIndex = 0;
    const DELAY = 2250;
    const PAUSE_BEFORE_RESTART = 5000;
    let animationInProgress = false;

    function animateMessages() {
      if (animationInProgress) return;
      animationInProgress = true;

      messages.forEach((msg) => {
        if (!(msg instanceof HTMLElement)) return;
        msg.classList.remove('visible');
        msg.style.display = 'none';
      });

      scrollContainer.scrollTop = 0;
      currentIndex = 0;
      showNextMessage();
    }

    function showNextMessage() {
      if (currentIndex < messages.length) {
        const message = messages[currentIndex];
        if (!(message instanceof HTMLElement)) {
          currentIndex++;
          setTimeout(showNextMessage, DELAY);
          return;
        }

        setTimeout(() => {
          message.style.display = 'block';
          void message.offsetWidth; // Force reflow so CSS animation triggers after display change
          message.classList.add('visible');

          setTimeout(() => {
            const messageBottom = message.offsetTop + message.offsetHeight;
            const containerHeight = scrollContainer.clientHeight;
            const currentScroll = scrollContainer.scrollTop;
            const scrollTarget = messageBottom - containerHeight + 20;

            if (scrollTarget > currentScroll) {
              scrollContainer.scrollTo({
                top: scrollTarget,
                behavior: 'smooth',
              });
            }

            currentIndex++;
            setTimeout(showNextMessage, DELAY);
          }, 300);
        }, 50);
      } else {
        setTimeout(() => {
          animationInProgress = false;
          animateMessages();
        }, PAUSE_BEFORE_RESTART);
      }
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !animationInProgress) {
          animateMessages();
        }
      },
      { threshold: 0.1 }
    );

    observer.observe(container);
  }

  initIphoneMessageAnimation();
</script>
