---
import { Icon } from "astro-icon/components";
---
<div class="relative max-w-sm mx-auto mt-12 sm:mt-16" aria-hidden="true">
  <!-- Phone frame -->
  <div class="bg-gray-900 rounded-4xl p-3 shadow-2xl">
    <div class="bg-white rounded-3xl overflow-hidden">
      <!-- Status bar -->
      <div class="bg-gray-100 px-4 py-2 flex items-center justify-between text-xs text-gray-500">
        <span>9:41</span>
        <div class="flex items-center gap-1">
          <Icon name="device-phone-mobile" class="w-3 h-3" />
          <span>100%</span>
        </div>
      </div>
      
      <!-- Notification content -->
      <div class="p-4 space-y-3">
        <!-- App header -->
        <div class="flex items-center gap-3">
          <div class="bg-primary p-1.5 rounded-lg">
            <Icon name="presentation-chart-line" class="w-4 h-4 text-white" />
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900">StockTextAlerts</p>
            <p class="text-xs text-gray-500">Just now</p>
          </div>
        </div>
        
        <!-- Message preview -->
        <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
          <p class="text-sm text-gray-800 font-medium mb-2">Daily Stock Digest</p>
          <div class="space-y-1.5 text-xs text-gray-600">
            <div class="flex justify-between">
              <span class="font-medium">AAPL</span>
              <span class="text-success-strong">+2.4%</span>
            </div>
            <div class="flex justify-between">
              <span class="font-medium">GOOGL</span>
              <span class="text-success-strong">+1.8%</span>
            </div>
            <div class="flex justify-between">
              <span class="font-medium">TSLA</span>
              <span class="text-error-strong">-0.5%</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Decorative glow -->
  <div class="absolute -inset-4 bg-primary/5 rounded-[3rem] -z-10 blur-xl"></div>
</div>
