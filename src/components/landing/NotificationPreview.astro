---
import phoneFrame from "../../assets/phone-frame.svg";
---
<div class="phone-preview-container" id="iphone-animation-demo" aria-hidden="true">
  <div class="phone-frame">
    <img src={phoneFrame.src} alt="" width="260" height="536" class="phone-frame-svg" />

    <!-- Message bubbles inside the phone screen -->
    <div class="messages-container">
      <div class="messages-scroll">
        <div class="messages-wrapper">
          <div class="message-bubble received" data-index="0">
            <p>Stock Update: AAPL $195.50 (+2.4%), GOOGL $178.20 (+1.8%), TSLA $248.30 (-0.5%)</p>
          </div>
          <div class="message-bubble sent" data-index="1">
            <p>What's driving AAPL today?</p>
          </div>
          <div class="message-bubble received" data-index="2">
            <p>Strong iPhone sales report and analyst upgrade from Morgan Stanley. Price target raised to $210.</p>
          </div>
          <div class="message-bubble received" data-index="3">
            <p>Alert: NVDA just hit a new 52-week high at $142.60, up 4.1%</p>
          </div>
          <div class="message-bubble sent" data-index="4">
            <p>Can you start tracking NVDA?</p>
          </div>
          <div class="message-bubble received" data-index="5">
            <p>Done! You will now receive updates for NVDA.</p>
          </div>
          <div class="message-bubble received" data-index="6">
            <p>Market Close: S&P 500 +0.8%, NASDAQ +1.2%. Your portfolio is up 2.1% today.</p>
          </div>
          <div class="message-bubble sent" data-index="7">
            <p>Any earnings to watch this week?</p>
          </div>
          <div class="message-bubble received" data-index="8">
            <p>MSFT reports Tuesday, AMZN Thursday. I'll alert you before market open.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative glow -->
  <div class="absolute -inset-4 bg-primary/5 rounded-[3rem] -z-10 blur-xl"></div>
</div>

<style>
  .phone-preview-container {
    position: relative;
    margin-left: auto;
    margin-right: auto;
    margin-top: 3rem;
    margin-bottom: 2rem;
    max-width: 260px;
  }

  @media (min-width: 640px) {
    .phone-preview-container {
      margin-top: 4rem;
    }
  }

  /* In the two-column hero, reduce top margin and allow a larger phone */
  @media (min-width: 1024px) {
    .phone-preview-container {
      margin-top: 0;
      margin-bottom: 0;
      max-width: 300px;
    }
  }

  .phone-frame {
    position: relative;
  }

  .phone-frame-svg {
    width: 100%;
    height: auto;
  }

  .messages-container {
    position: absolute;
    top: 15%;
    left: 4%;
    right: 4%;
    bottom: 7.5%;
    border-radius: 28px;
    overflow: hidden;
    background-color: var(--color-slate-50);
    pointer-events: none;
  }

  .messages-scroll {
    height: 100%;
    padding: 1rem;
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .messages-scroll::-webkit-scrollbar {
    display: none;
  }

  .messages-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .message-bubble {
    max-width: 85%;
    padding: 0.75rem;
    font-size: 0.875rem;
    line-height: 1.25;
    transform-origin: bottom;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    opacity: 0;
    display: none;
  }

  .message-bubble p {
    margin: 0;
  }

  .message-bubble.sent {
    margin-left: auto;
    background-color: var(--color-blue-500);
    color: white;
    border-radius: 0.5rem 0.5rem 0 0.5rem;
  }

  .message-bubble.received {
    background-color: var(--color-slate-100);
    color: var(--color-slate-800);
    border-radius: 0.5rem 0.5rem 0.5rem 0;
  }

  .message-bubble.visible {
    display: block;
    opacity: 1;
    animation: messageFadeIn 0.3s ease-out forwards;
  }

  @keyframes messageFadeIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<script>
  function initIphoneMessageAnimation(containerId: string) {
    const container = document.getElementById(containerId);
    if (!container) return;

    const messages = Array.from(container.querySelectorAll('.message-bubble')) as HTMLElement[];
    if (!messages.length) return;

    const scrollContainer = container.querySelector('.messages-scroll') as HTMLElement;
    if (!scrollContainer) return;

    // Respect prefers-reduced-motion
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      messages.forEach((msg) => {
        msg.style.display = 'block';
        msg.style.opacity = '1';
        msg.classList.add('visible');
        msg.style.animation = 'none';
      });
      return;
    }

    let currentIndex = 0;
    const DELAY = 1500;
    const PAUSE_BEFORE_RESTART = 4000;
    let animationInProgress = false;

    function animateMessages() {
      if (animationInProgress) return;
      animationInProgress = true;

      messages.forEach((msg) => {
        msg.classList.remove('visible');
        msg.style.display = 'none';
      });

      scrollContainer.scrollTop = 0;
      currentIndex = 0;
      showNextMessage();
    }

    function showNextMessage() {
      if (currentIndex < messages.length) {
        const message = messages[currentIndex];

        setTimeout(() => {
          message.style.display = 'block';
          void message.offsetWidth; // Force reflow so CSS animation triggers after display change
          message.classList.add('visible');

          setTimeout(() => {
            const messageBottom = message.offsetTop + message.offsetHeight;
            const containerHeight = scrollContainer.clientHeight;
            const currentScroll = scrollContainer.scrollTop;
            const scrollTarget = messageBottom - containerHeight + 20;

            if (scrollTarget > currentScroll) {
              scrollContainer.scrollTo({
                top: scrollTarget,
                behavior: 'smooth',
              });
            }

            currentIndex++;
            setTimeout(showNextMessage, DELAY);
          }, 300);
        }, 50);
      } else {
        setTimeout(() => {
          animationInProgress = false;
          animateMessages();
        }, PAUSE_BEFORE_RESTART);
      }
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !animationInProgress) {
          animateMessages();
        }
      },
      { threshold: 0.1 }
    );

    observer.observe(container);
  }

  document.addEventListener('DOMContentLoaded', () => {
    initIphoneMessageAnimation('iphone-animation-demo');
  });
</script>
