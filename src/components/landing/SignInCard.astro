---

import HCaptcha from "../HCaptcha.astro";

interface Props {
	emailPrefill?: string;
	errorMessage?: string | null;
	successMessage?: string | null;
}
const {
	emailPrefill = "",
	errorMessage = null,
	successMessage = null,
} = Astro.props;

const SIGNIN_FORM_ID = "signin-form";
const SIGNIN_CAPTCHA_TOKEN_ID = "signin_captcha_token";
const SIGNIN_CAPTCHA_STATUS_ID = "signin-captcha-status";
---
<div 
	class="max-w-md mx-auto bg-white rounded-lg shadow-lg border border-gray-200 p-8 mb-20"
	data-signin-form-id={SIGNIN_FORM_ID}
	data-signin-captcha-token-id={SIGNIN_CAPTCHA_TOKEN_ID}
	data-signin-captcha-status-id={SIGNIN_CAPTCHA_STATUS_ID}
>
  <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Sign in to your account</h2>
  {successMessage && (
    <div class="mb-4 rounded-md bg-green-50 p-4" role="alert">
      <p class="text-sm font-medium text-green-800">{successMessage}</p>
    </div>
  )}
  {errorMessage && (
    <div class="mb-4 rounded-md bg-red-50 p-4" role="alert">
      <p class="text-sm font-medium text-red-800">{errorMessage}</p>
    </div>
  )}
  <form class="space-y-6" action="/api/auth/signin" method="post" id={SIGNIN_FORM_ID}>
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
      <input 
        type="email" 
        name="email" 
        id="email" 
        required 
        autocomplete="email"
        class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-transparent" 
        placeholder="you@example.com"
        value={emailPrefill}
      />
    </div>
    <div>
      <label for="password" class="block text-sm font-medium text-gray-700 mb-2">Password</label>
      <input 
        type="password" 
        name="password" 
        id="password" 
        required 
        autocomplete="current-password"
        class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-transparent" 
        placeholder="••••••••"
      />
    </div>
		<div>
			<HCaptcha
				tokenInputId={SIGNIN_CAPTCHA_TOKEN_ID}
				callbackName="onSignInHCaptchaSuccess"
				errorCallback="onSignInHCaptchaError"
				expiredCallback="onSignInHCaptchaExpired"
			/>
			<div
				id={SIGNIN_CAPTCHA_STATUS_ID}
				class="mt-2 hidden rounded-md bg-red-50 p-3 text-sm text-red-700"
				role="status"
				aria-live="polite"
			></div>
		</div>
    <div class="flex items-center justify-between">
      <div class="text-sm">
        <a href="/auth/forgot" class="font-medium text-blue-600 hover:text-blue-500">Forgot your password?</a>
      </div>
    </div>
    <button 
      type="submit" 
      class="w-full text-white px-6 py-3 rounded-md font-medium transition-colors bg-blue-600 hover:bg-blue-700 cursor-pointer"
    >
      Sign In
    </button>
  </form>
  <p class="mt-6 text-center text-sm text-gray-600">
    New here? <a href="/auth/register" class="font-medium text-blue-600 hover:text-blue-500">Create an account</a>
  </p>
</div>

<script>
	import {
		createCaptchaStatusHelpers,
		initializeHCaptchaForm,
		setupCaptchaSubmitGuard,
		setupCaptchaTokenInputListener,
		setupHCaptchaCallback,
		setupHCaptchaErrorCallback,
		setupHCaptchaExpiredCallback,
	} from "../../lib/auth/hcaptcha";
	import { setupEmailInputHandlers } from "../../lib/forms/dom/email-input";

	const container = document.querySelector('[data-signin-form-id]');
	if (!container) {
		throw new Error("SignInCard container not found");
	}

	const SIGNIN_FORM_ID = container.getAttribute("data-signin-form-id");
	const SIGNIN_CAPTCHA_TOKEN_ID = container.getAttribute("data-signin-captcha-token-id");
	const SIGNIN_CAPTCHA_STATUS_ID = container.getAttribute("data-signin-captcha-status-id");

	if (!SIGNIN_FORM_ID || !SIGNIN_CAPTCHA_TOKEN_ID || !SIGNIN_CAPTCHA_STATUS_ID) {
		throw new Error("Missing required data attributes on SignInCard container");
	}

	const form = document.getElementById(SIGNIN_FORM_ID);
	if (form instanceof HTMLFormElement) {
		const captchaStatus = createCaptchaStatusHelpers(SIGNIN_CAPTCHA_STATUS_ID);

		const emailInput = document.getElementById("email");
		if (emailInput instanceof HTMLInputElement) {
			setupEmailInputHandlers(emailInput);
		}

		setupCaptchaSubmitGuard(SIGNIN_FORM_ID, SIGNIN_CAPTCHA_TOKEN_ID, (message) => {
			captchaStatus.show(message);
		});
		setupCaptchaTokenInputListener(SIGNIN_CAPTCHA_TOKEN_ID, (token) => {
			if (token.trim().length > 0) {
				captchaStatus.hide();
			}
		});

		initializeHCaptchaForm(SIGNIN_FORM_ID, SIGNIN_CAPTCHA_TOKEN_ID);
		setupHCaptchaCallback(
			"onSignInHCaptchaSuccess",
			SIGNIN_CAPTCHA_TOKEN_ID,
			SIGNIN_FORM_ID,
			() => {
				captchaStatus.hide();
			},
		);
		setupHCaptchaErrorCallback("onSignInHCaptchaError");
		setupHCaptchaExpiredCallback(
			"onSignInHCaptchaExpired",
			SIGNIN_CAPTCHA_TOKEN_ID,
		);
	}
</script>
