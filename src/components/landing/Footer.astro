---
const currentYear = new Date().getFullYear();
---
<footer class="bg-gray-50 border-t border-gray-200">
  <div class="max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-6 sm:flex-row sm:justify-between">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} StockTextAlerts. All rights reserved.
      </p>
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
          <li>
            <a href="/#features" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
              Features
            </a>
          </li>
          <li>
            <a href="/faq" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
              FAQ
            </a>
          </li>
          <li>
            <a href="/privacy" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="/terms" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
              Terms of Service
            </a>
          </li>
          <li>
            <a href="mailto:support@stocktextalerts.com" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
              Contact
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</footer>
