---

interface Props {
	isAuthenticated: boolean;
}
const { isAuthenticated } = Astro.props;
---
<section class="bg-primary-strong" aria-labelledby="cta-heading">
  <div class="max-w-3xl mx-auto text-center py-20 px-6 sm:py-24 sm:px-8 lg:px-12">
    <h2 id="cta-heading" class="text-4xl font-extrabold text-white sm:text-5xl md:text-6xl leading-tight">
      <span class="block">The stock info <span class="whitespace-nowrap">you need,</span> when you need it.</span>
    </h2>
    <p class="mt-6 text-xl leading-relaxed text-primary-soft">
      Track your stocks and let us handle the rest. Get a daily digest via email, text messages, or both—your choice.
    </p>
    {!isAuthenticated && (
      <div class="mt-10">
        <a 
          href="/auth/register" 
          class="btn btn-lg btn-secondary shadow-lg hover:shadow-xl motion-safe:hover:scale-105"
        >
          Create Free Account
        </a>
      </div>
    )}
  </div>
</section>
