---
import { Icon } from "astro-icon/components";

const steps = [
  {
    number: "1",
    icon: "user-circle" as const,
    title: "Create a free account",
    description: "Sign up with your email in under a minute. No credit card required.",
  },
  {
    number: "2",
    icon: "chart-bar" as const,
    title: "Pick your assets",
    description: "Search US stocks and ETFs by ticker or company name and add up to 10 to your watchlist.",
  },
  {
    number: "3",
    icon: "clock" as const,
    title: "Set your schedule",
    description: "Choose delivery times during market hours, plus optional Daily Digests, Asset Events, and Price Alerts.",
  },
  {
    number: "4",
    icon: "envelope" as const,
    title: "Preview & get your updates",
    description: "See live previews of your notifications, then choose email, SMS, or both for each type.",
  },
];
---
<section class="py-20 bg-surface" aria-labelledby="how-it-works-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <header class="text-center">
      <h2 id="how-it-works-heading" class="text-3xl leading-10 font-extrabold tracking-tight text-heading sm:text-4xl md:text-5xl">
        How it works
      </h2>
    </header>

    <ol class="mt-16 grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((step) => (
        <li class="relative text-center group">
          <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-primary/10 text-primary mb-5 transition-colors duration-300 group-hover:bg-primary group-hover:text-white motion-safe:group-hover:shadow-lg">
            <Icon name={step.icon} class="h-7 w-7" aria-hidden="true" />
          </div>
          <span class="inline-block text-sm font-bold text-primary uppercase tracking-wide mb-2" aria-hidden="true">Step {step.number}</span>
          <h3 class="text-lg font-semibold text-heading mb-2">{step.title}</h3>
          <p class="text-muted leading-relaxed">{step.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
