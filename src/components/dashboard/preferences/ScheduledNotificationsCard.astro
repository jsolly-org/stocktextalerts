---
import type { User } from "../../../lib/db";
import TimePicker from "../TimePicker.vue";

interface Props {
	user: User;
	formId: string;
}

const { user, formId } = Astro.props;
const phoneVerificationSectionId = `${formId}-phone-verification-section`;

const needsChannelSelection =
	!user.email_notifications_enabled && !user.sms_notifications_enabled;
const needsPhoneVerification =
	user.sms_notifications_enabled && !user.sms_opted_out && !user.phone_verified;
const needsSetup = needsChannelSelection || needsPhoneVerification;

function minutesToTimeInputValue(minutes: number): string {
	const hours = Math.floor(minutes / 60);
	const mins = minutes % 60;
	return `${String(hours).padStart(2, "0")}:${String(mins).padStart(2, "0")}`;
}

const currentTime = minutesToTimeInputValue(
	user.daily_digest_notification_time,
);
---

<div
	class="mb-6 bg-white rounded-lg shadow-sm border border-gray-200 p-6"
	data-scheduled-notifications
	data-form-id={formId}
	data-timezone={user.timezone}
	data-next-send-at-iso={user.next_send_at ?? ""}
	data-email-notifications-enabled={user.email_notifications_enabled ? "true" : "false"}
	data-sms-notifications-enabled={user.sms_notifications_enabled ? "true" : "false"}
	data-sms-opted-out={user.sms_opted_out ? "true" : "false"}
	data-phone-verified={user.phone_verified ? "true" : "false"}
>
	<div class="flex items-start justify-between gap-4">
		<div>
			<h2 class="text-2xl font-bold text-gray-900">
				Scheduled Notifications
			</h2>
			<p class="text-sm text-gray-600 mt-1">
				Configure when scheduled notifications are delivered.
			</p>
		</div>
		<div class="shrink-0 text-xs text-gray-700 bg-gray-100 border border-gray-200 rounded-full px-3 py-1">
			<span class="text-gray-600">It is now</span>{" "}
			<span id="daily-digest-current-time" class="font-medium tabular-nums"></span>
		</div>
	</div>

	<p id={`${formId}-scheduled-notifications-save-hint`} class="mt-4 text-sm text-amber-700 hidden">
		Changes aren't saved until you click{" "}
		<span class="font-medium">Save Preferences</span> at the bottom of the page.
	</p>

	<div class="mt-6 rounded-lg border border-gray-200 bg-gray-50 p-4">
		<div class="flex items-start justify-between gap-4">
			<div>
				<div class="flex items-center gap-3">
					<h3 class="text-base font-semibold text-gray-900">Daily Digest</h3>
					<span class="inline-flex items-center rounded-full bg-white border border-gray-200 px-2 py-0.5 text-xs text-gray-600">
						Once per day
					</span>
				</div>
				<p class="text-sm text-gray-600 mt-1">
					A summary of your tracked stocks, delivered using your selected
					notification channels.
				</p>
			</div>

			<label class="inline-flex items-center gap-2 cursor-pointer select-none">
				<input
					type="hidden"
					name="daily_digest_enabled"
					value="off"
				/>
				<input
					type="checkbox"
					name="daily_digest_enabled"
					value="on"
					id="daily_digest_enabled"
					class="h-4 w-4 cursor-pointer"
					checked={user.daily_digest_enabled}
				/>
				<span class="text-sm font-medium text-slate-700">
					Enabled
				</span>
			</label>
		</div>

		{needsSetup && (
			<div class="mt-4 rounded-lg border border-amber-200 bg-amber-50 p-4">
				<p class="text-sm font-medium text-amber-900">Setup required</p>
				<ul class="mt-2 space-y-1 text-sm text-amber-800">
					{needsChannelSelection && (
						<li>
							Enable at least one notification channel in{" "}
							<a
								href="#notification-preferences"
								class="font-medium text-amber-900 underline"
							>
								notification preferences
							</a>
							.
						</li>
					)}
					{needsPhoneVerification && (
						<li>
							Verify your phone number in{" "}
							<a
								href={`#${phoneVerificationSectionId}`}
								class="font-medium text-amber-900 underline"
							>
								SMS settings
							</a>
							{" "}to enable SMS deliveries.
						</li>
					)}
				</ul>
			</div>
		)}

		<div id="daily-digest-settings" class="mt-4 grid gap-4 sm:grid-cols-[1fr_auto] sm:items-end">
			<div>
				<label
					for="daily_digest_notification_time"
					class="block text-sm font-medium text-slate-700 mb-1"
				>
					Delivery time
				</label>
				<TimePicker
					client:idle
					inputId="daily_digest_notification_time"
					inputName="daily_digest_notification_time"
					initialTime={currentTime}
					disabled={!user.daily_digest_enabled}
				/>
			</div>

			<div class="sm:text-right">
				<button
					type="button"
					id="daily-digest-send-now"
					class="w-full sm:w-auto inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors cursor-pointer disabled:bg-gray-400 disabled:cursor-not-allowed"
				>
					Send now
				</button>
			</div>

			<div id="daily-digest-live-details" class="sm:col-span-2">
				<p class="text-xs text-gray-600">
					Your next daily digest will arrive in{" "}
					<span
						id="daily-digest-countdown"
						class="font-medium tabular-nums"
					></span><span
						id="daily-digest-arrival-time"
						class="font-medium"
					></span><span id="daily-digest-timezone" class="font-medium"></span>.
					{" "}If you want to change your timezone, please select a new one in{" "}
					<a
						href="#notification-preferences"
						class="text-blue-600 hover:text-blue-700 underline"
					>notification preferences</a>.
				</p>
			</div>
		</div>
	</div>
</div>

<div
	id="daily-digest-skip-modal"
	class="fixed inset-0 z-50 hidden"
	role="dialog"
	aria-modal="true"
	aria-labelledby="daily-digest-skip-modal-title"
>
	<button
		type="button"
		id="daily-digest-skip-modal-backdrop"
		class="absolute inset-0 bg-black/40"
		aria-label="Close"
	></button>
	<div class="relative mx-auto mt-24 w-[min(92vw,28rem)] rounded-xl bg-white shadow-lg border border-gray-200 p-5">
		<h3
			id="daily-digest-skip-modal-title"
			class="text-base font-semibold text-gray-900"
		>
			Send daily digest now
		</h3>
		<p class="mt-2 text-sm text-gray-700">
			Your next notification is due to send in{" "}
			<span id="daily-digest-skip-modal-due-in" class="font-medium"></span>. Would
			you like to skip the next notification?
		</p>

		<div class="mt-4 flex flex-col-reverse gap-2 sm:flex-row sm:justify-end">
			<button
				type="button"
				id="daily-digest-skip-modal-send-no-skip"
				class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-900 hover:bg-gray-50 cursor-pointer"
			>
				Send now
			</button>
			<button
				type="button"
				id="daily-digest-skip-modal-send-and-skip"
				class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 cursor-pointer"
			>
				Send now & skip next
			</button>
		</div>
	</div>
</div>

<script>
	import { initScheduledNotificationsCards } from "./scheduled-notifications";

	initScheduledNotificationsCards();
</script>
