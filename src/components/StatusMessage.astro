---
type StatusTone = "success" | "error" | "warning" | "info";

interface Props {
	message?: string;
	tone?: StatusTone;
	class?: string;
}

const { message, tone = "info", class: className } = Astro.props;

const toneClasses: Record<StatusTone, string> = {
	success: "status-tone-success",
	error: "status-tone-error",
	warning: "status-tone-warning",
	info: "status-tone-info",
};
---

<div
	class={`rounded-lg border p-4 text-sm font-medium ${toneClasses[tone]} ${className ?? ""}`}
	role="alert"
>
	{Astro.slots.default ? <slot /> : message}
</div>
