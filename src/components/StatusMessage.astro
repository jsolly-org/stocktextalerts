---
import { Icon } from "astro-icon/components";
import { type StatusTone, STATUS_TONE_CLASSES } from "../lib/constants";

interface Props {
	message?: string;
	tone?: StatusTone;
	class?: string;
}

const { message, tone = "info", class: className } = Astro.props;

const toneIcons: Record<StatusTone, string> = {
	success: "check-circle-24",
	error: "exclamation-circle-24",
	warning: "exclamation-triangle-24",
	info: "information-circle-20",
};
---

<div
	class={`rounded-lg border p-4 text-sm font-medium flex items-start gap-3 ${STATUS_TONE_CLASSES[tone]} ${className ?? ""}`}
	role="alert"
>
	<Icon name={toneIcons[tone]} class="size-5 shrink-0 mt-0.5" aria-hidden="true" />
	<span>{Astro.slots.default ? <slot /> : message}</span>
</div>
