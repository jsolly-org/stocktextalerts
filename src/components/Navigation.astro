---

import type { User } from "@supabase/supabase-js";
import { Icon } from "astro-icon/components";

interface Props {
	user?: User;
}
const { user } = Astro.props;
const currentPage = Astro.url.pathname;
const isLanding = currentPage === "/";
---
<nav
  aria-label="Main navigation"
  class="bg-white/80 backdrop-blur-md border-b border-gray-200 sticky top-0 z-50"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <div class="flex items-center gap-4 sm:gap-8">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group" aria-label="StockTextAlerts home">
          <div class="bg-primary text-white p-1.5 rounded-lg group-hover:bg-primary-strong transition-colors shadow-sm">
            <Icon name="presentation-chart-line" class="size-5" aria-hidden="true" focusable="false" />
          </div>
          <span class="text-xl font-bold text-gray-900 tracking-tight group-hover:text-primary transition-colors hidden sm:block">StockTextAlerts</span>
        </a>

        <!-- Main Nav Links -->
        <ul class="flex items-center gap-4 sm:gap-6">
          {!user && isLanding && (
            <li class="hidden md:block">
              <a href="#features" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">
                Features
              </a>
            </li>
          )}
          {user && (
            <li>
              <a 
                href="/dashboard"
                aria-current={currentPage === "/dashboard" ? "page" : undefined}
                class:list={[
                  "text-sm font-medium transition-colors px-3 py-1.5 rounded-lg",
                  currentPage === "/dashboard" ? "text-primary bg-primary/10" : "text-gray-600 hover:text-gray-900 hover:bg-gray-100"
                ]}
              >
                Dashboard
              </a>
            </li>
          )}
        </ul>
      </div>

      <!-- Right Actions -->
      <div class="flex items-center gap-4">
        {user ? (
          <div class="flex items-center gap-4">
            <a
              href="/profile"
              aria-label="Profile"
              aria-current={currentPage === "/profile" ? "page" : undefined}
              class:list={[
                "group rounded-full p-1 transition-colors",
                currentPage === "/profile" ? "bg-primary/10" : "bg-gray-100 hover:bg-gray-200"
              ]}
            >
              <Icon
                name="user-circle"
                class:list={[
                  "size-8",
                  currentPage === "/profile" ? "text-primary" : "text-gray-500 group-hover:text-gray-700"
                ]}
                aria-hidden="true"
                focusable="false"
              />
            </a>
            <span class="text-sm text-gray-500 hidden md:block font-medium truncate max-w-[200px]">{user.email}</span>
            <div class="h-4 w-px bg-gray-200 hidden md:block"></div>
            <form action="/api/auth/signout" method="post" class="flex">
              <button 
                type="submit" 
                class="btn btn-sm btn-ghost text-error-strong hover:text-error-strong"
              >
                Sign Out
              </button>
            </form>
          </div>
        ) : (
          <div class="flex items-center gap-3">
            <a href="/signin" class="btn btn-sm btn-ghost">Sign in</a>
            <a 
              href="/auth/register" 
              class="btn btn-sm btn-primary whitespace-nowrap"
            >
              Start Tracking
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</nav>
