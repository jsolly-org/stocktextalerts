---
import { CARD_GRADIENT_ACCENTS } from "../../lib/constants";

interface Props {
	email: string;
}
const { email } = Astro.props;
---
<section class="card mb-6" aria-labelledby="account-heading">
	<div class={`h-1 ${CARD_GRADIENT_ACCENTS.gray}`}></div>
	<div class="card-body">
		<h2 id="account-heading" class="text-2xl font-bold text-gray-900 mb-4">Account</h2>
	
		<div class="space-y-6">
			<div>
				<label for="email" class="block text-sm font-medium text-gray-700 mb-2">
					Current email
				</label>
				<input
					type="email"
					id="email"
					value={email}
					readonly
					class="w-full px-4 py-3 border border-gray-300 rounded-md bg-gray-100 text-gray-500"
				/>
			</div>
			<form
				class="space-y-3"
				action="/api/auth/update-email"
				method="post"
				data-current-email={email}
			>
				<div>
					<label
						for="new-email"
						class="block text-sm font-medium text-gray-700 mb-2"
					>
						New email
					</label>
					<input
						type="email"
						id="new-email"
						name="email"
						autocomplete="email"
						required
						class="w-full px-4 py-3 border border-gray-300 rounded-md"
						placeholder="you@company.com"
						aria-describedby="email-change-help"
					/>
					<p id="email-change-help" class="mt-2 text-sm text-gray-500">
						We will send confirmation links to both your current and new email
						addresses. The change only completes after both are confirmed.
					</p>
					<p
						id="email-same-feedback"
						class="mt-2 text-sm text-warning-text hidden"
						role="status"
						aria-live="polite"
					>
						This is already your current email address.
					</p>
				</div>
				<button
					id="save-email-btn"
					class="btn btn-md btn-primary"
					type="submit"
					disabled
				>
					Update email
				</button>
			</form>
		</div>
	</div>
</section>
<script>
	const form = document.querySelector(
		'form[action="/api/auth/update-email"]',
	) as HTMLFormElement | null;
	if (form) {
		const input = form.querySelector<HTMLInputElement>("#new-email");
		const submitBtn = form.querySelector<HTMLButtonElement>("#save-email-btn");
		const sameFeedback = form.querySelector<HTMLParagraphElement>(
			"#email-same-feedback",
		);
		const currentEmail =
			form.dataset.currentEmail?.trim().toLowerCase() ?? "";

		if (input && submitBtn && sameFeedback) {
			const updateState = () => {
				const newEmail = input.value.trim().toLowerCase();
				const isSame =
					currentEmail.length > 0 && newEmail.length > 0 && newEmail === currentEmail;

				sameFeedback.classList.toggle("hidden", !isSame);
				submitBtn.disabled =
					!input.validity.valid || !input.value.trim() || isSame;
			};
			input.addEventListener("input", updateState);
			input.addEventListener("change", updateState);
			updateState();
		}
	}
</script>
