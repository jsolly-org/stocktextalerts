---
import { Icon } from "astro-icon/components";
import { MIN_PASSWORD_LENGTH } from "../../lib/auth-constants";

interface Props {
	email: string;
}
const { email } = Astro.props;
---
<section class="card mb-6" aria-labelledby="account-heading">
	<div class="card-accent card-accent-gray"></div>
	<div class="card-body">
		<div class="flex items-center gap-3 mb-2">
			<div class="flex items-center justify-center w-10 h-10 rounded-lg bg-surface-active">
				<Icon name="envelope" class="size-5 text-body-secondary" aria-hidden="true" />
			</div>
			<h2 id="account-heading" class="text-2xl font-bold text-heading">Account</h2>
		</div>
		<p class="text-body-secondary text-sm mb-6">Manage your email address.</p>
	
		<div class="space-y-6">
			<div>
				<label for="email" class="block text-sm font-medium text-label mb-1">
					Current email
				</label>
				<input
					type="email"
					id="email"
					value={email}
					readonly
					aria-readonly="true"
					class="input input-lg bg-surface-alt text-muted cursor-not-allowed select-all"
				/>
			</div>
			<form
				class="space-y-4"
				action="/api/auth/update-email"
				method="post"
				data-current-email={email}
			>
				<div>
					<label
						for="new-email"
						class="block text-sm font-medium text-label mb-1"
					>
						New email
					</label>
					<input
						type="email"
						id="new-email"
						name="email"
						autocomplete="email"
						required
						class="input input-lg"
						placeholder="you@company.com&hellip;"
						aria-describedby="email-change-help email-same-feedback"
					/>
					<p id="email-change-help" class="mt-2 text-sm text-muted">
						We will send confirmation links to both your current and new email
						addresses. The change only completes after both are confirmed.
					</p>
					<p
						id="email-same-feedback"
						class="mt-2 text-sm text-warning-text hidden"
						role="status"
						aria-live="polite"
					>
						This is already your current email address.
					</p>
				</div>
				<button
					id="save-email-btn"
					class="btn btn-md btn-primary"
					type="submit"
					data-submit-loading
				>
					Update email
				</button>
			</form>

			<form
				class="space-y-4 border-t border-edge pt-6"
				action="/api/auth/change-password"
				method="post"
			>
				<input type="hidden" name="email" autocomplete="username" value={email} />
				<fieldset class="space-y-4">
					<legend class="text-sm font-medium text-label">
						Change password
					</legend>
					<div>
						<label
							for="new-password"
							class="block text-sm font-medium text-label mb-1"
						>
							New password
						</label>
						<input
							type="password"
							id="new-password"
							name="password"
							autocomplete="new-password"
							required
							minlength={MIN_PASSWORD_LENGTH}
							class="input input-lg"
							placeholder="••••••••"
							aria-describedby="password-change-help"
						/>
						<p id="password-change-help" class="mt-2 text-sm text-muted">
							Use at least {MIN_PASSWORD_LENGTH} characters.
						</p>
					</div>
				</fieldset>
				<button
					id="save-password-btn"
					class="btn btn-md btn-primary"
					type="submit"
					data-submit-loading
				>
					Update password
				</button>
			</form>
		</div>
	</div>
</section>
<script>
	const form = document.querySelector(
		'form[action="/api/auth/update-email"]',
	) as HTMLFormElement | null;
	if (form) {
		const input = form.querySelector<HTMLInputElement>("#new-email");
		const submitBtn = form.querySelector<HTMLButtonElement>("#save-email-btn");
		const sameFeedback = form.querySelector<HTMLParagraphElement>(
			"#email-same-feedback",
		);
		const currentEmail =
			form.dataset.currentEmail?.trim().toLowerCase() ?? "";

		if (input && submitBtn && sameFeedback) {
			const updateState = () => {
				const newEmail = input.value.trim().toLowerCase();
				const isSame =
					currentEmail.length > 0 && newEmail.length > 0 && newEmail === currentEmail;

				sameFeedback.classList.toggle("hidden", !isSame);
				submitBtn.disabled =
					!input.validity.valid || !input.value.trim() || isSame;
			};
			input.addEventListener("input", updateState);
			input.addEventListener("change", updateState);
			updateState();
		}
	}

</script>
