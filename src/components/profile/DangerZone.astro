---

interface Props {
	action?: string;
}
const { action = "/api/auth/delete-account" } = Astro.props;
---
<section class="bg-error-bg/50 rounded-xl shadow-sm border border-error-border p-8" aria-labelledby="danger-zone-heading">
	<h2 id="danger-zone-heading" class="text-xl font-bold text-error-strong mb-2">Danger Zone</h2>
	<p class="text-gray-600 mb-6">
		Once you delete your account, there is no going back. Please be certain.
	</p>

	<form data-profile-delete-form action={action} method="post">
		<fieldset>
			<legend class="sr-only">Delete account</legend>
			<button
				type="submit"
				class="btn btn-md btn-danger"
			>
				Delete Account
			</button>
		</fieldset>
	</form>
</section>

<script>
	import { rootLogger } from "../../lib/logging";

	const forms = document.querySelectorAll('[data-profile-delete-form]');
	if (forms.length === 0) {
		rootLogger.error("Delete account form not found", {
			selector: "[data-profile-delete-form]",
		});
	}

	forms.forEach((form) => {
		if (!(form instanceof HTMLFormElement)) {
			return;
		}

		form.addEventListener("submit", (event) => {
			const confirmed = confirm(
				"Are you sure you want to delete your account? This action cannot be undone.",
			);

			if (!confirmed) {
				event.preventDefault();
			}
		});
	});
</script>

