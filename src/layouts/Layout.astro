---
import { Icon } from "astro-icon/components";
import "../global.css";
import { REGISTRATION_ENABLED } from "../lib/constants";
interface Props {
	title: string;
	description: string;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
	/** Suppress the "registrations closed" banner (set on the authenticated app pages). */
	hideRegistrationBanner?: boolean;
}
const { title, description, jsonLd, hideRegistrationBanner }: Props = Astro.props;
const showRegistrationBanner = !REGISTRATION_ENABLED && !hideRegistrationBanner;

function escapeJsonForHtml(json: string): string {
	// JSON-LD is injected via set:html, so we must prevent script-breakout if any
	// future field contains `</script>` or raw `<`/`>`/`&`.
	return json
		.replaceAll("&", "\\u0026")
		.replaceAll("<", "\\u003c")
		.replaceAll(">", "\\u003e");
}

const jsonLdHtml = jsonLd ? escapeJsonForHtml(JSON.stringify(jsonLd)) : null;
// Astro.site may be undefined when using AstroContainer (container-based tests),
// even if 'site' is configured in vitest.config.ts. Without this fallback,
// new URL(Astro.url.pathname, undefined) would throw a TypeError.
const canonicalBase = Astro.site ?? Astro.url;
const canonicalURL = new URL(Astro.url.pathname, canonicalBase);
// Replace with your own image
const socialImageURL = new URL("/images/opengraph-image.jpg", canonicalBase);
// Omit manifest on Vercel preview to avoid 401 from Deployment Protection; use host fallback if env unset.
const requestHost = Astro.url.host;
const isVercelPreviewByHost =
	requestHost.endsWith(".vercel.app") &&
	(requestHost.split(".")[0] ?? "").includes("-");
const omitManifestOnVercel =
	(process.env.VERCEL === "1" && process.env.VERCEL_ENV !== "production") ||
	isVercelPreviewByHost;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111827" media="(prefers-color-scheme: dark)" />
    <meta name="generator" content={Astro.generator} />
    <!-- Private app: every page stays out of search indexes. Static pages bypass
         middleware on Vercel, so this build-baked meta is what covers them. -->
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicons -->
    <link rel="icon" href="/favicons/favicon.ico" />
    <link
        rel="apple-touch-icon"
        sizes="180x180"
        href="/favicons/apple-touch-icon.png"
    />
    <link
        rel="icon"
        type="image/png"
        sizes="32x32"
        href="/favicons/favicon-32x32.png"
    />
    <link
        rel="icon"
        type="image/png"
        sizes="16x16"
        href="/favicons/favicon-16x16.png"
    />
    <link
        rel="icon"
        sizes="192x192"
        href="/favicons/android-chrome-192x192.png"
    />
    <link
        rel="icon"
        sizes="512x512"
        href="/favicons/android-chrome-512x512.png"
    />
    <!-- On protected Vercel Preview deploys, the browser's manifest request can 401 and spam console noise. -->
    {!omitManifestOnVercel && <link rel="manifest" href="/favicons/site.webmanifest" />}

    <!-- Open Graph / Meta (formerly Facebook) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="StockTextAlerts with a stock candlestick chart and Start Notifications call-to-action" />

    <!-- X (formerly Twitter) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />

    {jsonLdHtml && (
      <script is:inline type="application/ld+json" set:html={jsonLdHtml} />
    )}

    <slot name="head" />
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus-visible:not-sr-only focus-visible:absolute focus-visible:top-4 focus-visible:left-4 focus-visible:z-50 focus-visible:px-4 focus-visible:py-2 focus-visible:bg-primary focus-visible:text-white focus-visible:rounded-lg focus-visible:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-primary focus-visible:shadow-lg"
    >
      Skip to main content
    </a>
    {showRegistrationBanner && (
      <div class="status-tone-info border-b px-4 py-2 text-center text-sm font-medium">
        New registrations are closed — StockTextAlerts is a private application.
      </div>
    )}
    <slot />
    <a
      href="mailto:support@stocktextalerts.com"
      class="fixed bottom-4 right-4 z-50 flex items-center gap-1.5 rounded-full border border-edge/60 bg-surface-alt/85 px-3 py-1.5 text-xs text-label shadow-sm backdrop-blur-md backdrop-saturate-150 transition-colors hover:text-primary"
      aria-label="Contact support via email"
    >
      <Icon name="envelope" class="size-3.5" aria-hidden="true" />
      Support
    </a>
    <script>
      (() => {
        const MOBILE_MEDIA_QUERY = "(max-width: 767.99px)";
        const FOCUSED_FIELD_PADDING_PX = 16;
        const FOCUSED_FIELD_CENTER_TOLERANCE_PX = 12;
        const FOCUS_RETRY_DELAY_MS = 300;

        let activeFocusedField: HTMLElement | null = null;
        let focusScrollFrame: number | null = null;
        let focusScrollTimeout: ReturnType<typeof setTimeout> | null = null;

        const getScrollBehavior = () =>
          window.matchMedia("(prefers-reduced-motion: reduce)").matches
            ? "auto"
            : "smooth";

        const isMobileViewport = () => window.matchMedia(MOBILE_MEDIA_QUERY).matches;

        const clearPendingFocusScroll = () => {
          if (focusScrollFrame !== null) {
            cancelAnimationFrame(focusScrollFrame);
            focusScrollFrame = null;
          }
          if (focusScrollTimeout !== null) {
            clearTimeout(focusScrollTimeout);
            focusScrollTimeout = null;
          }
        };

        const getScrollableFormField = (target: EventTarget | null): HTMLElement | null => {
          const field =
            target instanceof HTMLElement
              ? target.closest(
                  "input, textarea, select, [contenteditable]:not([contenteditable='false'])",
                )
              : null;
          if (!(field instanceof HTMLElement)) return null;
          if (field instanceof HTMLInputElement && field.type === "hidden") return null;
          if (field instanceof HTMLInputElement && field.readOnly) return null;
          return field;
        };

        const isScrollableElement = (element: HTMLElement | null): boolean => {
          if (!(element instanceof HTMLElement)) return false;
          const style = window.getComputedStyle(element);
          const overflowY = style.overflowY;
          if (overflowY !== "auto" && overflowY !== "scroll") return false;
          return element.scrollHeight > element.clientHeight + 1;
        };

        const isViewportScrollContainer = (element: HTMLElement): boolean =>
          element === document.scrollingElement ||
          element === document.documentElement ||
          element === document.body;

        const getScrollContainer = (field: HTMLElement): HTMLElement => {
          let current = field.parentElement;
          while (current) {
            if (isScrollableElement(current)) {
              return current;
            }
            current = current.parentElement;
          }
          return document.scrollingElement instanceof HTMLElement
            ? document.scrollingElement
            : document.documentElement;
        };

        const scrollFieldIntoView = (field: HTMLElement): void => {
          if (!isMobileViewport() || !field.isConnected) return;

          const container = getScrollContainer(field);
          if (!(container instanceof HTMLElement)) return;

          const isViewportContainer = isViewportScrollContainer(container);
          const fieldRect = field.getBoundingClientRect();
          const containerRect =
            isViewportContainer
              ? { top: 0, bottom: window.innerHeight, height: window.innerHeight }
              : container.getBoundingClientRect();

          const visualViewport = window.visualViewport;
          const viewportTop = visualViewport?.offsetTop ?? 0;
          const viewportBottom =
            (visualViewport?.offsetTop ?? 0) +
            (visualViewport?.height ?? window.innerHeight);
          const visibleTop =
            Math.max(containerRect.top, viewportTop) + FOCUSED_FIELD_PADDING_PX;
          const visibleBottom =
            Math.min(containerRect.bottom, viewportBottom) - FOCUSED_FIELD_PADDING_PX;

          const fallbackScrollIntoView = () => {
            field.scrollIntoView({
              behavior: getScrollBehavior(),
              block: "center",
              inline: "nearest",
            });
          };

          if (visibleBottom <= visibleTop) {
            fallbackScrollIntoView();
            return;
          }

          const desiredCenter = visibleTop + (visibleBottom - visibleTop) / 2;
          const fieldCenter = fieldRect.top + fieldRect.height / 2;

          if (
            Math.abs(fieldCenter - desiredCenter) <= FOCUSED_FIELD_CENTER_TOLERANCE_PX
          ) {
            return;
          }

          const maxScrollTop = Math.max(0, container.scrollHeight - container.clientHeight);

          if (maxScrollTop === 0) {
            fallbackScrollIntoView();
            return;
          }

          const currentScrollTop = isViewportContainer ? window.scrollY : container.scrollTop;

          const fieldOffsetTop = fieldRect.top - containerRect.top + currentScrollTop;
          const desiredCenterWithinContainer = desiredCenter - containerRect.top;
          const nextScrollTop = Math.max(
            0,
            Math.min(
              fieldOffsetTop + fieldRect.height / 2 - desiredCenterWithinContainer,
              maxScrollTop,
            ),
          );

          if (Math.abs(nextScrollTop - currentScrollTop) <= 1) {
            return;
          }

          if (isViewportContainer) {
            window.scrollTo({ top: nextScrollTop, behavior: getScrollBehavior() });
            return;
          }

          container.scrollTo({ top: nextScrollTop, behavior: getScrollBehavior() });
        };

        const syncFocusedFieldIntoView = () => {
          const field = getScrollableFormField(document.activeElement);
          if (!field) {
            activeFocusedField = null;
            clearPendingFocusScroll();
            return;
          }

          activeFocusedField = field;
          clearPendingFocusScroll();
          focusScrollFrame = requestAnimationFrame(() => {
            scrollFieldIntoView(field);
            // iOS often reports the final keyboard-adjusted viewport slightly later.
            focusScrollTimeout = setTimeout(() => {
              scrollFieldIntoView(field);
            }, FOCUS_RETRY_DELAY_MS);
          });
        };

        const handleFocusIn = (event: FocusEvent): void => {
          if (!isMobileViewport()) return;
          const field = getScrollableFormField(event.target);
          if (!field) return;
          activeFocusedField = field;
          syncFocusedFieldIntoView();
        };

        const handleFocusOut = (): void => {
          requestAnimationFrame(() => {
            if (getScrollableFormField(document.activeElement)) return;
            activeFocusedField = null;
            clearPendingFocusScroll();
          });
        };

        const handleVisualViewportChange = () => {
          if (!isMobileViewport() || !activeFocusedField) return;
          syncFocusedFieldIntoView();
        };

        document.addEventListener(
          "submit",
          (event) => {
            const form = event.target;
            if (!(form instanceof HTMLFormElement)) {
              return;
            }

            const submitter = event.submitter;
            const button =
              submitter instanceof HTMLButtonElement
                ? submitter
                : form.querySelector("button[type='submit'][data-submit-loading]");

            if (
              !(button instanceof HTMLButtonElement) ||
              !button.hasAttribute("data-submit-loading")
            ) {
              return;
            }

            button.disabled = true;
            button.setAttribute("aria-busy", "true");
            button.classList.add("btn-loading");
          },
          { capture: true },
        );

        document.addEventListener("focusin", handleFocusIn, { capture: true });
        document.addEventListener("focusout", handleFocusOut, { capture: true });
        window.visualViewport?.addEventListener("resize", handleVisualViewportChange);
        window.visualViewport?.addEventListener("scroll", handleVisualViewportChange);
      })();
    </script>
  </body>
</html>
