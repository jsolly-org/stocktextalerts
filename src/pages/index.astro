---

import CTA from "../components/landing/CTA.astro";
import Features from "../components/landing/Features.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/landing/Hero.astro";
import HowItWorks from "../components/landing/HowItWorks.astro";
import Navigation from "../components/Navigation.astro";
import StatusMessage from "../components/StatusMessage.astro";
import Layout from "../layouts/Layout.astro";
import { isUserApproved } from "../lib/auth/approval/status";
import { createUserService } from "../lib/auth/user-service";
import { createSupabaseServerClient } from "../lib/db/supabase";
import { formatMessage } from "../lib/messaging/status-messages";

const supabase = createSupabaseServerClient();
const users = createUserService(supabase, Astro.cookies);
// The landing page is for anonymous visitors only. Signed-in users are bounced to
// where they belong (mirrors dashboard.astro's approval branch): approved → dashboard,
// awaiting approval → pending page. An orphaned auth cookie with no users row falls
// through to the anonymous landing.
const authUser = await users.getCurrentUser({ requireApproval: false });
if (authUser) {
  const dbUser = await users.getById(authUser.id);
  if (dbUser && isUserApproved(dbUser)) {
    return Astro.redirect("/dashboard");
  }
  if (dbUser) {
    return Astro.redirect("/auth/pending-approval");
  }
}
const search = Astro.url.searchParams;
const errorMessage = formatMessage(search.get("error"));
const successMessage = formatMessage(search.get("success"));

const siteUrl = (Astro.site?.href ?? Astro.url.origin).replace(/\/$/, "");
const jsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		"name": "StockTextAlerts",
		"url": siteUrl,
	},
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		"name": "StockTextAlerts",
		"url": siteUrl,
		"logo": `${siteUrl}/favicons/android-chrome-512x512.png`,
		"description": "Get scheduled updates for your tracked assets via email and optional Telegram. Track US assets and set your preferred delivery times.",
	},
];
---
<Layout title="Free Stock & ETF Price Alerts via Email & Telegram | StockTextAlerts" description="Get free stock and ETF price alerts via email or Telegram on your schedule. Track US-listed assets with up to five daily delivery times." jsonLd={jsonLd}>
  <div class="min-h-screen bg-surface">
    <header>
      <Navigation user={authUser ?? undefined} />
    </header>

    <main id="main-content">
      {(errorMessage || successMessage) && (
        <div class="max-w-5xl mx-auto px-4 pt-6 sm:px-6">
          {errorMessage && (
            <StatusMessage class="mb-4" tone="error" message={errorMessage} />
          )}
          {successMessage && (
            <StatusMessage class="mb-4" tone="success" message={successMessage} />
          )}
        </div>
      )}
      
      <Hero />

      <HowItWorks />
      <Features />
      <CTA />
    </main>
    <Footer />
  </div>
</Layout>
