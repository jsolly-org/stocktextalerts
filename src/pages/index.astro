---

import CTA from "../components/landing/CTA.astro";
import Features from "../components/landing/Features.astro";
import Footer from "../components/landing/Footer.astro";
import Hero from "../components/landing/Hero.astro";
import HowItWorks from "../components/landing/HowItWorks.astro";
import Navigation from "../components/Navigation.astro";
import StatusMessage from "../components/StatusMessage.astro";
import Layout from "../layouts/Layout.astro";
import { createUserService } from "../lib/db";
import { createSupabaseServerClient } from "../lib/db/supabase";
import { formatMessage } from "../lib/constants";

const supabase = createSupabaseServerClient();
const users = createUserService(supabase, Astro.cookies);
const user = await users.getCurrentUser();
const isAuthenticated = !!user;
const search = Astro.url.searchParams;
const errorMessage = formatMessage(search.get("error"));
const successMessage = formatMessage(search.get("success"));

const siteUrl = Astro.site?.href ?? Astro.url.origin;
const jsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		"name": "StockTextAlerts",
		"url": siteUrl,
	},
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		"name": "StockTextAlerts",
		"url": siteUrl,
		"logo": `${siteUrl}/favicons/android-chrome-512x512.png`,
		"description": "Get a daily digest for your tracked stocks via email and optional SMS. Track US stocks, set your preferred time and timezone.",
	},
];
---
<Layout title="Stock Text Alerts | Daily Stock Digest via Email & SMS" description="Get a daily digest for your tracked stocks via email and optional SMS. Track US stocks, set your preferred time and timezone." jsonLd={jsonLd}>
  <div class="min-h-screen bg-white">
    <header>
      <Navigation user={user || undefined} />
    </header>

    <main id="main-content">
      {(errorMessage || successMessage) && (
        <div class="max-w-5xl mx-auto px-4 pt-6 sm:px-6">
          {errorMessage && (
            <StatusMessage class="mb-4" tone="error" message={errorMessage} />
          )}
          {successMessage && (
            <StatusMessage class="mb-4" tone="success" message={successMessage} />
          )}
        </div>
      )}
      
      <Hero isAuthenticated={isAuthenticated} />

      <HowItWorks />
      <Features />
      <CTA isAuthenticated={isAuthenticated} />
    </main>
    <Footer />
  </div>
</Layout>
