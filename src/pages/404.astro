---
import { Icon } from "astro-icon/components";
import Navigation from "../components/Navigation.astro";
import Layout from "../layouts/Layout.astro";

export const prerender = true;
---
<Layout title="404 - Page Not Found | StockTextAlerts" description="The page you're looking for doesn't exist.">
  <div class="min-h-screen bg-surface flex flex-col">
    <header>
      <Navigation />
    </header>

    <main id="main-content" class="flex-1 flex items-center justify-center relative overflow-hidden">
      <!-- Decorative background elements -->
      <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="absolute -top-40 -right-32 w-80 h-80 bg-blue-100 rounded-full opacity-50 blur-3xl"></div>
        <div class="absolute -bottom-40 -left-32 w-80 h-80 bg-primary/10 rounded-full opacity-50 blur-3xl"></div>
      </div>

      <div class="relative z-10 max-w-lg mx-auto px-4 py-16 text-center animate-fade-in">
        <!-- Fake ticker display -->
        <div class="mb-8">
          <div class="inline-flex items-center gap-2 bg-surface-active rounded-full px-4 py-2 text-sm text-body-secondary mb-6">
            <Icon name="presentation-chart-line" class="w-4 h-4 text-primary" aria-hidden="true" />
            <span class="font-medium">PAGE</span>
            <span class="text-error-strong font-bold">-100%</span>
          </div>
        </div>

        <!-- Animated downward chart -->
        <div class="crash-chart relative h-32 mb-8" aria-hidden="true">
          <Icon name="chart-crash" class="w-full h-full" />
        </div>

        <!-- 404 text -->
        <h1 class="text-7xl sm:text-8xl font-extrabold text-heading mb-4">
          <span class="bg-linear-to-r from-error-strong to-red-400 bg-clip-text text-transparent">404</span>
        </h1>
        
        <h2 class="text-2xl sm:text-3xl font-bold text-heading mb-4">
          Ticker Not Found
        </h2>
        
        <p class="text-body-secondary text-lg mb-8 max-w-md mx-auto">
          Looks like this page took a nosedive. The URL you're looking for doesn't exist or has been delisted.
        </p>

        <!-- Action buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/" class="btn btn-lg btn-primary w-full sm:w-auto">
            <Icon name="arrow-left" class="w-5 h-5 mr-2" aria-hidden="true" />
            Back to Home
          </a>
          <a href="/dashboard" class="btn btn-lg btn-secondary w-full sm:w-auto">
            <Icon name="chart-bar" class="w-5 h-5 mr-2" aria-hidden="true" />
            Go to Dashboard
          </a>
        </div>

        <!-- Fun footer note -->
        <p class="mt-12 text-sm text-faint">
          Don't worry, your real assets are doing better than this page.
        </p>
      </div>
    </main>
  </div>
</Layout>

<style>
  .crash-chart :global(.chart-line) {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    animation: draw-line 1.5s ease-out forwards;
  }

  .crash-chart :global(.chart-area) {
    opacity: 0;
    animation: fade-in-area 0.5s ease-out 1s forwards;
  }

  @keyframes draw-line {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes fade-in-area {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .crash-chart :global(.chart-line),
    .crash-chart :global(.chart-area) {
      animation: none;
      stroke-dashoffset: 0;
      opacity: 1;
    }
  }
</style>
