---
import Footer from "../../components/Footer.astro";
import Navigation from "../../components/Navigation.astro";
import Layout from "../../layouts/Layout.astro";

export const prerender = true;

const LAST_UPDATED = "February 9, 2026"; // update when policy changes

const siteUrl = (Astro.site?.href ?? Astro.url.origin).replace(/\/$/, "");
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
		{ "@type": "ListItem", "position": 2, "name": "Privacy Policy", "item": `${siteUrl}/legal/privacy` },
	],
};
---

<Layout
  title="Privacy Policy | StockTextAlerts"
  description="Learn how StockTextAlerts collects, uses, and protects your personal information including email, phone number, and usage data for stock and ETF alert services."
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-surface">
    <header>
      <Navigation />
    </header>
    <main id="main-content" class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-8 text-balance">Privacy Policy</h1>

      <div class="prose prose-sm max-w-none space-y-6">
        <section>
          <h2 class="text-2xl font-semibold mb-4">Introduction</h2>
          <p>StockTextAlerts (&ldquo;we,&rdquo; &ldquo;us,&rdquo; &ldquo;the Company&rdquo;) is committed to protecting privacy. This Privacy Policy explains how we collect, use, disclose, and safeguard data when you visit the website and use our services.</p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">Information We Collect</h2>
          <p>We may collect data in a variety of ways. Data collected on the site includes:</p>
          <ul class="list-disc ml-6 space-y-2">
            <li><strong>Personal Data:</strong> Email address, phone number, and other details provided voluntarily during account registration</li>
            <li><strong>Device Data:</strong> Device details including IP address, browser type, and operating system</li>
            <li><strong>Usage Data:</strong> Details about service interaction, including features used and settings configured</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">How We Use Your Information</h2>
          <p>Collected data is used for the following purposes:</p>
          <ul class="list-disc ml-6 space-y-2">
            <li>To provide, maintain, and improve services</li>
            <li>To send you stock and ETF alerts and notifications via SMS or email</li>
            <li>To communicate with you regarding updates, support, and account information</li>
            <li>To enforce terms and conditions and protect against fraudulent activity</li>
            <li>To comply with legal obligations</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">SMS Communications</h2>
          <p>When you opt-in to receive SMS notifications, you consent to receive text messages from StockTextAlerts. Standard message and data rates may apply. You can opt-out of SMS communications at any time by adjusting your notification channels in your account settings.</p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">Data Security</h2>
          <p>We implement appropriate technical and organizational measures designed to protect personal data against unauthorized access, alteration, disclosure, or destruction. However, no method of transmission over the internet or electronic storage is 100% secure.</p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">Third-Party Services</h2>
          <p>We may use third-party service providers to operate the website and support business operations. These third parties may access personal data to perform tasks on our behalf and are required to maintain confidentiality.</p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">Your Rights</h2>
          <p>Depending on location, you may have rights regarding personal data, including rights to access, correct, update, or delete personal data. To exercise these rights, contact us at the address below.</p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">Changes to This Privacy Policy</h2>
          <p>We may update this Privacy Policy from time to time to reflect changes in our practices or for other operational, legal, or regulatory reasons. We will notify you of any material changes by updating the date of this policy and posting the updated policy on our website.</p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">Contact Us</h2>
          <p>If you have questions about this Privacy Policy or our privacy practices, please contact us at <a href="mailto:support@stocktextalerts.com" class="link-primary">support@stocktextalerts.com</a>.</p>
        </section>
      </div>

      <div class="mt-12 text-sm text-body-secondary">
        <p>Last updated: {LAST_UPDATED}</p>
      </div>
    </main>
    <Footer />
  </div>
</Layout>
