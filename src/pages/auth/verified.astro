---

import { Icon } from "astro-icon/components";
import Layout from "../../layouts/Layout.astro";
import {
	type SupabaseEmailOtpType,
	isConsumedEmailOtpError,
	verifySupabaseOtp,
} from "../../lib/auth/supabase-otp";
import { clearAuthCookies } from "../../lib/auth/session/cookies";
import { createUserService } from "../../lib/auth/user-service";
import {
	createSupabaseAdminClient,
	createSupabaseServerClient,
} from "../../lib/db/supabase";
import { rootLogger } from "../../lib/logging";

const supabase = createSupabaseServerClient();
const userService = createUserService(supabase, Astro.cookies);

function parseOtpType(value: string | null): SupabaseEmailOtpType | null {
	if (value === "email" || value === "email_change") {
		return value;
	}
	return null;
}

let showConfirmForm = false;
let formTokenHash = "";
let formType: SupabaseEmailOtpType = "email";

if (Astro.request.method === "POST") {
	// ── POST: user clicked "Verify my email" ──
	// Token verification is deferred to POST so that email link scanners
	// (which prefetch GET URLs) don't consume the single-use OTP token
	// before the real user clicks. See:
	// https://supabase.com/docs/guides/troubleshooting/otp-verification-failures-token-has-expired-or-otp_expired-errors-5ee4d0
	const formData = await Astro.request.formData();
	const tokenHashValue = formData.get("token_hash");
	const typeValue = formData.get("type");
	const tokenHash =
		typeof tokenHashValue === "string" ? tokenHashValue : null;
	const type = parseOtpType(typeof typeValue === "string" ? typeValue : null);

	if (!tokenHash || !type) {
		return Astro.redirect("/auth/signin?error=invalid_verification");
	}

	const { data, error } = await verifySupabaseOtp(supabase, {
		token_hash: tokenHash,
		type,
	});

	if (error || !data?.user) {
		const errorCode = error?.code ?? "unknown";
		const benignEmailChangeFailure =
			type === "email_change" &&
			!data?.user &&
			(isConsumedEmailOtpError(error) || error == null);
		if (benignEmailChangeFailure) {
			// Double-confirm flows may POST a consumed link or return no user shape.
			rootLogger.info("Email change confirmation link already used or expired", {
				type,
				errorCode,
			});
			return Astro.redirect("/auth/signin?success=email_updated");
		}
		if (type === "email" && isConsumedEmailOtpError(error)) {
			rootLogger.info("Signup confirmation link already used or expired", {
				type,
				errorCode,
			});
			return Astro.redirect("/auth/signin?error=invalid_verification");
		}
		rootLogger.error(
			"Email verification token validation failed",
			{
				tokenHashPresent: true,
				type,
				hasUser: Boolean(data?.user),
				errorCode,
			},
			error,
		);
		return Astro.redirect("/auth/signin?error=invalid_verification");
	}

	// Only meaningful for signup confirmation. For email_change with
	// double_confirm_changes, the user is already confirmed (we're swapping
	// which email, not creating a new account), and the second click of the
	// double-confirm fires with no session — Supabase returns a partial user
	// shape there, which would falsely trip this check.
	if (type === "email" && !data.user.email_confirmed_at) {
		rootLogger.error("User email not confirmed after token verification", {
			userId: data.user.id,
		});
		return Astro.redirect("/auth/signin?error=verification_failed");
	}

	if (type === "email_change") {
		const adminClient = createSupabaseAdminClient();
		const { data: authData, error: authError } =
			await adminClient.auth.admin.getUserById(data.user.id);
		if (authError || !authData?.user?.email) {
			rootLogger.error(
				"Failed to load updated auth email after verification",
				{
					userId: data.user.id,
					hasEmail: Boolean(authData?.user?.email),
				},
				authError ?? undefined,
			);
			return Astro.redirect("/profile?error=email_change_failed");
		}

		const normalizedEmail = authData.user.email.trim();
		const { error: updateError } = await adminClient
			.from("users")
			.update({ email: normalizedEmail })
			.eq("id", data.user.id);

		if (updateError) {
			rootLogger.error(
				"Failed to sync updated email to user profile",
				{ userId: data.user.id, email: normalizedEmail },
				updateError,
			);
			return Astro.redirect("/profile?error=email_change_failed");
		}

		clearAuthCookies(Astro.cookies);
		return Astro.redirect("/auth/signin?success=email_updated");
	}
} else {
	// ── GET ──
	const tokenHash = Astro.url.searchParams.get("token_hash");
	const type = parseOtpType(Astro.url.searchParams.get("type"));

	// If token_hash is present but type is invalid/missing, treat link as invalid
	// and immediately remove the raw token from the URL.
	if (tokenHash && type === null) {
		const cleanedUrl = new URL(Astro.url);
		cleanedUrl.searchParams.delete("token_hash");
		cleanedUrl.searchParams.delete("type");
		return Astro.redirect(
			`${cleanedUrl.pathname}${cleanedUrl.search}${cleanedUrl.hash}`,
		);
	}

	if (tokenHash && type) {
		// Don't verify yet — render a confirmation form so email link
		// prefetchers don't consume the single-use token.
		showConfirmForm = true;
		formTokenHash = tokenHash;
		formType = type;
	} else {
		// No token_hash — check if user has a valid session with confirmed email.
		// This handles cases where Supabase already verified the token before redirect.
		const user = await userService.getCurrentUser();
		if (!user || !user.email_confirmed_at) {
			rootLogger.info("No valid session or email not confirmed", {
				hasSession: Boolean(user),
				emailConfirmed: Boolean(user?.email_confirmed_at),
			});
			return Astro.redirect("/auth/signin?error=invalid_verification");
		}
	}
}

const title = showConfirmForm ? "Confirm Your Email" : "Email Verified";
const description = showConfirmForm
	? "Click the button below to confirm your email address."
	: "Your email has been successfully verified. You can now sign in to StockTextAlerts to manage your tracked assets and notification channels.";
---
<Layout title={title} description={description}>
  <main id="main-content" class="min-h-screen flex items-center justify-center bg-surface-alt py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
      {showConfirmForm ? (
        <>
          <header class="text-center">
            <div class="mx-auto h-12 w-12 flex items-center justify-center rounded-full bg-info-bg">
              <Icon name="envelope" class="h-6 w-6 text-info-text" aria-hidden="true" />
            </div>
            <h1 class="mt-6 text-center text-2xl sm:text-3xl font-extrabold text-heading">
              Confirm Your Email
            </h1>
            <p class="mt-2 text-center text-sm text-body-secondary">
              Click the button below to finish verifying your email address.
            </p>
          </header>

          <section class="mt-8">
            <form method="POST" action="/auth/verified">
              <input type="hidden" name="token_hash" value={formTokenHash} />
              <input type="hidden" name="type" value={formType} />
              <button type="submit" class="btn btn-md btn-primary w-full">
                Verify my email
              </button>
            </form>
          </section>
        </>
      ) : (
        <>
          <header class="text-center">
            <div class="mx-auto h-12 w-12 flex items-center justify-center rounded-full bg-success-bg">
              <Icon name="check" class="h-6 w-6 text-success-text" aria-hidden="true" />
            </div>
            <h1 class="mt-6 text-center text-2xl sm:text-3xl font-extrabold text-heading">
              Email Verified!
            </h1>
            <p class="mt-2 text-center text-sm text-body-secondary">
              You&rsquo;re all set. You can now sign in to your account.
            </p>
          </header>

          <section class="mt-8">
            <a
              href="/auth/signin"
              class="btn btn-md btn-primary w-full"
            >
              Sign In
            </a>
          </section>
        </>
      )}
    </div>
  </main>
</Layout>
