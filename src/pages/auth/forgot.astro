---

import { Icon } from "astro-icon/components";
import HCaptcha from "../../components/HCaptcha.astro";
import EmailInput from "../../components/forms/EmailInput.vue";
import Navigation from "../../components/Navigation.astro";
import StatusMessage from "../../components/StatusMessage.astro";
import Layout from "../../layouts/Layout.astro";
import { formatMessage } from "../../lib/constants";
const search = Astro.url.searchParams;
const success = search.get("success");
const error = search.get("error");
const secondsNum = Number.parseInt(search.get("seconds") ?? "", 10);
const seconds =
	Number.isFinite(secondsNum) && secondsNum >= 0 ? String(secondsNum) : null;
let message = "";
let messageType: "success" | "error" | null = null;
if (success === "true") {
	message = formatMessage("password_reset_sent");
	messageType = "success";
} else if (error) {
	messageType = "error";
	switch (error) {
		case "rate_limit":
			message = seconds
				? `For security purposes, you must wait ${seconds} more seconds before requesting to reset your password`
				: formatMessage("rate_limit");
			break;
		default:
			message = formatMessage(error) || formatMessage("failed");
	}
}
---
<Layout title="Forgot Password" description="Request a password reset email.">
  <div class="min-h-screen bg-gray-50">
    <header>
      <Navigation />
    </header>

    <main id="main-content" class="max-w-3xl mx-auto px-6 py-12">
      <div class="mb-6">
        <a
          href="/signin"
          class="inline-flex items-center text-sm text-gray-600 hover:text-gray-900 font-medium"
        >
          <Icon name="arrow-left" class="w-4 h-4 mr-2" aria-hidden="true" />
          Back to Sign in
        </a>
      </div>

      <div class="max-w-md mx-auto bg-white rounded-lg shadow-lg border border-gray-200 p-8">
        <header>
          <h1 class="text-2xl font-bold text-gray-900 mb-2">Forgot your password?</h1>
          <p class="text-sm text-gray-600 mb-6">Enter your email and we'll send you a link to reset your password.</p>
        </header>

        {message && messageType && (
          <StatusMessage
            class="mb-4"
            tone={messageType === "success" ? "success" : "error"}
            message={message}
          />
        )}

        <form class="space-y-4" action="/api/auth/email/forgot-password" method="post" id="forgot-form">
          <fieldset>
            <legend class="sr-only">Reset email</legend>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
            <EmailInput
              client:load
              type="email"
              name="email"
              id="email"
              required
              autocomplete="email"
              class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-primary focus:border-primary"
              placeholder="you@example.com"
            />
          </fieldset>
          <fieldset>
            <legend class="sr-only">Security check</legend>
            <HCaptcha
              tokenInputId="forgot_captcha_token"
              callbackName="onForgotHCaptchaSuccess"
              errorCallback="onForgotHCaptchaError"
              expiredCallback="onForgotHCaptchaExpired"
              ariaLabel="Complete the CAPTCHA verification"
            />
          </fieldset>
          <div
            id="forgot-captcha-status"
            class="mt-2 hidden rounded-lg border p-3 text-sm status-tone-error"
            role="status"
            aria-live="polite"
          ></div>
          <button 
            type="submit"
            class="w-full bg-primary hover:bg-primary-strong text-white px-6 py-3 rounded-md font-medium transition-colors cursor-pointer"
          >
            Send reset link
          </button>
        </form>
      </div>
    </main>
  </div>
</Layout>

<script>
	import {
		createCaptchaStatusHelpers,
		initializeHCaptchaForm,
		setupCaptchaTokenInputListener,
		setupHCaptchaCallback,
		setupHCaptchaErrorCallback,
		setupHCaptchaExpiredCallback,
	} from "../../lib/auth/hcaptcha";
	import { rootLogger } from "../../lib/logging";

	const captchaStatus = createCaptchaStatusHelpers("forgot-captcha-status");

	setupCaptchaTokenInputListener("forgot_captcha_token", (token) => {
		if (token.trim().length > 0) {
			captchaStatus.hide();
		}
	});

	initializeHCaptchaForm("forgot-form", "forgot_captcha_token");
	setupHCaptchaCallback(
		"onForgotHCaptchaSuccess",
		"forgot_captcha_token",
		"forgot-form",
	);

	setupHCaptchaErrorCallback("onForgotHCaptchaError", (errorCode) => {
		rootLogger.error("hCaptcha error", { errorCode });
		captchaStatus.show("CAPTCHA failed to load. Please refresh and try again.");
	});

	setupHCaptchaExpiredCallback(
		"onForgotHCaptchaExpired",
		"forgot_captcha_token",
		() => {
			captchaStatus.show("CAPTCHA expired. Please complete it again.");
		},
	);
</script>

