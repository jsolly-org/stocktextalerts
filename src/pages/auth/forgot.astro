---

import { Icon } from "astro-icon/components";
import Footer from "../../components/Footer.astro";
import Navigation from "../../components/Navigation.astro";
import StatusMessage from "../../components/StatusMessage.astro";
import Layout from "../../layouts/Layout.astro";
import { formatMessage } from "../../lib/messaging/status-messages";
const search = Astro.url.searchParams;
const success = search.get("success");
const error = search.get("error");
const secondsNum = Number.parseInt(search.get("seconds") ?? "", 10);
const seconds =
	Number.isFinite(secondsNum) && secondsNum >= 0 ? String(secondsNum) : null;
let message = "";
let messageType: "success" | "error" | null = null;
if (success === "true") {
	message = formatMessage("password_reset_sent");
	messageType = "success";
} else if (error) {
	messageType = "error";
	switch (error) {
		case "rate_limit":
			message = seconds
				? `For security purposes, you must wait ${seconds} more seconds before requesting to reset your password`
				: formatMessage("rate_limit");
			break;
		default:
			message = formatMessage(error) || formatMessage("failed");
	}
}
---
<Layout title="Forgot Password | StockTextAlerts" description="Request a password reset email for your StockTextAlerts account. Enter your email to receive a secure link to set a new password.">
  <div class="min-h-screen bg-surface-alt">
    <header>
      <Navigation />
    </header>

    <main id="main-content" class="max-w-3xl mx-auto px-4 py-8 sm:px-6 sm:py-12">
      <div class="mb-6">
        <a href="/auth/signin" class="link-primary inline-flex items-center gap-2">
          <Icon name="arrow-left" class="size-4" aria-hidden="true" />
          Back to Sign in
        </a>
      </div>

      <div class="max-w-md mx-auto bg-surface rounded-lg shadow-lg border border-edge p-6 sm:p-8">
        <header>
          <h1 class="text-2xl font-bold text-heading mb-2">Forgot your password?</h1>
          <p class="text-sm text-body-secondary mb-4">Enter the email address associated with your StockTextAlerts account and we'll send you a secure link to reset your password.</p>
          <p class="text-sm text-body-secondary mb-6">The reset link will expire after 24 hours for security. If you don't receive the email within a few minutes, check your spam folder or try again.</p>
        </header>

        {message && messageType && (
          <StatusMessage
            class="mb-4"
            tone={messageType === "success" ? "success" : "error"}
            message={message}
          />
        )}

        <form class="space-y-4" action="/api/auth/email/forgot-password" method="post" id="forgot-form">
          <fieldset>
            <legend class="sr-only">Reset email</legend>
            <label for="email" class="block text-sm font-medium text-label mb-2">Email</label>
            <input
              type="email"
              name="email"
              id="email"
              required
              autocomplete="email"
              class="input input-lg"
              placeholder="you@example.com"
            />
          </fieldset>
          <button
            type="submit"
            class="btn btn-lg btn-primary w-full"
            data-submit-loading
          >
            Send Reset Link
          </button>
        </form>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

