---

import { Icon } from "astro-icon/components";
import Navigation from "../../components/Navigation.astro";
import StatusMessage from "../../components/StatusMessage.astro";
import Layout from "../../layouts/Layout.astro";
import { formatMessage, MIN_PASSWORD_LENGTH } from "../../lib/constants";

const search = Astro.url.searchParams;
const tokenHash = search.get("token_hash");
const type = search.get("type");
const error = search.get("error");
let message = "";
let showResetLink = false;
const hasValidToken = Boolean(tokenHash) && type === "recovery";
let showForm = hasValidToken;

function setInvalidLinkState(msg: string) {
	message = msg;
	showResetLink = true;
	showForm = false;
}

if (!hasValidToken) {
	setInvalidLinkState(formatMessage("invalid_token"));
} else if (error) {
	switch (error) {
		case "expired":
			setInvalidLinkState(formatMessage("expired"));
			break;
		case "invalid_token":
			setInvalidLinkState(formatMessage("invalid_token"));
			break;
		default:
			message = formatMessage(error) || formatMessage("failed");
	}
}
---
<Layout title="Reset Password" description="Set a new password for your StockTextAlerts account. Use the link from your reset email to choose a new password and regain access." noindex>
  <div class="min-h-screen bg-surface-alt">
    <header>
      <Navigation />
    </header>

    <main id="main-content" class="max-w-3xl mx-auto px-4 py-8 sm:px-6 sm:py-12">
      <div class="mb-6">
        <a
          href="/auth/signin"
          class="inline-flex items-center text-sm text-body-secondary hover:text-heading font-medium"
        >
          <Icon name="arrow-left" class="w-4 h-4 mr-2" aria-hidden="true" />
          Back to Sign in
        </a>
      </div>

      <div class="max-w-md mx-auto bg-surface rounded-lg shadow-lg border border-edge p-6 sm:p-8">
        <header>
          <h1 class="text-2xl font-bold text-heading mb-2">Set a new password</h1>
          <p class="text-sm text-body-secondary mb-6">Choose a strong password for your account.</p>
        </header>

        {message && (
          <StatusMessage class="mb-4" tone="error" message={message} />
        )}

        {showForm && (
          <form id="reset-form" class="space-y-4" action="/api/auth/update-password" method="post">
            <input type="hidden" name="token_hash" value={tokenHash ?? ""} />
            <fieldset class="space-y-4">
              <legend class="sr-only">Set a new password</legend>
              <div>
                <label for="password" class="block text-sm font-medium text-label mb-2">New password</label>
                <input
                  type="password"
                  name="password"
                  id="password"
                  required
                  minlength={MIN_PASSWORD_LENGTH}
                  autocomplete="new-password"
                  class="input input-lg"
                  placeholder="••••••••"
                />
                <p class="text-sm text-muted mt-1">Minimum {MIN_PASSWORD_LENGTH} characters required</p>
              </div>
              <div>
                <label for="confirm" class="block text-sm font-medium text-label mb-2">Confirm password</label>
                <input
                  type="password"
                  name="confirm"
                  id="confirm"
                  required
                  minlength={MIN_PASSWORD_LENGTH}
                  autocomplete="new-password"
                  class="input input-lg"
                  placeholder="••••••••"
                />
                <p class="text-sm text-muted mt-1">Minimum {MIN_PASSWORD_LENGTH} characters required</p>
                <p
                  id="confirm-match-feedback"
                  class="mt-1 hidden items-center gap-1 text-sm"
                  role="status"
                  aria-live="polite"
                >
                  <Icon id="confirm-match-icon" name="check-circle-20" class="h-4 w-4" aria-hidden="true" />
                  <span id="confirm-match-text"></span>
                </p>
              </div>
            </fieldset>
            <button
              type="submit"
              class="btn btn-lg btn-primary w-full"
              data-submit-loading
            >
              Update password
            </button>
          </form>
        )}

        {showResetLink && (
          <div class="mt-6 text-center">
            <a href="/auth/forgot" class="link-primary">Request a new password reset</a>
          </div>
        )}
      </div>
    </main>
  </div>
</Layout>

<script>
  import { MIN_PASSWORD_LENGTH } from "../../lib/constants";
  (() => {
    const passwordInput = document.getElementById("password");
    const confirmInput = document.getElementById("confirm");
    const feedback = document.getElementById("confirm-match-feedback");
    const feedbackIcon = document.getElementById("confirm-match-icon");
    const feedbackText = document.getElementById("confirm-match-text");

    if (
      !(passwordInput instanceof HTMLInputElement) ||
      !(confirmInput instanceof HTMLInputElement) ||
      !(feedback instanceof HTMLElement) ||
      !(feedbackIcon instanceof HTMLElement) ||
      !(feedbackText instanceof HTMLElement)
    ) {
      return;
    }

    function hideFeedback() {
      feedback.classList.add("hidden");
      feedback.classList.remove("flex", "text-success-text", "text-error-text");
      feedbackIcon.classList.add("hidden");
      feedbackIcon.classList.remove("text-success-text", "text-error-text");
      feedbackText.textContent = "";
    }

    function showFeedback(matches) {
      feedback.classList.remove("hidden");
      feedback.classList.add("flex");
      feedback.classList.remove("text-success-text", "text-error-text");
      feedbackIcon.classList.remove("hidden", "text-success-text", "text-error-text");

      if (matches) {
        feedback.classList.add("text-success-text");
        feedbackIcon.classList.add("text-success-text");
        feedbackText.textContent = "Passwords match.";
        return;
      }

      feedback.classList.add("text-error-text");
      feedbackIcon.classList.add("hidden");
      feedbackText.textContent = "Passwords do not match.";
    }

    function updateMatchFeedback() {
      const confirmValue = confirmInput.value;
      const passwordValue = passwordInput.value;

      if (!confirmValue.length) {
        hideFeedback();
        return;
      }

      showFeedback(passwordValue.length >= MIN_PASSWORD_LENGTH && passwordValue === confirmValue);
    }

    passwordInput.addEventListener("input", updateMatchFeedback);
    confirmInput.addEventListener("input", updateMatchFeedback);
  })();
</script>
