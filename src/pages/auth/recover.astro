---

import { Icon } from "astro-icon/components";
import Navigation from "../../components/Navigation.astro";
import StatusMessage from "../../components/StatusMessage.astro";
import Layout from "../../layouts/Layout.astro";
import { formatMessage } from "../../lib/constants";

const search = Astro.url.searchParams;
const tokenHash = search.get("token_hash");
const type = search.get("type");
const error = search.get("error");
let message = "";
let showResetLink = false;
const hasValidToken = Boolean(tokenHash) && type === "recovery";
let showForm = hasValidToken;

function setInvalidLinkState(msg: string) {
	message = msg;
	showResetLink = true;
	showForm = false;
}

if (!hasValidToken) {
	setInvalidLinkState(formatMessage("invalid_token"));
} else if (error) {
	switch (error) {
		case "expired":
			setInvalidLinkState(formatMessage("expired"));
			break;
		case "invalid_token":
			setInvalidLinkState(formatMessage("invalid_token"));
			break;
		default:
			message = formatMessage(error) || formatMessage("failed");
	}
}
---
<Layout title="Reset Password" description="Set a new password for your account.">
  <div class="min-h-screen bg-gray-50">
    <header>
      <Navigation />
    </header>

    <main id="main-content" class="max-w-3xl mx-auto px-6 py-12">
      <div class="mb-6">
        <a
          href="/signin"
          class="inline-flex items-center text-sm text-gray-600 hover:text-gray-900 font-medium"
        >
          <Icon name="arrow-left" class="w-4 h-4 mr-2" aria-hidden="true" />
          Back to Sign in
        </a>
      </div>

      <div class="max-w-md mx-auto bg-white rounded-lg shadow-lg border border-gray-200 p-8">
        <header>
          <h1 class="text-2xl font-bold text-gray-900 mb-2">Set a new password</h1>
          <p class="text-sm text-gray-600 mb-6">Choose a strong password for your account.</p>
        </header>

        {message && (
          <StatusMessage class="mb-4" tone="error" message={message} />
        )}

        {showForm && (
          <form id="reset-form" class="space-y-4" action="/api/auth/update-password" method="post">
            <input type="hidden" name="token_hash" value={tokenHash ?? ""} />
            <fieldset class="space-y-4">
              <legend class="sr-only">Set a new password</legend>
              <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-2">New password</label>
                <input
                  type="password"
                  name="password"
                  id="password"
                  required
                  autocomplete="new-password"
                  class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-primary focus:border-primary"
                  placeholder="••••••••"
                  minlength="8"
                />
                <p class="text-sm text-gray-500 mt-1">Minimum 8 characters required</p>
              </div>
              <div>
                <label for="confirm" class="block text-sm font-medium text-gray-700 mb-2">Confirm password</label>
                <input
                  type="password"
                  name="confirm"
                  id="confirm"
                  required
                  autocomplete="new-password"
                  class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-primary focus:border-primary"
                  placeholder="••••••••"
                  minlength="8"
                />
                <p class="text-sm text-gray-500 mt-1">Minimum 8 characters required</p>
              </div>
            </fieldset>
            <button
              type="submit"
              class="w-full bg-primary hover:bg-primary-strong text-white px-6 py-3 rounded-md font-medium transition-colors cursor-pointer"
            >
              Update password
            </button>
          </form>
        )}

        {showResetLink && (
          <div class="mt-6 text-center">
            <a href="/auth/forgot" class="text-sm font-medium text-primary hover:text-primary-strong">
              Request a new password reset
            </a>
          </div>
        )}
      </div>
    </main>
  </div>
</Layout>

