---

import { Icon } from "astro-icon/components";
import Footer from "../../components/Footer.astro";
import SignInCard from "../../components/SignInCard.astro";
import Layout from "../../layouts/Layout.astro";
import {
	getAuthErrorMessage,
	getAuthSuccessMessage,
} from "../../lib/auth/messages";
import {
	getPostSigninRedirect,
	getSafeRedirectPath,
} from "../../lib/auth/redirects";
import { createUserService } from "../../lib/db";
import { createSupabaseServerClient } from "../../lib/db/supabase";

const supabase = createSupabaseServerClient();
const users = createUserService(supabase, Astro.cookies);
const search = Astro.url.searchParams;
const errorCode = search.get("error");
const errorMessage = getAuthErrorMessage(errorCode);
const successCode = search.get("success");
const successMessage = getAuthSuccessMessage(successCode);
const emailPrefill = search.get("email") ?? "";
const redirectPath = getSafeRedirectPath(search.get("redirect"));
const user = await users.getCurrentUser();
if (user) {
	return Astro.redirect(getPostSigninRedirect(redirectPath));
}
---
<Layout title="Sign In | StockTextAlerts" description="Sign in to manage tracked assets, notification schedules, and alert channels.">
  <main id="main-content" class="min-h-screen bg-surface-alt flex flex-col justify-center px-4 py-10 sm:px-6 sm:py-12 lg:px-8">
    <header class="sm:mx-auto sm:w-full sm:max-w-md">
      <div class="flex justify-center">
        <a href="/" class="flex items-center gap-2 group" aria-label="StockTextAlerts home">
          <div class="bg-primary text-white p-1.5 rounded-lg group-hover:bg-primary-strong transition-colors shadow-sm">
            <Icon name="presentation-chart-line" class="size-8" aria-hidden="true" />
          </div>
          <span class="text-xl font-bold text-heading tracking-tight group-hover:text-primary transition-colors">StockTextAlerts</span>
        </a>
      </div>
      <h1 class="mt-6 text-center text-2xl sm:text-3xl font-extrabold text-heading">
        Sign in to your account
      </h1>
      <p class="mt-2 text-center text-sm text-body-secondary">
        Manage tracked assets, notification schedules, and alert preferences.
      </p>
      <p class="mt-2 text-center text-sm text-body-secondary">
        New here? <a href="/auth/register" class="link-primary">Create a free account</a>
      </p>
    </header>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
      <SignInCard
        emailPrefill={emailPrefill}
        errorCode={errorCode}
        errorMessage={errorMessage}
        successMessage={successMessage}
				redirectPath={redirectPath}
      />
    </div>
  </main>
  <Footer />
</Layout>
