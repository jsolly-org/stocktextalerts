---

import { Icon } from "astro-icon/components";
import StatusMessage from "../../components/StatusMessage.astro";
import Layout from "../../layouts/Layout.astro";
import { formatMessage } from "../../lib/constants";

const search = Astro.url.searchParams;
const email = search.get("email");
const success = search.get("success");
const error = search.get("error");
let message = "";
let messageType: "success" | "error" | null = null;
if (success === "true") {
	message = formatMessage("verification_email_sent");
	messageType = "success";
} else if (error) {
	messageType = "error";
	message = formatMessage(error) || formatMessage("failed");
}
---
<Layout title="Verify Your Email" description="Please verify your email address to continue. Check your inbox for the confirmation link from StockTextAlerts, then sign in to access your account." noindex>
  <main id="main-content" class="min-h-screen flex items-center justify-center bg-surface-alt py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
      <header class="text-center">
        <div class="mx-auto h-12 w-12 flex items-center justify-center rounded-full bg-info-bg">
          <Icon name="envelope" class="h-6 w-6 text-info-text" aria-hidden="true" />
        </div>
        <h1 class="mt-6 text-center text-2xl sm:text-3xl font-extrabold text-heading">
          Check Your Email
        </h1>
        <p class="mt-2 text-center text-sm text-body-secondary">
          We&rsquo;ve sent a verification link to
        </p>
        <p class="mt-1 text-center text-sm font-medium text-heading">
          {email || "your email address"}
        </p>
      </header>

      <div class="mt-8 space-y-6">
        <section class="rounded-md border p-4 status-tone-info" aria-labelledby="next-steps-heading">
          <div class="flex">
            <div class="shrink-0">
              <Icon name="information-circle-20" class="h-5 w-5 text-info-text" aria-hidden="true" />
            </div>
            <div class="ml-3">
              <h3 id="next-steps-heading" class="text-sm font-medium">
                What&rsquo;s next?
              </h3>
              <div class="mt-2 text-sm">
                <ul class="list-disc pl-5 space-y-1">
                  <li>Check your email inbox (and spam folder)</li>
                  <li>Click the verification link in the email</li>
                  <li>Return here to sign in</li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        {message && messageType && (
          <StatusMessage
            tone={messageType === "success" ? "success" : "error"}
            message={message}
          />
        )}

        <div class="space-y-4">
          <form id="resend-form" action="/api/auth/email/resend-verification" method="post">
            <input type="hidden" name="email" value={email || ""} />
            <button
              id="resend-btn"
              type="submit"
              class="btn btn-md btn-secondary w-full"
            >
              Resend verification email
            </button>
          </form>
          
          <div class="text-center">
            <a href="/auth/signin" class="link-primary inline-flex items-center gap-2">
              <Icon name="arrow-left" class="size-4" aria-hidden="true" />
              Back to sign in
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ success, error }}>
	(function setupResendVerification() {
		const resendBtn = document.getElementById("resend-btn");
		const resendForm = document.getElementById("resend-form");

		if (
			!(resendBtn instanceof HTMLButtonElement) ||
			!(resendForm instanceof HTMLFormElement)
		) {
			return;
		}

		let cooldownTimer = null;

		const COOLDOWN_KEY = "resend-verification-cooldown";
		const PENDING_KEY = "resend-verification-pending";
		const COOLDOWN_DURATION = 30;

		function getRemainingCooldownSeconds() {
			try {
				const lastSentStr = localStorage.getItem(COOLDOWN_KEY);
				if (!lastSentStr) return 0;
				const elapsed = Math.floor(
					(Date.now() - Number.parseInt(lastSentStr, 10)) / 1000,
				);
				return Math.max(0, COOLDOWN_DURATION - elapsed);
			} catch {
				return 0;
			}
		}

		function markPendingSubmit() {
			try {
				sessionStorage.setItem(PENDING_KEY, "1");
			} catch {
				// Ignore sessionStorage failures.
			}
		}

		function hasPendingSubmit() {
			try {
				return sessionStorage.getItem(PENDING_KEY) === "1";
			} catch {
				return false;
			}
		}

		function clearPendingSubmit() {
			try {
				sessionStorage.removeItem(PENDING_KEY);
			} catch {
				// Ignore sessionStorage failures.
			}
		}

		function setButtonCooldown(seconds) {
			if (cooldownTimer) {
				clearInterval(cooldownTimer);
			}

			resendBtn.disabled = true;
			resendBtn.setAttribute("aria-busy", "true");
			let remaining = seconds;

			const updateButton = () => {
				if (remaining > 0) {
					resendBtn.textContent = `Resend verification email (${remaining}s)`;
					remaining--;
					return;
				}

				resendBtn.disabled = false;
				resendBtn.removeAttribute("aria-busy");
				resendBtn.textContent = "Resend verification email";
				if (cooldownTimer) {
					clearInterval(cooldownTimer);
					cooldownTimer = null;
				}
			};

			updateButton();
			cooldownTimer = setInterval(updateButton, 1000);
		}

		resendForm.addEventListener("submit", () => {
			markPendingSubmit();
			resendBtn.disabled = true;
			resendBtn.setAttribute("aria-busy", "true");
			resendBtn.textContent = "Sending verification email...";
		});

		// Start cooldown only after a confirmed successful round-trip.
		if (success === "true" && hasPendingSubmit()) {
			try {
				localStorage.setItem(COOLDOWN_KEY, Date.now().toString());
			} catch {
				// Ignore localStorage failures.
			} finally {
				clearPendingSubmit();
			}
		}

		// If the backend rejected the resend, clear pending state and allow retry.
		if (error && hasPendingSubmit()) {
			clearPendingSubmit();
		}

		// Initialize from persisted cooldown.
		const remaining = getRemainingCooldownSeconds();
		if (remaining > 0) {
			setButtonCooldown(remaining);
		}
	})();
</script>
