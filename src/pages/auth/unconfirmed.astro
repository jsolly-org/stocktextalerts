---

import { Icon } from "astro-icon/components";
import HCaptcha from "../../components/HCaptcha.astro";
import Layout from "../../layouts/Layout.astro";

const search = Astro.url.searchParams;
const email = search.get("email");
const success = search.get("success");
const error = search.get("error");
let message = "";
let messageType: "success" | "error" | null = null;
if (success === "true") {
	message = "Verification email sent! Check your inbox.";
	messageType = "success";
} else if (error) {
	messageType = "error";
	switch (error) {
		case "email_required":
			message = "No email address found";
			break;
		case "failed":
			message = "Failed to send email. Please try again.";
			break;
		case "captcha_required":
			message = "Please complete the CAPTCHA and try again.";
			break;
		default:
			message = "An unexpected error occurred. Please try again.";
	}
}
---
<Layout title="Verify Your Email" description="Please verify your email address to continue">
  <div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
      <div class="text-center">
        <div class="mx-auto h-12 w-12 flex items-center justify-center rounded-full bg-blue-100">
          <Icon name="envelope" class="h-6 w-6 text-blue-600" aria-hidden="true" />
        </div>
        <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
          Check Your Email
        </h2>
        <p class="mt-2 text-center text-sm text-gray-600">
          We've sent a verification link to
        </p>
        <p class="mt-1 text-center text-sm font-medium text-gray-900">
          {email || "your email address"}
        </p>
      </div>

      <div class="mt-8 space-y-6">
        <div class="rounded-md bg-blue-50 p-4">
          <div class="flex">
            <div class="shrink-0">
              <Icon name="information-circle-20" class="h-5 w-5 text-blue-400" aria-hidden="true" />
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-blue-800">
                What's next?
              </h3>
              <div class="mt-2 text-sm text-blue-700">
                <ul class="list-disc pl-5 space-y-1">
                  <li>Check your email inbox (and spam folder)</li>
                  <li>Click the verification link in the email</li>
                  <li>Return here to sign in</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        {message && (
          <div class={`p-4 rounded-md ${messageType === "success" ? "bg-green-50 text-green-700" : "bg-red-50 text-red-700"}`} role="alert">
            {message}
          </div>
        )}

        <div class="space-y-4">
          <form id="resend-form" action="/api/auth/email/resend-verification" method="post">
            <input type="hidden" name="email" value={email || ""} />
						<HCaptcha
							tokenInputId="unconfirmed_captcha_token"
							callbackName="onUnconfirmedHCaptchaSuccess"
							widgetClasses="mb-4"
							errorCallback="onUnconfirmedHCaptchaError"
							expiredCallback="onUnconfirmedHCaptchaExpired"
						/>
					<div
						id="unconfirmed-captcha-status"
						class="mt-2 hidden rounded-md bg-red-50 p-3 text-sm text-red-700"
						role="status"
						aria-live="polite"
					></div>
            <button
              id="resend-btn"
              type="submit"
              class="group relative w-full flex justify-center py-2 px-4 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Resend verification email
            </button>
          </form>
          
          <div class="text-center">
            <a
              href="/signin"
              class="font-medium text-blue-600 hover:text-blue-500"
            >
              Back to sign in
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
	import {
		createCaptchaStatusHelpers,
		setupCaptchaTokenInputListener,
		setupHCaptchaCallback,
		setupHCaptchaErrorCallback,
		setupHCaptchaExpiredCallback,
	} from "../../lib/auth/hcaptcha";
	import { rootLogger } from "../../lib/logging";

	(function setupResendVerification() {
		const resendBtn = document.getElementById("resend-btn");
		const resendForm = document.getElementById("resend-form");
		const captchaTokenInput = document.getElementById("unconfirmed_captcha_token");

		if (
			!(resendBtn instanceof HTMLButtonElement) ||
			!(resendForm instanceof HTMLFormElement) ||
			!(captchaTokenInput instanceof HTMLInputElement)
		) {
			return;
		}

		setupResendVerificationElements(resendBtn, resendForm, captchaTokenInput);
	})();

	function setupResendVerificationElements(
		resendBtn: HTMLButtonElement,
		resendForm: HTMLFormElement,
		captchaTokenInput: HTMLInputElement,
	) {
		const captchaStatus = createCaptchaStatusHelpers("unconfirmed-captcha-status");
		let cooldownTimer: ReturnType<typeof setInterval> | null = null;

		const COOLDOWN_KEY = "resend-verification-cooldown";
		const COOLDOWN_DURATION = 30;

		function getRemainingCooldownSeconds(): number {
			try {
				const lastSentStr = localStorage.getItem(COOLDOWN_KEY);
				if (!lastSentStr) return 0;
				const elapsed = Math.floor(
					(Date.now() - Number.parseInt(lastSentStr, 10)) / 1000,
				);
				return Math.max(0, COOLDOWN_DURATION - elapsed);
			} catch {
				return 0;
			}
		}

		function canResendNow(): boolean {
			return getRemainingCooldownSeconds() === 0;
		}

		function updateResendDisabledState() {
			const hasCaptchaToken = captchaTokenInput.value.trim().length > 0;
			resendBtn.disabled = !hasCaptchaToken || !canResendNow();
		}

		function initializeCooldown() {
			const remaining = getRemainingCooldownSeconds();

			if (remaining > 0) {
				setButtonCooldown(remaining);
				return;
			}

			updateResendDisabledState();
		}

		resendForm.addEventListener("submit", () => {
			try {
				localStorage.setItem(COOLDOWN_KEY, Date.now().toString());
			} catch (err) {
				rootLogger.error(
					"Failed to save cooldown timestamp to localStorage",
					{
						action: "persist_resend_cooldown",
						storageKey: COOLDOWN_KEY,
					},
					err,
				);
			}
		});

		function setButtonCooldown(seconds: number) {
			if (cooldownTimer) {
				clearInterval(cooldownTimer);
			}

			resendBtn.disabled = true;
			let remaining = seconds;

			const updateButton = () => {
				if (remaining > 0) {
					resendBtn.textContent = `Resend verification email (${remaining}s)`;
					remaining--;
					return;
				}

				updateResendDisabledState();
				resendBtn.textContent = "Resend verification email";
				if (cooldownTimer) {
					clearInterval(cooldownTimer);
					cooldownTimer = null;
				}
			};

			updateButton();
			cooldownTimer = setInterval(updateButton, 1000);
		}

		setupHCaptchaCallback(
			"onUnconfirmedHCaptchaSuccess",
			"unconfirmed_captcha_token",
		);

		setupHCaptchaErrorCallback("onUnconfirmedHCaptchaError", (errorCode) => {
			rootLogger.error("hCaptcha error", { errorCode });
			captchaStatus.show("CAPTCHA failed to load. Please refresh and try again.");
		});

		setupHCaptchaExpiredCallback(
			"onUnconfirmedHCaptchaExpired",
			"unconfirmed_captcha_token",
			() => {
				captchaStatus.show("CAPTCHA expired. Please complete it again.");
			},
		);

		setupCaptchaTokenInputListener("unconfirmed_captcha_token", (token) => {
			updateResendDisabledState();
			if (token.trim().length > 0) {
				captchaStatus.hide();
			}
		});

		initializeCooldown();
	}
</script>

