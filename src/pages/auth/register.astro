---

import { Icon } from "astro-icon/components";
import EmailInput from "../../components/EmailInput.vue";
import Footer from "../../components/Footer.astro";
import Navigation from "../../components/Navigation.astro";
import StatusMessage from "../../components/StatusMessage.astro";
import Layout from "../../layouts/Layout.astro";
import { createSupabaseServerClient } from "../../lib/db/supabase";
import { rootLogger } from "../../lib/logging";
import { formatMessage } from "../../lib/constants";
import { getTimezoneOptions } from "../../lib/time/cache";

const search = Astro.url.searchParams;
const error = search.get("error");
let showSignInLink = false;
const supabase = createSupabaseServerClient();
let timezones: Awaited<ReturnType<typeof getTimezoneOptions>> = [];
let timezoneLoadError = false;
try {
	timezones = await getTimezoneOptions(supabase);
} catch (loadError) {
	rootLogger.error(
		"Failed to load timezone options",
		{ action: "load_timezone_options", page: "register" },
		loadError,
	);
	timezoneLoadError = true;
}
const message = formatMessage(error);
if (error === "user_already_exists") {
	showSignInLink = true;
}
---
<Layout title="Create Your Account | StockTextAlerts" description="Create a new StockTextAlerts account. Sign up to get updates for your tracked US assets via email and optional text messages.">
  <div class="min-h-screen bg-surface-alt">
    <header>
      <Navigation />
    </header>
    
    <main id="main-content" class="max-w-3xl mx-auto px-4 py-8 sm:px-6 sm:py-12">
      <div class="mb-6">
        <a href="/" class="link-primary inline-flex items-center gap-2">
          <Icon name="arrow-left" class="size-4" aria-hidden="true" />
          Back to Home
        </a>
      </div>

      <div class="max-w-md mx-auto space-y-8">
        <header>
          <h1 class="mt-6 text-center text-2xl sm:text-3xl font-extrabold text-heading">Register</h1>
          <p class="mt-2 text-center text-sm text-body-secondary">
            Already have an account? <a href="/auth/signin" class="link-primary">Sign in to your account</a>
          </p>
        </header>

        {message && (
          <StatusMessage class="mb-4" tone="error">
            <span>{message}</span>
            {showSignInLink && (
              <> <a href="/auth/signin" class="link-primary">Sign in</a>.</>
            )}
          </StatusMessage>
        )}

        {timezoneLoadError && (
          <StatusMessage class="mb-4" tone="warning">
            Unable to load timezone options. You can set your timezone later in your profile.
          </StatusMessage>
        )}

        <form class="mt-8 space-y-6" action="/api/auth/email/register" method="post" id="register-form">
          <fieldset class="rounded-md shadow-sm -space-y-px">
            <legend class="sr-only">Account information</legend>
            <div>
              <label for="email" class="sr-only">Email</label>
              <EmailInput
                client:load
                type="email"
                name="email"
                id="email"
                required
                autocomplete="email"
                class="appearance-none rounded-none relative block w-full px-3 py-2 border border-edge-strong placeholder-muted text-heading rounded-t-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:border-primary focus-visible:z-10 sm:text-sm disabled:bg-disabled-bg disabled:cursor-not-allowed"
                placeholder="Email address…"
              />
            </div>
            <div>
              <label for="password" class="sr-only">Password</label>
              <input
                type="password"
                name="password"
                id="password"
                required
                autocomplete="new-password"
                spellcheck="false"
                class="appearance-none rounded-none relative block w-full px-3 py-2 border border-edge-strong placeholder-muted text-heading rounded-b-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:border-primary focus-visible:z-10 sm:text-sm disabled:bg-disabled-bg disabled:cursor-not-allowed"
                placeholder="Password…"
              />
            </div>
          </fieldset>
          
          <fieldset>
            <legend class="sr-only">Timezone</legend>
            <label for="timezone" class="block text-sm font-medium text-label mb-1">
              Timezone
            </label>
            <p class="text-sm text-body-secondary mb-2">
              We auto-detected this, but you can change it if it&rsquo;s wrong.
            </p>
            <select
              id="timezone"
              name="timezone"
              class="input cursor-pointer"
              disabled={timezoneLoadError}
            >
              <option value="">
                Select your timezone (optional)
              </option>
              {timezones.map((tz) => (
                <option value={tz.value}>{tz.label}</option>
              ))}
            </select>
          </fieldset>

          <div>
            <button 
              type="submit" 
              class="btn btn-md btn-primary w-full"
            >
              Register
            </button>
          </div>
        </form>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<script>
import { DEFAULT_TIMEZONE } from "../../lib/constants";
	import { setupDetectedTimezoneOption } from "../../lib/time/detected-timezone";

	// Ensure register form preselects a detected timezone even before user profile exists.
	setupDetectedTimezoneOption({ defaultTimezone: DEFAULT_TIMEZONE });
</script>

