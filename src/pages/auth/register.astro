---

import { Icon } from "astro-icon/components";
import HCaptcha from "../../components/HCaptcha.astro";
import EmailInput from "../../components/forms/EmailInput.vue";
import Navigation from "../../components/Navigation.astro";
import StatusMessage from "../../components/StatusMessage.astro";
import Layout from "../../layouts/Layout.astro";
import { createSupabaseServerClient } from "../../lib/db/supabase";
import { rootLogger } from "../../lib/logging";
import { formatMessage } from "../../lib/constants";
import { getTimezoneOptions } from "../../lib/time/cache";

const search = Astro.url.searchParams;
const error = search.get("error");
let showSignInLink = false;
const supabase = createSupabaseServerClient();
let timezones: Awaited<ReturnType<typeof getTimezoneOptions>> = [];
let timezoneLoadError = false;
try {
	timezones = await getTimezoneOptions(supabase);
} catch (loadError) {
	rootLogger.error(
		"Failed to load timezone options",
		{ action: "load_timezone_options", page: "register" },
		loadError,
	);
	timezoneLoadError = true;
}
const message = formatMessage(error);
if (error === "user_already_exists") {
	showSignInLink = true;
}
---
<Layout title="Register | Stock Text Alerts" description="Create a new Stock Text Alerts account. Sign up to get a daily digest for your tracked US stocks via email and optional text messages.">
  <div class="min-h-screen bg-gray-50">
    <header>
      <Navigation />
    </header>
    
    <main id="main-content" class="max-w-3xl mx-auto px-4 py-8 sm:px-6 sm:py-12">
      <div class="mb-6">
        <a href="/" class="link-primary inline-flex items-center gap-2">
          <Icon name="arrow-left" class="size-4" aria-hidden="true" />
          Back to Home
        </a>
      </div>

      <div class="max-w-md mx-auto space-y-8">
        <header>
          <h1 class="mt-6 text-center text-2xl sm:text-3xl font-extrabold text-gray-900">Register</h1>
          <p class="mt-2 text-center text-sm text-gray-600">
            Already have an account? <a href="/auth/signin" class="link-primary">Sign in</a>
          </p>
        </header>

        {message && (
          <StatusMessage class="mb-4" tone="error">
            <span>{message}</span>
            {showSignInLink && (
              <> <a href="/auth/signin" class="link-primary">Sign in</a>.</>
            )}
          </StatusMessage>
        )}

        {timezoneLoadError && (
          <StatusMessage class="mb-4" tone="warning">
            Unable to load timezone options. You can set your timezone later in your profile.
          </StatusMessage>
        )}

        <form class="mt-8 space-y-6" action="/api/auth/email/register" method="post" id="register-form">
          <fieldset class="rounded-md shadow-sm -space-y-px">
            <legend class="sr-only">Account information</legend>
            <div>
              <label for="email" class="sr-only">Email</label>
              <EmailInput
                client:load
                type="email"
                name="email"
                id="email"
                required
                autocomplete="email"
                class="appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-t-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary focus:z-10 sm:text-sm disabled:bg-gray-100 disabled:cursor-not-allowed"
                placeholder="Email address"
              />
            </div>
            <div>
              <label for="password" class="sr-only">Password</label>
              <input 
                type="password" 
                name="password" 
                id="password" 
                required 
                autocomplete="new-password"
                class="appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-b-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary focus:z-10 sm:text-sm disabled:bg-gray-100 disabled:cursor-not-allowed" 
                placeholder="Password"
              />
            </div>
          </fieldset>
          
          <fieldset>
            <legend class="sr-only">Timezone</legend>
            <label for="timezone" class="block text-sm font-medium text-gray-700 mb-1">
              Timezone
            </label>
            <p class="text-sm text-gray-600 mb-2">
              We auto-detected this, but you can change it if it’s wrong.
            </p>
            <select
              id="timezone"
              name="timezone"
              class="input cursor-pointer"
              disabled={timezoneLoadError}
            >
              <option value="">
                Select your timezone (optional)
              </option>
              {timezones.map((tz) => (
                <option value={tz.value}>{tz.label}</option>
              ))}
            </select>
          </fieldset>

          <fieldset>
            <legend class="sr-only">Security check</legend>
            <HCaptcha
              tokenInputId="register_captcha_token"
              callbackName="onRegisterHCaptchaSuccess"
              errorCallback="onRegisterHCaptchaError"
              expiredCallback="onRegisterHCaptchaExpired"
              ariaLabel="Complete the CAPTCHA verification"
            />
          </fieldset>
          <div
            id="register-captcha-status"
            class="mt-2 hidden rounded-lg border p-3 text-sm status-tone-error"
            role="status"
            aria-live="polite"
          ></div>
          <div>
            <button 
              type="submit" 
              class="btn btn-md btn-primary w-full"
            >
              Register
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>
</Layout>

<script>
import { DEFAULT_TIMEZONE } from "../../lib/constants";
	import { setupDetectedTimezoneOption } from "../../lib/time/detected-timezone";

	setupDetectedTimezoneOption({ defaultTimezone: DEFAULT_TIMEZONE });
</script>

<script>
	import {
		createCaptchaStatusHelpers,
		initializeHCaptchaForm,
		setupCaptchaTokenInputListener,
		setupHCaptchaCallback,
		setupHCaptchaErrorCallback,
		setupHCaptchaExpiredCallback,
	} from "../../lib/auth/hcaptcha";
	import { rootLogger } from "../../lib/logging";

	const captchaStatus = createCaptchaStatusHelpers("register-captcha-status");

	initializeHCaptchaForm("register-form", "register_captcha_token");
	setupHCaptchaCallback(
		"onRegisterHCaptchaSuccess",
		"register_captcha_token",
		"register-form",
	);

	setupHCaptchaErrorCallback("onRegisterHCaptchaError", (errorCode) => {
		rootLogger.error("hCaptcha error", { errorCode });
		captchaStatus.show("CAPTCHA failed to load. Please refresh and try again.");
	});

	setupHCaptchaExpiredCallback(
		"onRegisterHCaptchaExpired",
		"register_captcha_token",
		() => {
			captchaStatus.show("CAPTCHA expired. Please complete it again.");
		},
	);

	setupCaptchaTokenInputListener("register_captcha_token", (token) => {
		if (token.trim().length > 0) {
			captchaStatus.hide();
		}
	});
</script>
