---

import { Icon } from "astro-icon/components";
import EmailInput from "../../components/EmailInput.vue";
import Footer from "../../components/Footer.astro";
import StatusMessage from "../../components/StatusMessage.astro";
import Layout from "../../layouts/Layout.astro";
import { createSupabaseServerClient } from "../../lib/db/supabase";
import { rootLogger } from "../../lib/logging";
import { formatMessage, MIN_PASSWORD_LENGTH, REGISTRATION_ENABLED } from "../../lib/constants";
import { getTimezoneOptions } from "../../lib/time/cache";

if (!REGISTRATION_ENABLED) {
	return Astro.redirect("/auth/signin?error=registration_closed");
}

const search = Astro.url.searchParams;
const error = search.get("error");
let showSignInLink = false;
const supabase = createSupabaseServerClient();
let timezones: Awaited<ReturnType<typeof getTimezoneOptions>> = [];
let timezoneLoadError = false;
try {
	timezones = await getTimezoneOptions(supabase);
} catch (loadError) {
	rootLogger.error(
		"Failed to load timezone options",
		{ action: "load_timezone_options", page: "register" },
		loadError,
	);
	timezoneLoadError = true;
}
const message = formatMessage(error);
if (error === "user_already_exists") {
	showSignInLink = true;
}
---
<Layout title="Create Your Account | StockTextAlerts" description="Create a new StockTextAlerts account. Sign up to get updates for your tracked US assets via email and optional text messages." noindex>
  <main id="main-content" class="min-h-screen bg-surface-alt flex flex-col justify-center px-4 py-10 sm:px-6 sm:py-12 lg:px-8">
    <header class="sm:mx-auto sm:w-full sm:max-w-md">
      <div class="flex justify-center">
        <a href="/" class="flex items-center gap-2 group" aria-label="StockTextAlerts home">
          <div class="bg-primary text-white p-1.5 rounded-lg group-hover:bg-primary-strong transition-colors shadow-sm">
            <Icon name="presentation-chart-line" class="size-8" aria-hidden="true" />
          </div>
          <span class="text-xl font-bold text-heading tracking-tight group-hover:text-primary transition-colors">StockTextAlerts</span>
        </a>
      </div>
      <h1 class="mt-6 text-center text-2xl sm:text-3xl font-extrabold text-heading">
        Create your account
      </h1>
      <p class="mt-2 text-center text-sm text-body-secondary">
        Get price alerts, daily digests, and market event notifications.
      </p>
      <p class="mt-2 text-center text-sm text-body-secondary">
        Already have an account? <a href="/auth/signin" class="link-primary">Sign in</a>
      </p>
    </header>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
      <section
        class="card max-w-md mx-auto p-8 mb-20"
        aria-labelledby="register-heading"
      >
        <h2 id="register-heading" class="sr-only">Registration form</h2>

        {message && (
          <StatusMessage class="mb-6" tone="error">
            <span>{message}</span>
            {showSignInLink && (
              <> <a href="/auth/signin" class="link-primary">Sign in</a>.</>
            )}
          </StatusMessage>
        )}

        {timezoneLoadError && (
          <StatusMessage class="mb-6" tone="warning">
            Unable to load timezone options. You can set your timezone later in your profile.
          </StatusMessage>
        )}

        <form class="space-y-6" action="/api/auth/email/register" method="post" id="register-form">
          <fieldset class="space-y-4">
            <legend class="sr-only">Account information</legend>
            <p class="text-sm text-body-secondary">
              Want access? DM <a href="https://x.com/_jsolly" class="link-primary" rel="noopener noreferrer" target="_blank">@_jsolly</a> on X for the registration password.
            </p>
            <div>
              <label for="registration_password" class="block text-sm font-medium text-label mb-2">Registration password</label>
              <input
                type="password"
                name="registration_password"
                id="registration_password"
                required
                autocomplete="off"
                spellcheck="false"
                class="input input-lg"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-label mb-2">Email</label>
              <EmailInput
                client:load
                type="email"
                name="email"
                id="email"
                required
                autocomplete="email"
                class="input input-lg"
                placeholder="you@example.com&hellip;"
              />
            </div>
            <div>
              <label for="password" class="block text-sm font-medium text-label mb-2">Password</label>
              <input
                type="password"
                name="password"
                id="password"
                required
                minlength={MIN_PASSWORD_LENGTH}
                autocomplete="new-password"
                spellcheck="false"
                class="input input-lg"
                placeholder="••••••••"
                aria-describedby="password-help"
              />
              <p id="password-help" class="mt-1.5 text-sm text-muted">At least {MIN_PASSWORD_LENGTH} characters</p>
            </div>
            <div>
              <label for="confirm" class="block text-sm font-medium text-label mb-2">Confirm password</label>
              <input
                type="password"
                name="confirm"
                id="confirm"
                required
                minlength={MIN_PASSWORD_LENGTH}
                autocomplete="new-password"
                spellcheck="false"
                class="input input-lg"
                placeholder="••••••••"
                aria-describedby="confirm-match-feedback"
              />
              <p
                id="confirm-match-feedback"
                class="mt-1.5 hidden items-center gap-1 text-sm"
                role="status"
                aria-live="polite"
              >
                <Icon id="confirm-match-icon" name="check-circle-20" class="h-4 w-4" aria-hidden="true" />
                <span id="confirm-match-text"></span>
              </p>
            </div>
          </fieldset>

          <fieldset>
            <legend class="sr-only">Timezone</legend>
            <label for="timezone" class="block text-sm font-medium text-label mb-2">
              Timezone
            </label>
            <select
              id="timezone"
              name="timezone"
              class="input cursor-pointer"
              disabled={timezoneLoadError}
              aria-describedby="timezone-help"
            >
              <option value="">
                Select your timezone (optional)
              </option>
              {timezones.map((tz) => (
                <option value={tz.value}>{tz.label}</option>
              ))}
            </select>
            <p id="timezone-help" class="mt-1.5 text-sm text-muted">
              We auto-detected this, but you can change it if it&rsquo;s wrong.
            </p>
          </fieldset>

          <button
            type="submit"
            class="btn btn-lg btn-primary w-full"
            data-submit-loading
          >
            <span>Create account</span>
          </button>
        </form>

        <p class="mt-6 text-center text-sm text-body-secondary">
          Already have an account? <a href="/auth/signin" class="link-primary">Sign in</a>
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script>
import { DEFAULT_TIMEZONE, MIN_PASSWORD_LENGTH } from "../../lib/constants";
	import { setupDetectedTimezoneOption } from "../../lib/time/detected-timezone";

	// Ensure register form preselects a detected timezone even before user profile exists.
	setupDetectedTimezoneOption({ defaultTimezone: DEFAULT_TIMEZONE });

	(() => {
		const passwordInput = document.getElementById("password");
		const confirmInput = document.getElementById("confirm");
		const feedback = document.getElementById("confirm-match-feedback");
		const feedbackIcon = document.getElementById("confirm-match-icon");
		const feedbackText = document.getElementById("confirm-match-text");

		if (
			!(passwordInput instanceof HTMLInputElement) ||
			!(confirmInput instanceof HTMLInputElement) ||
			!feedback ||
			!feedbackIcon ||
			!feedbackText
		) {
			return;
		}

		const pwInput: HTMLInputElement = passwordInput;
		const confInput: HTMLInputElement = confirmInput;
		const fb: HTMLElement = feedback;
		const fbIcon: HTMLElement = feedbackIcon;
		const fbText: HTMLElement = feedbackText;

		function hideFeedback() {
			fb.classList.add("hidden");
			fb.classList.remove("flex", "text-success-text", "text-error-text");
			fbIcon.classList.add("hidden");
			fbIcon.classList.remove("text-success-text", "text-error-text");
			fbText.textContent = "";
		}

		function showFeedback(matches: boolean) {
			fb.classList.remove("hidden");
			fb.classList.add("flex");
			fb.classList.remove("text-success-text", "text-error-text");
			fbIcon.classList.remove("hidden", "text-success-text", "text-error-text");

			if (matches) {
				fb.classList.add("text-success-text");
				fbIcon.classList.add("text-success-text");
				fbText.textContent = "Passwords match.";
				return;
			}

			fb.classList.add("text-error-text");
			fbIcon.classList.add("hidden");
			fbText.textContent = "Passwords do not match.";
		}

		function updateMatchFeedback() {
			const confirmValue = confInput.value;
			const passwordValue = pwInput.value;

			if (!confirmValue.length) {
				hideFeedback();
				return;
			}

			if (passwordValue.length < MIN_PASSWORD_LENGTH) {
				showFeedback(false);
				fbText.textContent = `Password must be at least ${MIN_PASSWORD_LENGTH} characters.`;
				return;
			}

			showFeedback(passwordValue === confirmValue);
		}

		pwInput.addEventListener("input", updateMatchFeedback);
		confInput.addEventListener("input", updateMatchFeedback);
	})();
</script>
