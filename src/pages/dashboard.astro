---

import DashboardPanels from "../components/dashboard/DashboardPanels.vue";
import Navigation from "../components/Navigation.astro";
import Layout from "../layouts/Layout.astro";
import { isUserApproved } from "../lib/auth/approval";
import { buildSigninRedirectUrl } from "../lib/auth/redirects";
import { createUserService, getUserAssets } from "../lib/db";
import { createSupabaseServerClient } from "../lib/db/supabase";
import { rootLogger } from "../lib/logging";
import { requireEnv } from "../lib/db/env";
import { formatPhoneFromE164 } from "../lib/messaging/format-phone";

const supabase = createSupabaseServerClient();
const users = createUserService(supabase, Astro.cookies);
const authUser = await users.getCurrentUser({ requireApproval: false });
if (!authUser) {
	rootLogger.info("Dashboard access attempted without authenticated user", {
		page: "dashboard",
		reason: "unauthenticated",
	});
	return Astro.redirect(
		buildSigninRedirectUrl(`${Astro.url.pathname}${Astro.url.search}`),
	);
}
const [dbUser, userAssets] = await Promise.all([
	users.getById(authUser.id),
	getUserAssets(supabase, authUser.id),
]);
if (!dbUser) {
	rootLogger.error("Auth user exists but database user record missing", {
		userId: authUser.id,
		page: "dashboard",
	});
	return Astro.redirect("/?error=user_not_found");
}
if (!isUserApproved(dbUser)) {
	rootLogger.info("Dashboard access attempted before user approval", {
		userId: authUser.id,
		page: "dashboard",
	});
	return Astro.redirect("/auth/pending-approval");
}
const initialAssets = userAssets.map((asset) => ({ symbol: asset.symbol, name: asset.name, type: asset.type, icon_url: asset.icon_url }));

// ALL per-option channel prefs live in `notification_preferences` (single source of
// truth), not on the users row, so they aren't carried by `getById`. Load every row
// for this user (session-scoped client; RLS allows reading own rows). Telegram rows
// feed the panels' telegram multiselect (grouped by type/facet); email/sms rows are
// folded back onto the user object so the existing per-option controls keep reading
// `user.<field>`.
const { data: prefRows } = await supabase
	.from("notification_preferences")
	.select("notification_type, content, channel, enabled")
	.eq("user_id", authUser.id);

// daily_digest + asset_events: keyed by content facet ("prices", "calendar", …).
const dailyDigestTelegramPrefs: Record<string, boolean> = {};
const assetEventsTelegramPrefs: Record<string, boolean> = {};
// market types (content=''): keyed by notification_type.
const marketTelegramPrefs: Record<string, boolean> = {};
// email/sms per-option fields folded back onto the user (DashboardUser augment).
const channelPrefFields: Record<string, boolean> = {};
for (const row of prefRows ?? []) {
	if (row.channel === "telegram") {
		if (row.notification_type === "daily_digest") {
			dailyDigestTelegramPrefs[row.content] = row.enabled;
		} else if (row.notification_type === "asset_events") {
			assetEventsTelegramPrefs[row.content] = row.enabled;
		} else {
			marketTelegramPrefs[row.notification_type] = row.enabled;
		}
	} else {
		const field =
			row.content === ""
				? `${row.notification_type}_include_${row.channel}`
				: `${row.notification_type}_include_${row.content}_${row.channel}`;
		channelPrefFields[field] = row.enabled;
	}
}

// Augment the users row with per-option email/sms booleans so the dashboard panels
// keep reading `user.<field>` for those controls (defaults to false when no row).
const EMAIL_SMS_PREF_FIELDS = [
	"daily_digest_include_prices_email","daily_digest_include_prices_sms",
	"daily_digest_include_top_movers_email","daily_digest_include_top_movers_sms",
	"daily_digest_include_news_email","daily_digest_include_rumors_email",
	"market_scheduled_asset_price_include_email","market_scheduled_asset_price_include_sms",
	"asset_events_include_calendar_email","asset_events_include_calendar_sms",
	"asset_events_include_ipo_email","asset_events_include_ipo_sms",
	"asset_events_include_analyst_email","asset_events_include_analyst_sms",
	"asset_events_include_insider_email","asset_events_include_insider_sms",
	"market_asset_price_alerts_include_email","market_asset_price_alerts_include_sms",
	"price_move_alerts_include_email","price_move_alerts_include_sms",
	"price_targets_include_email","price_targets_include_sms",
] as const;
const channelPrefDefaults = Object.fromEntries(
	EMAIL_SMS_PREF_FIELDS.map((f) => [f, channelPrefFields[f] ?? false]),
);
const user = { ...dbUser, ...channelPrefDefaults } as import("../lib/db").DashboardUser;

const rawTwilioNumber = requireEnv("TWILIO_PHONE_NUMBER");
const smsPhoneNumber = formatPhoneFromE164(rawTwilioNumber);
---
<Layout title="Dashboard" description="Review and manage your asset notifications. Add or remove tracked assets, set your delivery schedule, and choose email or SMS delivery." noindex>
	<div class="min-h-screen bg-surface-alt">
		<header>
			<Navigation user={authUser} />
		</header>

		<main id="main-content" class="max-w-4xl mx-auto px-0 py-0 md:px-6 md:py-12">
			<header class="mb-8 hidden md:block">
				<h1 class="text-2xl sm:text-3xl font-bold text-heading">Dashboard</h1>
				<p class="mt-2 text-sm text-body-secondary">
					Manage your alert channels, tracked assets, and delivery schedule.
				</p>
			</header>
			<DashboardPanels
				client:load
				user={user}
				initialAssets={initialAssets}
				smsPhoneNumber={smsPhoneNumber}
				dailyDigestTelegramPrefs={dailyDigestTelegramPrefs}
				assetEventsTelegramPrefs={assetEventsTelegramPrefs}
				marketTelegramPrefs={marketTelegramPrefs}
			/>
		</main>
	</div>
</Layout>
