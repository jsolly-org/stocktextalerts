---

import stocksData from "../../scripts/us-stocks.json";
import DashboardPanels from "../components/dashboard/DashboardPanels.vue";
import type { StockOption } from "../components/dashboard/stocks/StockInput.vue";
import Navigation from "../components/Navigation.astro";
import Layout from "../layouts/Layout.astro";
import { createUserService, getUserStocks } from "../lib/db";
import { createSupabaseServerClient } from "../lib/db/supabase";
import { rootLogger } from "../lib/logging";

/* ============= Precomputed Stock Options ============= */
type StockJsonItem = {
	symbol: string;
	name: string;
};
const stockOptions: StockOption[] = (
	stocksData as { data: StockJsonItem[] }
).data.map((stock) => ({
	value: stock.symbol,
	label: `${stock.symbol} - ${stock.name}`,
}));
const supabase = createSupabaseServerClient();
const users = createUserService(supabase, Astro.cookies);
const authUser = await users.getCurrentUser();
if (!authUser) {
	rootLogger.info("Dashboard access attempted without authenticated user", {
		page: "dashboard",
		reason: "unauthenticated",
	});
	return Astro.redirect("/");
}
const [dbUser, userStocks] = await Promise.all([
	users.getById(authUser.id),
	getUserStocks(supabase, authUser.id),
]);
if (!dbUser) {
	rootLogger.error("Auth user exists but database user record missing", {
		userId: authUser.id,
		page: "dashboard",
	});
	return Astro.redirect("/?error=user_not_found");
}
const user = dbUser;
const initialStocks = userStocks.map((stock) => ({ symbol: stock.symbol, name: stock.name }));
---
<Layout title="Dashboard" description="Review and manage your stock notifications">
	<div class="min-h-screen bg-gray-50">
		<Navigation user={authUser} />

		<div class="max-w-4xl mx-auto px-6 py-12">
		<DashboardPanels
			client:load
			user={user}
			stockOptions={stockOptions}
			initialStocks={initialStocks}
		/>
		</div>
	</div>
</Layout>

