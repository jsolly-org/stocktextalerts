---

import DashboardPanels from "../components/dashboard/DashboardPanels.vue";
import Navigation from "../components/Navigation.astro";
import Layout from "../layouts/Layout.astro";
import { isUserApproved } from "../lib/auth/approval/status";
import { buildSigninRedirectUrl } from "../lib/auth/redirects";
import { createUserService } from "../lib/auth/user-service";
import { NOTIFICATION_PREFERENCE_CATALOG } from "../lib/constants";
import { getUserAssets } from "../lib/db";
import { createSupabaseServerClient } from "../lib/db/supabase";
import type { PriceMoveThresholdMap } from "../components/dashboard/types";
import { rootLogger } from "../lib/logging";
import {
	buildChannelPreferenceSnapshot,
	loadUserPreferenceRows,
} from "../lib/notification-preferences/channels";

const supabase = createSupabaseServerClient();
const users = createUserService(supabase, Astro.cookies);
const authUser = await users.getCurrentUser({ requireApproval: false });
if (!authUser) {
	rootLogger.info("Dashboard access attempted without authenticated user", {
		page: "dashboard",
		reason: "unauthenticated",
	});
	return Astro.redirect(
		buildSigninRedirectUrl(`${Astro.url.pathname}${Astro.url.search}`),
	);
}
const [dbUser, userAssets] = await Promise.all([
	users.getById(authUser.id),
	getUserAssets(supabase, authUser.id),
]);
if (!dbUser) {
	rootLogger.error("Auth user exists but database user record missing", {
		userId: authUser.id,
		page: "dashboard",
	});
	return Astro.redirect("/?error=user_not_found");
}
if (!isUserApproved(dbUser)) {
	rootLogger.info("Dashboard access attempted before user approval", {
		userId: authUser.id,
		page: "dashboard",
	});
	return Astro.redirect("/auth/pending-approval");
}
const initialAssets = userAssets.map((asset) => ({ symbol: asset.symbol, name: asset.name, type: asset.type, icon_url: asset.icon_url }));

// Per-stock price-move alert thresholds (opt-in). Keyed by symbol so the market
// panel can render each tracked asset's configured threshold. authenticated has
// SELECT on the table, so the session client reads them directly. A read failure
// renders empty (graceful during the deploy window before migrations apply) but
// is logged so a permanent break is greppable rather than silent.
const { data: thresholdRows, error: thresholdReadError } = await supabase
	.from("price_move_alert_thresholds")
	.select("symbol, threshold_value, threshold_unit")
	.eq("user_id", authUser.id);
if (thresholdReadError) {
	rootLogger.warn(
		"Failed to load price-move thresholds; rendering empty",
		{ userId: authUser.id, page: "dashboard" },
		thresholdReadError,
	);
}
const priceMoveThresholds: PriceMoveThresholdMap = {};
for (const row of thresholdRows ?? []) {
	priceMoveThresholds[row.symbol] = {
		value: Number(row.threshold_value),
		unit: row.threshold_unit,
	};
}

// ALL per-option channel prefs live in `notification_preferences` (single source of
// truth), not on the users row, so they aren't carried by `getById`. Rebuild the
// flat per-option snapshot (catalog-derived; missing rows default false). Telegram
// entries feed the panels' telegram multiselect (grouped by type/facet); email
// entries are folded back onto the user object so the existing per-option controls
// keep reading `user.<field>`.
const prefRows = await loadUserPreferenceRows(supabase, authUser.id);
const prefSnapshot = buildChannelPreferenceSnapshot(prefRows);

// daily_notification: keyed by content facet ("prices", "calendar", …);
// market types (content=''): keyed by notification_type.
const dailyDigestTelegramPrefs: Record<string, boolean> = {};
const assetEventsTelegramPrefs: Record<string, boolean> = {};
const marketTelegramPrefs: Record<string, boolean> = {};
const channelPrefDefaults: Record<string, boolean> = {};
for (const entry of NOTIFICATION_PREFERENCE_CATALOG) {
	const enabled = prefSnapshot[entry.fieldName];
	if (entry.channel !== "telegram") {
		channelPrefDefaults[entry.fieldName] = enabled;
	} else if (entry.notification_type !== "daily_notification") {
		marketTelegramPrefs[entry.notification_type] = enabled;
	} else if (entry.family === "digest") {
		dailyDigestTelegramPrefs[entry.content] = enabled;
	} else {
		assetEventsTelegramPrefs[entry.content] = enabled;
	}
}
const user = { ...dbUser, ...channelPrefDefaults } as import("../lib/db/types").DashboardUser;
---
<Layout title="Dashboard" description="Review and manage your asset notifications. Add or remove tracked assets, set your delivery schedule, and choose email or Telegram delivery." hideRegistrationBanner>
	<div class="min-h-screen bg-surface-alt">
		<header>
			<Navigation user={authUser} />
		</header>

		<main id="main-content" class="max-w-4xl mx-auto px-0 py-0 md:px-6 md:py-12">
			<header class="mb-8 hidden md:block">
				<h1 class="text-2xl sm:text-3xl font-bold text-heading">Dashboard</h1>
				<p class="mt-2 text-sm text-body-secondary">
					Manage your alert channels, tracked assets, and delivery schedule.
				</p>
			</header>
			<DashboardPanels
				client:load
				user={user}
				initialAssets={initialAssets}
				dailyDigestTelegramPrefs={dailyDigestTelegramPrefs}
				assetEventsTelegramPrefs={assetEventsTelegramPrefs}
				marketTelegramPrefs={marketTelegramPrefs}
				priceMoveThresholds={priceMoveThresholds}
			/>
		</main>
	</div>
</Layout>
