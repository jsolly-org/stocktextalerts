---

import assetsData from "../../scripts/us-assets.json";
import DashboardPanels from "../components/dashboard/DashboardPanels.vue";
import type { AssetOption } from "../components/dashboard/assets/AssetInput.vue";
import Navigation from "../components/Navigation.astro";
import Layout from "../layouts/Layout.astro";
import { buildSigninRedirectUrl } from "../lib/auth/redirects";
import { createUserService, getUserAssets } from "../lib/db";
import { createSupabaseServerClient } from "../lib/db/supabase";
import { rootLogger } from "../lib/logging";

/* ============= Precomputed Asset Options ============= */
type AssetJsonItem = {
	symbol: string;
	name: string;
	type: "stock" | "etf";
};
const assetOptions: AssetOption[] = (
	assetsData as { data: AssetJsonItem[] }
).data.map((asset) => ({
	value: asset.symbol,
	label: `${asset.symbol} - ${asset.name}`,
	type: asset.type,
}));
const supabase = createSupabaseServerClient();
const users = createUserService(supabase, Astro.cookies);
const authUser = await users.getCurrentUser();
if (!authUser) {
	rootLogger.info("Dashboard access attempted without authenticated user", {
		page: "dashboard",
		reason: "unauthenticated",
	});
	const returnTo = `${Astro.url.pathname}${Astro.url.search}`;
	return Astro.redirect(buildSigninRedirectUrl(returnTo));
}
const [dbUser, userAssets] = await Promise.all([
	users.getById(authUser.id),
	getUserAssets(supabase, authUser.id),
]);
if (!dbUser) {
	rootLogger.error("Auth user exists but database user record missing", {
		userId: authUser.id,
		page: "dashboard",
	});
	return Astro.redirect("/?error=user_not_found");
}
const user = dbUser;
const initialAssets = userAssets.map((asset) => ({ symbol: asset.symbol, name: asset.name }));
---
<Layout title="Dashboard" description="Review and manage your asset notifications. Add or remove tracked assets, set your notification schedule and timezone, and choose email or SMS delivery." noindex>
	<div class="min-h-screen bg-gray-50">
		<header>
			<Navigation user={authUser} />
		</header>

		<main id="main-content" class="max-w-4xl mx-auto px-4 py-8 sm:px-6 sm:py-12">
			<header class="mb-8">
				<h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Dashboard</h1>
				<p class="mt-2 text-sm text-gray-600">
					Manage your alert channels, tracked assets, and delivery schedule.
				</p>
			</header>
			<DashboardPanels
				client:load
				user={user}
				assetOptions={assetOptions}
				initialAssets={initialAssets}
			/>
		</main>
	</div>
</Layout>

