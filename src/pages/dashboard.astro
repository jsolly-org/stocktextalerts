---
import { readFile } from "node:fs/promises";
import DashboardPanels from "../components/dashboard/DashboardPanels.vue";
import type { StockOption } from "../components/dashboard/stocks/StockInput.vue";
import Navigation from "../components/Navigation.astro";
import Layout from "../layouts/Layout.astro";
import {
	createUserService,
	getUserStocks,
	type Stock,
	type User,
} from "../lib/db";
import { createSupabaseServerClient } from "../lib/db/supabase";
import { rootLogger } from "../lib/logging";
import { formatMessage } from "../lib/status-messages";
import { getTimezoneOptions } from "../lib/time/cache";

const supabase = createSupabaseServerClient();
const users = createUserService(supabase, Astro.cookies);

const authUser = await users.getCurrentUser();

if (!authUser) {
	rootLogger.error("Dashboard access attempted without authenticated user");
	return Astro.redirect("/");
}

const dbUser = await users.getById(authUser.id);

if (!dbUser) {
	rootLogger.error("Auth user exists but database user record missing", {
		userId: authUser.id,
		page: "dashboard",
	});
	return Astro.redirect("/?error=user_not_found");
}

const user = dbUser;

const stocksFileUrl = new URL("../../scripts/us-stocks.json", import.meta.url);
const stocksFileContents = await readFile(stocksFileUrl, "utf-8");
const { data: allStocks } = JSON.parse(stocksFileContents) as { data: Stock[] };

const userStocks = await getUserStocks(supabase, authUser.id);

let timezones: Awaited<ReturnType<typeof getTimezoneOptions>>;
let timezoneLoadError = false;

try {
	timezones = await getTimezoneOptions(supabase, {
		includeValues: [user.timezone],
	});
} catch (error) {
	rootLogger.error("Failed to load timezone options", undefined, error);
	timezoneLoadError = true;
	timezones = user.timezone
		? [
				{
					value: user.timezone,
					label: user.timezone.replace(/_/g, " "),
					display_order: 0,
				},
			]
		: [];
}

const initialSymbols = userStocks.map((stock) => stock.symbol);

const stockOptions: StockOption[] = allStocks.map((stock) => ({
	value: stock.symbol,
	label: `${stock.symbol} - ${stock.name}`,
}));

const url = new URL(Astro.request.url);
const successMessage = url.searchParams.get("success");
const errorMessage = url.searchParams.get("error");
const isEditingPhone = url.searchParams.get("change_phone") === "1";

const formId = "dashboard-preferences-form";
const statusId = "dashboard-preferences-save-status";
---

<Layout title="Dashboard" description="Review and manage your stock notifications">
	<div class="min-h-screen bg-gray-50">
		<Navigation user={authUser} />

		<div class="max-w-4xl mx-auto px-6 py-12">
			<div class="mb-8 bg-white rounded-lg shadow-sm border border-gray-200 p-6">
				<h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
				<p class="mt-1 text-gray-600">
					Configure your notification preferences and track stocks.
				</p>
			</div>

		{successMessage && successMessage !== "verification_sent" && (
			<div class="mb-6 bg-green-50 border border-green-200 rounded-lg p-4" role="alert">
				<p class="text-green-800">{formatMessage(successMessage)}</p>
			</div>
		)}

		{errorMessage && (
			<div class="mb-6 bg-red-50 border border-red-200 rounded-lg p-4" role="alert">
				<p class="text-red-800">{formatMessage(errorMessage)}</p>
			</div>
		)}

		{timezoneLoadError && (
			<div class="mb-6 p-4 rounded-md bg-yellow-50 border border-yellow-200 text-yellow-700" role="alert">
				Unable to load all timezone options. Only your current timezone is available. Please refresh the page to try again.
			</div>
		)}

		<DashboardPanels
			client:load
			user={user}
			timezones={timezones}
			timezoneLoadError={timezoneLoadError}
			isEditingPhone={isEditingPhone}
			formId={formId}
			statusId={statusId}
			successMessage={successMessage}
			stockOptions={stockOptions}
			initialSymbols={initialSymbols}
		/>
		</div>
	</div>
</Layout>

