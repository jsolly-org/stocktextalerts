---
import Footer from '../components/landing/Footer.astro';
import Navigation from '../components/Navigation.astro';
import Layout from '../layouts/Layout.astro';

export const prerender = true;

const siteUrl = (Astro.site?.href ?? Astro.url.origin).replace(/\/$/, "");
const jsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		"name": "StockTextAlerts",
		"url": siteUrl,
		"logo": `${siteUrl}/favicons/android-chrome-512x512.png`,
		"description": "A free service that delivers stock and ETF price alerts via email and SMS on your schedule.",
		"contactPoint": {
			"@type": "ContactPoint",
			"email": "support@stocktextalerts.com",
			"contactType": "customer support",
		},
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
			{ "@type": "ListItem", "position": 2, "name": "About", "item": `${siteUrl}/about` },
		],
	},
];
---

<Layout
  title="About StockTextAlerts | Free Stock & ETF Price Alerts"
  description="StockTextAlerts delivers free stock and ETF price alerts via email and SMS. Learn how our service works and our commitment to investors."
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-white">
    <header>
      <Navigation />
    </header>
    <main id="main-content" class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-8 text-balance">About StockTextAlerts</h1>

      <div class="prose prose-sm max-w-none space-y-8">
        <section>
          <h2 class="text-2xl font-semibold mb-4">What we do</h2>
          <p>StockTextAlerts is a free notification service for investors and market watchers. We deliver concise stock and ETF price updates directly to your inbox or phone via SMS, on the schedule you choose.</p>
          <p>Our goal is simple: give you the market information you care about, when you want it, without the noise. No app to install, no ads, no paywalls.</p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">How it works</h2>
          <p>After <a href="/auth/register" class="link-primary">creating a free account</a>, you build a watchlist of US-listed assets from thousands of NYSE and NASDAQ tickers. Then you choose:</p>
          <ul class="list-disc ml-6 space-y-2">
            <li><strong>Delivery times:</strong> Up to five daily price check notifications, sent at the times you pick</li>
            <li><strong>Channels:</strong> Email, SMS, or both for each notification type</li>
            <li><strong>Extras:</strong> Optional daily digests with news and rumors, plus asset events (earnings, dividends, splits, insider trades, analyst consensus)</li>
            <li><strong>Format:</strong> Customize layout and data with live previews before anything is sent</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">Why we built this</h2>
          <p>Most stock alert services are either expensive, cluttered with features you don't need, or require installing yet another app. We wanted something different: a lightweight tool that delivers exactly the information you need, straight to the devices you already use.</p>
          <p>StockTextAlerts started as a personal project to solve a simple problem, and we decided to make it available to everyone for free.</p>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">Our commitment</h2>
          <ul class="list-disc ml-6 space-y-2">
            <li><strong>Free to use:</strong> Account creation, asset tracking, email alerts, and SMS delivery are all free</li>
            <li><strong>Privacy-first:</strong> We only collect the data needed to deliver your alerts. Read our <a href="/privacy" class="link-primary">privacy policy</a> for details</li>
            <li><strong>No spam:</strong> You control exactly what you receive and when. Unsubscribe or opt out any time</li>
            <li><strong>Reliable delivery:</strong> Alerts are sent on time, every time</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-semibold mb-4">Important disclaimer</h2>
          <p>StockTextAlerts is an informational service only. The data and alerts we provide should not be treated as investment advice. Always consult a qualified financial advisor before making investment decisions. See our <a href="/terms" class="link-primary">terms of service</a> for more.</p>
        </section>

        <section id="contact">
          <h2 class="text-2xl font-semibold mb-4">Contact us</h2>
          <p>Have questions, feedback, or need help with your account? Reach out at <a href="mailto:support@stocktextalerts.com" class="link-primary">support@stocktextalerts.com</a>.</p>
        </section>
      </div>
    </main>
    <Footer />
  </div>
</Layout>
