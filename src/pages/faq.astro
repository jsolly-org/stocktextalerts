---
import Footer from '../components/landing/Footer.astro';
import Navigation from '../components/Navigation.astro';
import Layout from '../layouts/Layout.astro';

export const prerender = true;

const faqs = [
	{
		question: "What is StockTextAlerts?",
		answer: "StockTextAlerts is a free service that sends you updates on the US assets you choose to track. You receive a concise summary of price changes delivered via email, SMS, or both."
	},
	{
		question: "How do asset updates work?",
		answer: "Once you create an account and pick the asset tickers you want to follow, we compile updates based on your preferences. You can receive frequent scheduled price alerts, plus optional daily and weekly notifications (like news/extras or an earnings calendar). You can choose whether each notification type is delivered via email, SMS, or both. Everything is delivered in your preferred timezone."
	},
	{
		question: "Can I choose which notifications are sent via email vs SMS?",
		answer: "Yes. Enable email and/or SMS, then choose which notification types are delivered to each channel. Some add-ons (like News and Rumors) are email-only."
	},
	{
		question: "I didn't receive my verification email. What should I do?",
		answer: "Check your spam folder, then use the resend button on the unconfirmed page to request a new verification email. If it still doesn’t arrive, reach out to support@stocktextalerts.com."
	},
	{
		question: "What assets can I track?",
		answer: "You can track any US-listed asset. Our database includes thousands of tickers from the NYSE and NASDAQ. Simply search by ticker symbol or company name in your dashboard."
	},
	{
		question: "Is StockTextAlerts free?",
		answer: "Yes. Creating an account, tracking assets, and receiving email updates are completely free. SMS delivery is also available at no extra cost."
	},
	{
		question: "How do I get asset alerts by text message?",
		answer: "After signing up, go to your dashboard and enable SMS as a notification channel. Add your phone number, verify it, and your updates will be sent as a text message in addition to (or instead of) email. You can reply STOP at any time to opt out of SMS; reply START to opt back in, then re-enable SMS from your dashboard."
	},
	{
		question: "When are updates sent?",
		answer: "You can choose up to five delivery times for market price notifications (in your preferred timezone). Daily notifications are sent once per day at your selected daily delivery time, and the weekly calendar is delivered every Monday (at your daily delivery time, or 9:00 AM by default)."
	},
	{
		question: "What are Daily Notifications?",
		answer: "Daily Notifications are a once-daily digest that's separate from market price alerts. You can add optional extras like News, Rumors, Analyst Consensus, and Insider Trades for the assets you track. News and Rumors are email-only and may include clickable source links in the email."
	},
	{
		question: "What is the Weekly Calendar?",
		answer: "The Weekly Calendar is a Monday notification that highlights upcoming earnings reports for the assets you track, so you can see what's coming up for the week. You can choose to receive it via email, SMS, or both."
	},
	{
		question: "What information is included in the updates?",
		answer: "Each update shows the ticker symbol, current price, and percentage change for every asset you track. It's designed to be a quick, at-a-glance summary you can read in seconds."
	},
	{
		question: "Can I customize how the updates look?",
		answer: "Yes. You can set format preferences like showing the company name, including percent change, and using a more detailed layout. You'll also see live previews so you know what your email and SMS updates will look like."
	},
	{
		question: "Do I need to install an app?",
		answer: "No. StockTextAlerts works entirely through email and SMS. There is nothing to download or install. Manage your settings through our website and receive your updates in your inbox or messaging app."
	},
	{
		question: "How do I add or remove assets from my watchlist?",
		answer: "Log in and visit your dashboard. Use the asset search to find tickers and add them to your list. To remove an asset, click the remove button next to its name."
	},
	{
		question: "Is StockTextAlerts investment advice?",
		answer: "No. StockTextAlerts is an informational service only. The data we provide should not be treated as investment advice. Always consult a qualified financial advisor before making investment decisions."
	},
];

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map(faq => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.answer,
		},
	})),
};
---

<Layout
  title="Frequently Asked Questions | StockTextAlerts"
  description="Frequently asked questions about StockTextAlerts. Learn how asset updates work, what assets you can track, how to get alerts by text message, and more."
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-white">
    <header>
      <Navigation />
    </header>
    <main id="main-content" class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-4 text-balance">Frequently Asked Questions</h1>
      <p class="text-lg text-gray-600 mb-10">Everything you need to know about tracking assets and choosing how you receive notifications (email, SMS, or both).</p>

      <div class="space-y-8">
        {faqs.map((faq) => (
          <section class="border-b border-gray-200 pb-8">
            <h2 class="text-xl font-semibold text-gray-900 mb-3">{faq.question}</h2>
            <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
          </section>
        ))}
      </div>

      <div class="mt-12 bg-gray-50 rounded-lg p-6 sm:p-8 border border-gray-200">
        <h2 class="text-xl font-semibold text-gray-900 mb-2">Still have questions?</h2>
        <p class="text-gray-600">
          Reach out to us at <a href="mailto:support@stocktextalerts.com" class="link-primary">support@stocktextalerts.com</a> and we'll get back to you.
        </p>
      </div>
    </main>
    <Footer />
  </div>
</Layout>
