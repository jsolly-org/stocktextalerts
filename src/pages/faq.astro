---
import Footer from '../components/Footer.astro';
import Navigation from '../components/Navigation.astro';
import Layout from '../layouts/Layout.astro';
import { REGISTRATION_ENABLED } from '../lib/constants';

export const prerender = true;

const faqs = [
	{
		question: "What is StockTextAlerts?",
		answer: REGISTRATION_ENABLED
			? 'This free service sends updates on US stocks and ETFs you choose to follow. You receive a concise summary of price changes by email, SMS, or both. <a href="/auth/register" class="link-primary">Create a free account</a> to get started.'
			: 'This free service sends updates on US stocks and ETFs you choose to follow. You receive a concise summary of price changes by email, SMS, or both. <a href="/auth/signin" class="link-primary">Sign in</a> to get started.'
	},
	{
		question: "How do asset updates work?",
		answer: REGISTRATION_ENABLED
			? 'Once you <a href="/auth/register" class="link-primary">create an account</a> and pick the asset tickers you want to follow, we compile updates based on your preferences. You can receive scheduled market asset price notifications, optional Asset Price Alerts, optional Price Targets, plus an optional daily digest and asset events notifications. You can choose whether each notification type is delivered by email, SMS, or both.'
			: 'Once you <a href="/auth/signin" class="link-primary">sign in</a> and pick the asset tickers you want to follow, we compile updates based on your preferences. You can receive scheduled market asset price notifications, optional Asset Price Alerts, optional Price Targets, plus an optional daily digest and asset events notifications. You can choose whether each notification type is delivered by email, SMS, or both.'
	},
	{
		question: "What are Asset Price Alerts?",
		answer: "Asset Price Alerts are optional smart alerts for tracked stocks (not ETFs) during US market hours. You can choose sensitivity (Significant or Extreme). We evaluate alert conditions throughout the trading day and limit delivery to one alert per symbol per US trading day."
	},
	{
		question: "What are Price Targets?",
		answer: "Price Targets let you set a specific price for any watchlist symbol (e.g. alert me when AAPL hits $200). When the price is reached during US market hours, we send a one-shot notification by email and/or SMS (your choice). The target is then cleared; you can set a new one from your dashboard."
	},
	{
		question: "Can I choose which notifications are sent via email vs SMS?",
		answer: "Yes. Enable email and/or SMS, then choose which notification types are delivered to each channel (including Asset Price Alerts, Price Targets, and Asset Events). Some add-ons (like News and Rumors) are email-only. You can also manage channels by SMS command: reply STOP to pause SMS, START to resume SMS, STOP EMAIL to disable email notifications, STOP ALL to disable both, or HELP for options."
	},
	{
		question: "I didn\u2019t receive my verification email. What should I do?",
		answer: 'Check your spam folder, then use the resend button on the unconfirmed page to request a new verification email. If it still doesn\u2019t arrive, email <a href="mailto:support@stocktextalerts.com" class="link-primary">support@stocktextalerts.com</a> or <a href="/contact" class="link-primary">use our contact page</a>.'
	},
	{
		question: "Why did I get a rate limit message when changing my password, email, or deleting my account?",
		answer: "To protect your account, we limit how often you can attempt certain sensitive actions (password change, email change, account deletion). If you see a rate limit message, wait the specified number of minutes and try again. For password help, you can use the forgot-password flow. For other issues, contact support."
	},
	{
		question: "What assets can I track?",
		answer: "You can track up to 10 US-listed stocks and ETFs. Simply search by ticker symbol or company name in your dashboard."
	},
	{
		question: "Is StockTextAlerts free?",
		answer: REGISTRATION_ENABLED
			? 'Yes. Creating an account, tracking assets, and receiving email updates are completely free. SMS delivery is also available at no extra cost. <a href="/auth/register" class="link-primary">Sign up for free</a>.'
			: 'Yes. Creating an account, tracking assets, and receiving email updates are completely free. SMS delivery is also available at no extra cost.'
	},
	{
		question: "How do I get asset alerts by text message?",
		answer: REGISTRATION_ENABLED
			? 'After <a href="/auth/register" class="link-primary">signing up</a>, go to your dashboard and enable SMS as a notification channel. Add your phone number, verify it, and your updates will be sent as a text message in addition to (or instead of) email. You can reply STOP to pause SMS and START to turn SMS back on, or update notification settings in your dashboard.'
			: 'After <a href="/auth/signin" class="link-primary">signing in</a>, go to your dashboard and enable SMS as a notification channel. Add your phone number, verify it, and your updates will be sent as a text message in addition to (or instead of) email. You can reply STOP to pause SMS and START to turn SMS back on, or update notification settings in your dashboard.'
	},
	{
		question: "When are updates sent?",
		answer: "You can choose up to eight delivery times for scheduled market asset price notifications. Notifications send anytime US markets are trading — pre-market (4:30 AM–9:30 AM ET), regular hours (9:30 AM–4:00 PM ET), or after-hours (4:00 PM–7:30 PM ET) on market-open days. The 30-minute gaps between sessions (9:00–9:30 AM and 4:00–4:30 PM ET) are skipped. Asset Price Alerts (if enabled) run during US market hours and can trigger as activity happens, with delivery limited to one alert per symbol per US trading day. Price targets (if set) trigger when the market price reaches your target, then are cleared. The daily digest is sent once per day at your selected daily delivery time, and asset events (calendar events like earnings/dividends/splits, upcoming IPOs, and optional extras like insider trades and analyst consensus) are delivered at the same time (note: analyst consensus may be sent up to once per month)."
	},
	{
		question: "What is the Daily Digest?",
		answer: "The Daily Digest is a once-daily summary of your tracked asset prices that\u2019s separate from asset price alerts. You can add optional extras like News and Rumors for the assets you track. News and Rumors are email-only and may include clickable source links in the email."
	},
	{
		question: "What are Asset Events?",
		answer: "Asset Events is a daily notification that can include calendar events (earnings/dividends/splits), upcoming IPOs, insider trades, and analyst consensus. Each section has its own email/SMS toggle, so you can choose exactly what is delivered by channel. (Analyst consensus is typically sent up to once per month.)"
	},
	{
		question: "What information is included in the updates?",
		answer: "Each update shows the ticker symbol, current price, and percentage change for every asset you track. It\u2019s designed to be a quick, at-a-glance summary you can read in seconds."
	},
	{
		question: "Can I customize how the updates look?",
		answer: "Yes. Updates always include the ticker, current price, and percent change. You can also toggle sparklines (a small weekly price trend) and use live previews so you know what your email and SMS updates will look like."
	},
	{
		question: "Do I need to install an app?",
		answer: REGISTRATION_ENABLED
			? 'No. StockTextAlerts works entirely through email and SMS. There is nothing to download or install. <a href="/auth/register" class="link-primary">Create an account</a>, manage your settings through our website, and receive your updates in your inbox or messaging app.'
			: 'No. StockTextAlerts works entirely through email and SMS. There is nothing to download or install. <a href="/auth/signin" class="link-primary">Sign in</a>, manage your settings through our website, and receive your updates in your inbox or messaging app.'
	},
	{
		question: "How do I add or remove assets from my watchlist?",
		answer: '<a href="/auth/signin" class="link-primary">Sign in to your dashboard</a> to manage your watchlist. Use the asset search to find tickers and add them to your list. To remove an asset, click the remove button next to its name.'
	},
	{
		question: "Is StockTextAlerts investment advice?",
		answer: "No. This is an informational service only. The data we provide should not be treated as investment advice. Always consult a qualified financial advisor before making investment decisions."
	},
];

const siteUrl = (Astro.site?.href ?? Astro.url.origin).replace(/\/$/, "");

const jsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"mainEntity": faqs.map(faq => ({
			"@type": "Question",
			"name": faq.question,
			"acceptedAnswer": {
				"@type": "Answer",
				"text": faq.answer.replace(/<[^>]*>/g, ""),
			},
		})),
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
			{ "@type": "ListItem", "position": 2, "name": "FAQ", "item": `${siteUrl}/faq` },
		],
	},
];
---

<Layout
  title="Stock Alert FAQ | How Notifications Work"
  description="FAQs about StockTextAlerts. Learn how stock and ETF price alerts work, what US assets you can track, and how to get free alerts by text."
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-surface">
    <header>
      <Navigation />
    </header>
    <main id="main-content" class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-4 text-balance">Stock & ETF Alert FAQ</h1>
      <p class="text-lg text-body-secondary mb-10">Everything you need to know about tracking assets and choosing how you receive notifications (scheduled updates, Asset Price Alerts, and Price Targets by email, SMS, or both).</p>

      <div class="space-y-8">
        {faqs.map((faq) => (
          <section class="border-b border-edge pb-8">
            <h2 class="text-xl font-semibold text-heading mb-3">{faq.question}</h2>
            <p class="text-body-secondary leading-relaxed" set:html={faq.answer} />
          </section>
        ))}
      </div>

      <div class="mt-12 bg-surface-alt rounded-lg p-6 sm:p-8 border border-edge">
        <h2 class="text-xl font-semibold text-heading mb-2">Still have questions?</h2>
        <p class="text-body-secondary">
          Send us a message via our <a href="/contact" class="link-primary">contact page</a> or email <a href="mailto:support@stocktextalerts.com" class="link-primary">support@stocktextalerts.com</a> and we&rsquo;ll get back to you.
        </p>
      </div>
    </main>
    <Footer />
  </div>
</Layout>
