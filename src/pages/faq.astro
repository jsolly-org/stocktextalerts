---
import Footer from '../components/Footer.astro';
import Navigation from '../components/Navigation.astro';
import Layout from '../layouts/Layout.astro';
import { REGISTRATION_ENABLED } from '../lib/constants';

export const prerender = true;

const faqs = [
	{
		question: "What is StockTextAlerts?",
		answer: REGISTRATION_ENABLED
			? 'This free service sends updates on US stocks and ETFs you choose to follow. You receive a concise summary of price changes by email, SMS, or Telegram. <a href="/auth/register" class="link-primary">Create a free account</a> to get started.'
			: 'This free service sends updates on US stocks and ETFs you choose to follow. You receive a concise summary of price changes by email, SMS, or Telegram. <a href="/auth/signin" class="link-primary">Sign in</a> to get started.'
	},
	{
		question: "How do asset updates work?",
		answer: REGISTRATION_ENABLED
			? 'Once you <a href="/auth/register" class="link-primary">create an account</a> and pick the asset tickers you want to follow, we compile updates based on your preferences. You can receive scheduled market asset price notifications, optional Asset Price Alerts, plus an optional daily digest and asset events notifications. You can choose whether each notification type is delivered by email, SMS, or Telegram.'
			: 'Once you <a href="/auth/signin" class="link-primary">sign in</a> and pick the asset tickers you want to follow, we compile updates based on your preferences. You can receive scheduled market asset price notifications, optional Asset Price Alerts, plus an optional daily digest and asset events notifications. You can choose whether each notification type is delivered by email, SMS, or Telegram.'
	},
	{
		question: "What are Price Move Alerts?",
		answer: "Price Move Alerts notify you when a tracked stock moves past a threshold you set — as a percent or a dollar change in a single US trading day. Set a threshold per stock (they're off until you do). The move is measured from yesterday's close on the first alert, then re-triggered on each additional move of that size, and delivery is limited to protect against noise during busy sessions."
	},
	{
		question: "Can I choose which channel each notification uses?",
		answer: "Yes. Enable email, SMS, and/or Telegram, then choose which notification types are delivered to each channel (including Asset Price Alerts and Asset Events). News and Rumors are available by email and Telegram (not SMS). You can manage email and SMS by text command: reply STOP to pause SMS, START to resume SMS, STOP EMAIL to disable email notifications, STOP ALL to disable both, or HELP for options. Telegram is paused with the /stop command in the bot."
	},
	{
		question: "I didn\u2019t receive my verification email. What should I do?",
		answer: 'Check your spam folder, then use the resend button on the unconfirmed page to request a new verification email. If it still doesn\u2019t arrive, email <a href="mailto:support@stocktextalerts.com" class="link-primary">support@stocktextalerts.com</a> or <a href="/contact" class="link-primary">use our contact page</a>.'
	},
	{
		question: "Why did I get a rate limit message when changing my password, email, or deleting my account?",
		answer: "To protect your account, we limit how often you can attempt certain sensitive actions (password change, email change, account deletion). If you see a rate limit message, wait the specified number of minutes and try again. For password help, you can use the forgot-password flow. For other issues, contact support."
	},
	{
		question: "What assets can I track?",
		answer: "You can track up to 10 US-listed stocks and ETFs. Simply search by ticker symbol or company name in your dashboard."
	},
	{
		question: "Is StockTextAlerts free?",
		answer: REGISTRATION_ENABLED
			? 'Yes. Creating an account, tracking assets, and receiving email updates are completely free. SMS and Telegram delivery are also available at no extra cost. <a href="/auth/register" class="link-primary">Sign up for free</a>.'
			: 'Yes. Creating an account, tracking assets, and receiving email updates are completely free. SMS and Telegram delivery are also available at no extra cost.'
	},
	{
		question: "How do I get asset alerts on Telegram?",
		answer: REGISTRATION_ENABLED
			? 'After <a href="/auth/register" class="link-primary">signing up</a>, go to your dashboard and enable Telegram as a notification channel. Link your Telegram account, and your updates will be sent to Telegram in addition to (or instead of) email. You can turn Telegram off at any time in your notification settings.'
			: 'After <a href="/auth/signin" class="link-primary">signing in</a>, go to your dashboard and enable Telegram as a notification channel. Link your Telegram account, and your updates will be sent to Telegram in addition to (or instead of) email. You can turn Telegram off at any time in your notification settings.'
	},
	{
		question: "When are updates sent?",
		answer: 'You can choose up to eight delivery times for scheduled market asset price notifications. Times shown in <a href="/profile#timezone-heading" class="link-primary">your local timezone</a>, anchored to US market hours (4:30 AM – 7:30 PM ET). Notifications send whenever US markets are trading (pre-market, regular hours, or after-hours). Sends are skipped on weekends, full-day holidays, and after early-close days (~3 per year). Price Move Alerts (if enabled) run during US market hours and trigger when a tracked stock crosses your configured threshold, with delivery limited per symbol per US trading day. The daily digest is sent once per day at your selected daily delivery time, and asset events (calendar events like earnings/dividends/splits, upcoming IPOs, and optional extras like insider trades and analyst consensus) are delivered at the same time (note: analyst consensus may be sent up to once per month).'
	},
	{
		question: "What is the Daily Digest?",
		answer: "The Daily Digest is a once-daily summary of your tracked asset prices that\u2019s separate from asset price alerts. You can add optional extras like News and Rumors for the assets you track. News and Rumors are available by email and Telegram, and may include clickable source links."
	},
	{
		question: "What are Asset Events?",
		answer: "Asset Events is a daily notification that can include calendar events (earnings/dividends/splits), upcoming IPOs, insider trades, and analyst consensus. Each section has its own email, SMS, and Telegram toggle, so you can choose exactly what is delivered by channel. (Analyst consensus is typically sent up to once per month.)"
	},
	{
		question: "What information is included in the updates?",
		answer: "Each update shows the ticker symbol, current price, and percentage change for every asset you track. It\u2019s designed to be a quick, at-a-glance summary you can read in seconds."
	},
	{
		question: "Can I customize how the updates look?",
		answer: "Yes. Updates always include the ticker, current price, and percent change. You can also toggle sparklines (a small weekly price trend) and use live previews so you know what your email, SMS, and Telegram updates will look like."
	},
	{
		question: "Do I need to install an app?",
		answer: REGISTRATION_ENABLED
			? 'No. StockTextAlerts has no app of its own — you manage everything through our website. Updates arrive by email, SMS, or Telegram: email and SMS work with no setup, and Telegram simply uses the free Telegram app if you choose that channel. <a href="/auth/register" class="link-primary">Create an account</a> and pick the channels you want.'
			: 'No. StockTextAlerts has no app of its own — you manage everything through our website. Updates arrive by email, SMS, or Telegram: email and SMS work with no setup, and Telegram simply uses the free Telegram app if you choose that channel. <a href="/auth/signin" class="link-primary">Sign in</a> and pick the channels you want.'
	},
	{
		question: "How do I add or remove assets from my watchlist?",
		answer: '<a href="/auth/signin" class="link-primary">Sign in to your dashboard</a> to manage your watchlist. Use the asset search to find tickers and add them to your list. To remove an asset, click the remove button next to its name.'
	},
	{
		question: "Is StockTextAlerts investment advice?",
		answer: "No. This is an informational service only. The data we provide should not be treated as investment advice. Always consult a qualified financial advisor before making investment decisions."
	},
];

const siteUrl = (Astro.site?.href ?? Astro.url.origin).replace(/\/$/, "");

const jsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"mainEntity": faqs.map(faq => ({
			"@type": "Question",
			"name": faq.question,
			"acceptedAnswer": {
				"@type": "Answer",
				"text": faq.answer.replace(/<[^>]*>/g, ""),
			},
		})),
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
			{ "@type": "ListItem", "position": 2, "name": "FAQ", "item": `${siteUrl}/faq` },
		],
	},
];
---

<Layout
  title="Stock Alert FAQ | How Notifications Work"
  description="FAQs about StockTextAlerts. Learn how stock and ETF price alerts work, what US assets you can track, and how to get free alerts by email or Telegram."
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-surface">
    <header>
      <Navigation />
    </header>
    <main id="main-content" class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-4 text-balance">Stock & ETF Alert FAQ</h1>
      <p class="text-lg text-body-secondary mb-10">Everything you need to know about tracking assets and choosing how you receive notifications (scheduled updates and Asset Price Alerts by email, SMS, or Telegram).</p>

      <div class="space-y-8">
        {faqs.map((faq) => (
          <section class="border-b border-edge pb-8">
            <h2 class="text-xl font-semibold text-heading mb-3">{faq.question}</h2>
            <p class="text-body-secondary leading-relaxed" set:html={faq.answer} />
          </section>
        ))}
      </div>

      <div class="mt-12 bg-surface-alt rounded-lg p-6 sm:p-8 border border-edge">
        <h2 class="text-xl font-semibold text-heading mb-2">Still have questions?</h2>
        <p class="text-body-secondary">
          Send us a message via our <a href="/contact" class="link-primary">contact page</a> or email <a href="mailto:support@stocktextalerts.com" class="link-primary">support@stocktextalerts.com</a> and we&rsquo;ll get back to you.
        </p>
      </div>
    </main>
    <Footer />
  </div>
</Layout>
