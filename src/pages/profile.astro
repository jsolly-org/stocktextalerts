---

import { Icon } from "astro-icon/components";
import Navigation from "../components/Navigation.astro";
import AccountManagement from "../components/profile/AccountManagement.astro";
import DangerZone from "../components/profile/DangerZone.astro";
import TimeFormatSection from "../components/profile/TimeFormatSection.vue";
import TimezoneSection from "../components/profile/TimezoneSection.vue";
import StatusMessage from "../components/StatusMessage.astro";
import Layout from "../layouts/Layout.astro";
import { isUserApproved } from "../lib/auth/approval/status";
import { getAuthErrorMessage } from "../lib/auth/messages";
import { buildSigninRedirectUrl } from "../lib/auth/redirects";
import { formatMessage } from "../lib/messaging/status-messages";
import { createUserService } from "../lib/auth/user-service";
import { createSupabaseServerClient } from "../lib/db/supabase";
import { rootLogger } from "../lib/logging";
import { getTimezoneOptions } from "../lib/time/timezone/cache";

const supabase = createSupabaseServerClient();
const users = createUserService(supabase, Astro.cookies);
const authUser = await users.getCurrentUser({ requireApproval: false });
if (!authUser) {
	rootLogger.info("Profile access attempted without authenticated user", {
		page: "profile",
		reason: "unauthenticated",
	});
	return Astro.redirect(
		buildSigninRedirectUrl(`${Astro.url.pathname}${Astro.url.search}`),
	);
}
const user = await users.getById(authUser.id);
if (!user) {
	rootLogger.error("Auth user exists but database user record missing", {
		userId: authUser.id,
		page: "profile",
	});
	return Astro.redirect("/?error=user_not_found");
}
if (!isUserApproved(user)) {
	rootLogger.info("Profile access attempted before user approval", {
		userId: authUser.id,
		page: "profile",
	});
	return Astro.redirect("/auth/pending-approval");
}
let timezones: Awaited<ReturnType<typeof getTimezoneOptions>>;
let timezoneLoadError = false;
try {
	const includeValues = user.timezone ? [user.timezone] : [];
	timezones = await getTimezoneOptions(supabase, {
		includeValues,
	});
} catch (error) {
	rootLogger.error(
		"Failed to load timezone options",
		{ userId: user.id, action: "load_timezone_options" },
		error,
	);
	timezoneLoadError = true;
	timezones = user.timezone
		? [
				{
					value: user.timezone,
					label: user.timezone.replace(/_/g, " "),
					display_order: 0,
				},
			]
		: [];
}
const search = Astro.url.searchParams;
const error = search.get("error");
const success = search.get("success");
const minutesNum = Number.parseInt(search.get("minutes") ?? "", 10);
const minutes =
	Number.isFinite(minutesNum) && minutesNum >= 0 ? String(minutesNum) : null;
let errorMessage = "";
if (error) {
	if (error === "rate_limit" && minutes) {
		errorMessage = `You've made too many requests. Please wait ${minutes} minutes and try again.`;
	} else {
		errorMessage = getAuthErrorMessage(error);
	}
}
const successMessage = formatMessage(success);
---
<Layout title="Profile" description="Edit your profile and manage your StockTextAlerts account settings, including email, password, and notification delivery preferences." noindex>
  <div class="min-h-screen bg-surface-alt">
    <header>
      <Navigation user={authUser} />
    </header>
    
    <main id="main-content" class="max-w-3xl mx-auto px-4 py-8 sm:px-6 sm:py-12">
			<header class="card mb-8">
				<div class="card-accent card-accent-primary"></div>
				<div class="card-body">
					<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
						<div>
							<h1 class="text-2xl sm:text-3xl font-bold text-heading">Profile</h1>
							<p class="mt-1 text-body-secondary">Review and update account settings.</p>
						</div>
						<a href="/dashboard" class="link-primary inline-flex items-center gap-2">
							<Icon name="arrow-left" class="size-4" aria-hidden="true" />
							Back to Dashboard
						</a>
					</div>
				</div>
			</header>
    
      <div class="space-y-6">
        {errorMessage && (
          <StatusMessage tone="error" message={errorMessage} />
        )}

        {successMessage && (
          <StatusMessage tone="success" message={successMessage} />
        )}

        <section>
          <AccountManagement
            email={user.email}
          />
        </section>

				<section>
					<TimezoneSection
						client:idle
						user={user}
						timezones={timezones}
						timezoneLoadError={timezoneLoadError}
					/>
				</section>

				<section>
					<TimeFormatSection
						client:idle
						user={user}
					/>
				</section>
      </div>

			<section class="mt-6">
				<DangerZone />
			</section>
    </main>
  </div>
</Layout>
