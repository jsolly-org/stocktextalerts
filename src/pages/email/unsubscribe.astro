---
import Layout from "../../layouts/Layout.astro";
import StatusMessage from "../../components/StatusMessage.astro";
import { createUserService } from "../../lib/db";
import { createSupabaseAdminClient, createSupabaseServerClient } from "../../lib/db/supabase";
import { createLogger } from "../../lib/logging";
import { verifyEmailUnsubscribeToken } from "../../lib/messaging/email/unsubscribe";
import { isValidUuid } from "../../lib/validation";

const logger = createLogger({
	requestId: Astro.locals?.requestId,
	path: Astro.url.pathname,
	method: Astro.request.method,
});

const userId = Astro.url.searchParams.get("user");
const token = Astro.url.searchParams.get("token");

/** Token length cap to reject malformed or oversized values early. */
const MAX_TOKEN_LENGTH = 200;
const isValidToken = (s: string | null) =>
	typeof s === "string" && s.length > 0 && s.length <= MAX_TOKEN_LENGTH;

const serverSupabase = createSupabaseServerClient();
const users = createUserService(serverSupabase, Astro.cookies);
const isLoggedIn = !!(await users.getCurrentUser());

let tone: "success" | "error" = "error";
let message =
	"This unsubscribe link is invalid or has expired. Please sign in to manage your email notification-preferences.";
let canOfferSmsOptOut = false;
let smsOptOutUrl: string | null = null;

if (userId && token && isValidUuid(userId) && isValidToken(token)) {
	const supabase = createSupabaseAdminClient();
	const { data: user, error } = await supabase
		.from("users")
		.select("id,email,email_notifications_enabled,phone_verified")
		.eq("id", userId)
		.maybeSingle();

	// Per-option SMS facets live in notification_preferences; load this user's enabled
	// SMS rows so we can offer (and apply) a one-click SMS opt-out alongside email.
	const { data: smsPrefRows } = user
		? await supabase
				.from("notification_preferences")
				.select("notification_type, content")
				.eq("user_id", user.id)
				.eq("channel", "sms")
				.eq("enabled", true)
		: { data: null };

	if (error) {
		logger.error(
			"Failed to load user for email unsubscribe",
			{ userId },
			error,
		);
	} else if (!user) {
		logger.info("Email unsubscribe rejected: user not found", { userId });
	} else {
		const verification = verifyEmailUnsubscribeToken({
			userId: user.id,
			email: user.email,
			token,
		});

		if (!verification.ok) {
			logger.info("Email unsubscribe rejected: invalid token", {
				userId,
				reason: verification.reason,
			});
		} else {
			const wantsSmsOptOut = Astro.url.searchParams.get("sms") === "true";
			const enabledSmsRows = smsPrefRows ?? [];
			const canOptOutSms = user.phone_verified && enabledSmsRows.length > 0;

			const { error: updateError } = await supabase
				.from("users")
				.update({ email_notifications_enabled: false })
				.eq("id", user.id);

			// Turn off every enabled SMS facet row when the user asked to also opt out of SMS.
			let smsUpdateError = updateError;
			if (!updateError && wantsSmsOptOut && canOptOutSms) {
				const { error: smsError } = await supabase
					.from("notification_preferences")
					.update({ enabled: false })
					.eq("user_id", user.id)
					.eq("channel", "sms")
					.eq("enabled", true);
				smsUpdateError = smsError;
			}

			if (smsUpdateError) {
				logger.error(
					"Failed to disable email notifications via unsubscribe",
					{ userId },
					smsUpdateError,
				);
			} else {
				tone = "success";
				message =
					wantsSmsOptOut && canOptOutSms
						? `Email and SMS notifications are now turned off. You can ${isLoggedIn ? "visit your dashboard" : "sign in"} anytime to adjust your delivery schedule.`
						: `Email notifications are now turned off. You can ${isLoggedIn ? "visit your dashboard" : "sign in"} anytime to adjust your delivery schedule.`;

				if (canOptOutSms && !wantsSmsOptOut) {
					const params = new URLSearchParams({
						user: userId,
						token,
						sms: "true",
					});
					smsOptOutUrl = `/email/unsubscribe?${params.toString()}`;
					canOfferSmsOptOut = true;
				}
			}
		}
	}
}
---
<Layout title="Email Unsubscribe" description="Update your email notifications. Unsubscribe from StockTextAlerts emails or adjust your notification channels using your unique link." noindex>
	<main
		id="main-content"
		class="min-h-screen flex items-center justify-center bg-surface-alt py-12 px-4 sm:px-6 lg:px-8"
	>
		<div class="max-w-md w-full space-y-6">
			<header class="text-center">
				<h1 class="text-2xl sm:text-3xl font-bold text-heading">
					Email Notifications
				</h1>
				<p class="mt-2 text-sm text-body-secondary">
					Manage your email delivery notification-preferences.
				</p>
			</header>

			<StatusMessage tone={tone}>{message}</StatusMessage>

			{tone === "success" && canOfferSmsOptOut && smsOptOutUrl && (
				<div class="rounded-lg border border-edge bg-surface p-4 text-sm text-body-secondary">
					<p class="font-medium text-heading">Also unsubscribe from SMS?</p>
					<p class="mt-1">
						You can turn off SMS alerts from this same page.
					</p>
					<a
						href={smsOptOutUrl}
						class="mt-3 inline-flex w-full items-center justify-center rounded-md border border-edge-strong bg-surface px-4 py-2 text-sm font-semibold text-heading shadow-sm transition hover:bg-surface-alt focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
					>
						Unsubscribe from SMS too
					</a>
				</div>
			)}

			<div>
				{isLoggedIn ? (
					<a href="/dashboard" class="btn btn-md btn-primary w-full">
						Go to Dashboard
					</a>
				) : (
					<a href="/auth/signin" class="btn btn-md btn-primary w-full">
						Sign in to adjust schedule
					</a>
				)}
			</div>
		</div>
	</main>
</Layout>
