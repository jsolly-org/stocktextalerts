---
import Layout from "../../layouts/Layout.astro";
import StatusMessage from "../../components/StatusMessage.astro";
import { createSupabaseAdminClient } from "../../lib/db/supabase";
import { createLogger } from "../../lib/logging";
import { verifyEmailUnsubscribeToken } from "../../lib/notifications/email-unsubscribe";

const logger = createLogger({
	requestId: Astro.locals?.requestId,
	path: Astro.url.pathname,
	method: Astro.request.method,
});

const userId = Astro.url.searchParams.get("user");
const token = Astro.url.searchParams.get("token");

let tone: "success" | "error" = "error";
let message =
	"This unsubscribe link is invalid or has expired. Please sign in to manage your email notification-preferences.";
let canOfferSmsOptOut = false;
let smsOptOutUrl: string | null = null;

if (userId && token) {
	const supabase = createSupabaseAdminClient();
	const { data: user, error } = await supabase
		.from("users")
		.select("id,email,email_notifications_enabled,sms_notifications_enabled")
		.eq("id", userId)
		.maybeSingle();

	if (error) {
		logger.error(
			"Failed to load user for email unsubscribe",
			{ userId },
			error,
		);
	} else if (!user) {
		logger.info("Email unsubscribe rejected: user not found", { userId });
	} else {
		const verification = verifyEmailUnsubscribeToken({
			userId: user.id,
			email: user.email,
			token,
		});

		if (!verification.ok) {
			logger.info("Email unsubscribe rejected: invalid token", {
				userId,
				reason: verification.reason,
			});
		} else {
			const wantsSmsOptOut = Astro.url.searchParams.get("sms") === "true";
			const canOptOutSms = user.sms_notifications_enabled;
			const updates = {
				email_notifications_enabled: false,
				...(wantsSmsOptOut && canOptOutSms
					? { sms_notifications_enabled: false }
					: {}),
			};

			const { error: updateError } = await supabase
				.from("users")
				.update(updates)
				.eq("id", user.id);

			if (updateError) {
				logger.error(
					"Failed to disable email notifications via unsubscribe",
					{ userId },
					updateError,
				);
			} else {
				tone = "success";
				message =
					wantsSmsOptOut && canOptOutSms
						? "Email and SMS notifications are now turned off. You can sign in anytime to adjust your delivery schedule."
						: "Email notifications are now turned off. You can sign in anytime to adjust your delivery schedule.";

				if (canOptOutSms && !wantsSmsOptOut) {
					const params = new URLSearchParams({
						user: userId,
						token,
						sms: "true",
					});
					smsOptOutUrl = `/email/unsubscribe?${params.toString()}`;
					canOfferSmsOptOut = true;
				}
			}
		}
	}
}
---
<Layout title="Email Unsubscribe" description="Update your email notifications. Unsubscribe from Stock Text Alerts digest emails or adjust your notification channels using your unique link.">
	<main
		id="main-content"
		class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8"
	>
		<div class="max-w-md w-full space-y-6">
			<header class="text-center">
				<h1 class="text-2xl sm:text-3xl font-bold text-gray-900">
					Email Notifications
				</h1>
				<p class="mt-2 text-sm text-gray-600">
					Manage your email delivery notification-preferences.
				</p>
			</header>

			<StatusMessage tone={tone}>{message}</StatusMessage>

			{tone === "success" && canOfferSmsOptOut && smsOptOutUrl && (
				<div class="rounded-lg border border-gray-200 bg-white p-4 text-sm text-gray-600">
					<p class="font-medium text-gray-900">Also unsubscribe from SMS?</p>
					<p class="mt-1">
						You can turn off SMS alerts from this same page.
					</p>
					<a
						href={smsOptOutUrl}
						class="mt-3 inline-flex w-full items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-sm transition hover:bg-gray-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
					>
						Unsubscribe from SMS too
					</a>
				</div>
			)}

			<div>
				<a href="/auth/signin" class="btn btn-md btn-primary w-full">
					Sign in to adjust schedule
				</a>
			</div>
		</div>
	</main>
</Layout>
