# Copy this file to .act.secrets and fill in any required values.
# Keep .act.secrets local only (already gitignored).

# Needed for workflows that call external APIs or GitHub CLI.
GITHUB_TOKEN=ghp_replace_me

# Needed for deploy.yml (do not use production credentials for local runs).
SUPABASE_ACCESS_TOKEN=replace_me
SUPABASE_PROJECT_REF=replace_me
POSTGRES_PASSWORD=replace_me
