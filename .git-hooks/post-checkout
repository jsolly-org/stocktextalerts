#!/usr/bin/env bash
# Auto-provision a freshly-created worktree on the MANUAL `git worktree add` path. Thin committed shim over
# the shared dotagents logic (same "dotagents owns the logic" pattern as .git-hooks/pre-commit → gate-lib.sh).
# See ~/code/dotagents/hooks/post-checkout-provision.sh and rules/worktree-workflow.md.
#
# Never fail the checkout: if the shared provisioner is missing (dotagents not present) or errors, we still
# exit 0 — a non-zero post-checkout makes `git worktree add` itself report failure. It runs `worktree:provision`
# (the cheap, side-effect-free split — NOT `worktree:init`, which also runs the DESTRUCTIVE db:bootstrap reset
# of the one shared Supabase stack; that must never auto-run on every worktree add).
prov="${DOTAGENTS_POSTCHECKOUT:-$HOME/code/dotagents/hooks/post-checkout-provision.sh}"
[ -f "$prov" ] && bash "$prov" "$@"
exit 0
