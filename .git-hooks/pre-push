#!/usr/bin/env bash
# Pre-push GATE for stocktextalerts (gate-only — this hook does NOT deploy).
#
# Thin shim over the shared fleet gate library (dotagents/gate/gate-lib.sh): the
# ~100 lines of shared boilerplate — push-ref parsing, the gitleaks secrets scan,
# markdown-lint-on-change, the doc-only fast path, the working-tree guards, and
# run_step (silent on green, full output on red) — live in the lib. This file
# declares stocktextalerts' local pre-push gate (lint/types/static checks — no tests,
# no local Supabase). Unit + E2E and live DB privilege checks run in GitHub CI
# (.github/workflows/ci.yml).
#
# Production deploy is owned by GitHub Actions after `main` CI passes. The local
# `npm run deploy:code` path remains break-glass only; infra/template changes stay
# a manual `npm run deploy:infra` (full SAM, admin).
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"; cd "$ROOT"
# shellcheck source=/dev/null
source "${DOTAGENTS_GATE_LIB:-$HOME/code/dotagents/gate/gate-lib.sh}" || {
  echo "✗ dotagents gate-lib not found (expected ~/code/dotagents/gate/gate-lib.sh) — re-run install-local-agent-runtime.sh." >&2
  exit 1
}

# Opportunistic cleanup: reap merged + clean linked worktrees. github-handoff means a PR
# auto-merges AFTER the session ends, so /ship can't reap its own worktree in-session.
# Must run BEFORE gate_begin: that early-exits on a non-main push (the normal feature-branch
# → PR flow here), so anything after it never runs on the pushes that actually happen.
# `</dev/null` so it can't consume the hook's ref-update stdin; non-fatal — never blocks a push.
bash scripts/reap-worktrees.sh </dev/null || true

gate_begin "stocktextalerts"           # parse push; gitleaks; md-lint; doc-only fast path; banner; ERR trap
gate_require_clean_tree                # refuse dirty tree / pushed-SHA≠HEAD / non-fast-forward (the gate validates the tree)
gate_require_node                      # enforce the pinned Node (.nvmrc), not whatever's on PATH

# Cheap preflights — fail in seconds, not after the 15-minute battery.
run_step "dep grounding"                     gate_check_dep_grounding .git-hooks/pre-push scripts/*.sh aws/*.sh
# Build the Lambda bundle (esbuild via sam) as a fail-fast preflight. `npm run build` is astro/web
# only — nothing here ever built the handler bundle until the deploy's Phase 1, so an esbuild break
# (the 2026-06-21 resvg .node incident) surfaced only mid-deploy. Catch it in seconds, before the
# battery and before the deploy migrates prod. Offline + credential-free; restores the release-id stub.
run_step "lambda bundle build — catches an esbuild break before prod is touched" bash aws/deploy-web.sh --build

# --- Quality gate (local — no Podman/Postgres; see docs/github-ci.md) ---
run_step "biome ci"               npx --no-install biome ci . --error-on-warnings
run_step "yaml lint"              npm run check:yaml
run_step "actionlint"             npm run check:actions
run_step "astro check (types)"    npm run check:ts
run_step "knip (unused code)"     npm run check:knip
run_step "squawk migrations"      npm run check:sql
run_step "deploy fn coverage (template ↔ deploy-web.sh)" npm run check:deploy-functions
run_step "migration grants (static)" npm run check:migration-grants

# --- Landing only: this hook GATES; it does NOT deploy. ---
# GitHub Actions runs PR/merge-queue/main CI and then deploys the landed `main`
# commit from .github/workflows/deploy.yml.
echo "✓ pre-push gate passed — push will land; DB tests + unit/E2E run in GitHub CI on the PR."
echo "  After merge: GitHub Actions deploys automatically after main CI passes."

if gate_diff_matches '^aws/(template\.yaml|deploy\.sh)$'; then
  echo "⚠ aws/template.yaml or aws/deploy.sh changed — a full SAM infra deploy is needed:"
  echo "  npm run deploy:infra   (full SAM, admin creds)"
fi
