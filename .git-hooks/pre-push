#!/usr/bin/env bash
# Pre-push gate + deploy for stocktextalerts.
#
# Thin shim over the shared fleet gate library (dotagents/gate/gate-lib.sh): the
# ~100 lines of shared boilerplate — push-ref parsing, the gitleaks secrets scan,
# markdown-lint-on-change, the doc-only fast path, the working-tree guards, and
# run_step (silent on green, full output on red) — live in the lib. This file
# declares only stocktextalerts' full CI battery and the production deploy. The
# gate needs local Supabase up (db-privileges + test + test:e2e) — start it with
# `npm run db:start`. Deploy is code-only (Supabase → Vercel → Lambda code);
# infra/template changes stay a manual `npm run deploy:aws` (full SAM, admin).
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"; cd "$ROOT"
# shellcheck source=/dev/null
source "${DOTAGENTS_GATE_LIB:-$HOME/code/dotagents/gate/gate-lib.sh}" || {
  echo "✗ dotagents gate-lib not found (expected ~/code/dotagents/gate/gate-lib.sh) — re-run install-local-agent-runtime.sh." >&2
  exit 1
}

gate_begin "stocktextalerts" deploys   # parse push; gitleaks; md-lint; doc-only fast path; banner; ERR trap
gate_require_clean_tree                # refuse dirty tree / pushed-SHA≠HEAD / non-fast-forward (deploys from the tree)
gate_require_node                      # enforce the pinned Node (.nvmrc), not whatever's on PATH

# Cheap preflights — fail in seconds, not after the 15-minute battery.
run_step "dep grounding"                     gate_check_dep_grounding .git-hooks/pre-push scripts/*.sh aws/*.sh
run_step "deploy creds preflight"            bash aws/deploy-web.sh --preflight
run_step "db doctor (needs local Supabase up — npm run db:start)" npm run db:doctor

# --- Quality gate (the old run-ci battery — see docs/prepush-gate.md) ---
run_step "biome ci"               npx --no-install biome ci . --error-on-warnings
run_step "yaml lint"              npm run check:yaml
run_step "astro check (types)"    npm run check:ts
run_step "knip (unused code)"     npm run check:knip
run_step "squawk migrations"      npm run check:sql
run_step "deploy fn coverage (template ↔ deploy-web.sh)" npm run check:deploy-functions
run_step "migration grants (static)" npm run check:migration-grants
run_step "db privileges (needs local Supabase up)" npm run check:db-privileges
run_step "unit tests"             npm test
# E2E is a long Playwright run — stream it so a multi-minute suite shows progress.
echo "• E2E tests"
npm run test:e2e

# --- Deploy: code-only production deploy (Supabase → Vercel → Lambda code) ---
infra_changed=""
if gate_diff_matches '^aws/(template\.yaml|deploy\.sh)$'; then
  infra_changed=1
fi
echo "• production deploy"
trap 'echo "✗ deploy failed — production may be PARTIALLY updated (see phase above); push aborted. Fix and re-run: npm run deploy" >&2' ERR
bash aws/deploy-web.sh
echo "✓ pre-push gate + deploy complete"
if [ -n "$infra_changed" ]; then
  echo "⚠ aws/template.yaml or aws/deploy.sh changed — Lambda INFRA is NOT auto-deployed by this hook."
  echo "  Apply infra manually with admin creds:  npm run deploy:aws   (full SAM)"
fi
