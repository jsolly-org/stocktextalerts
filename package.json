{
	"name": "app-quickstart",
	"type": "module",
	"version": "0.0.1",
	"license": "MIT",
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"predev": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx scripts/db/doctor.ts || true",
		"dev": "node --env-file-if-exists=.env.local ./node_modules/.bin/astro dev",
		"build": "node --env-file-if-exists=.env.local ./node_modules/.bin/astro build",
		"build:preview": "ASTRO_ADAPTER=node node --env-file-if-exists=.env.local ./node_modules/.bin/astro build",
		"deploy": "bash aws/deploy-web.sh",
		"deploy:aws": "npm --prefix aws run deploy",
		"preview": "ASTRO_ADAPTER=node node --env-file-if-exists=.env.local ./node_modules/.bin/astro preview --port 4323",
		"prepare": "if [ -z \"$CI\" ] && git rev-parse --git-dir >/dev/null 2>&1; then git config core.hooksPath .git-hooks; fi",
		"pretest": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx scripts/db/doctor.ts",
		"test": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts",
		"test:e2e": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-playwright.ts",
		"test:e2e:preview": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-playwright.ts --config playwright.preview.config.ts",
		"test:all": "npm run test && npm run test:e2e",
		"check:ts": "astro check",
		"check:biome": "biome check --write --no-errors-on-unmatched",
		"check:knip": "knip",
		"check:md": "markdownlint-cli2 \"**/*.md\"",
		"check:md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
		"check:sql": "bash scripts/db/check-sql.sh",
		"check:db-privileges": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx scripts/db/check-privileges.ts",
		"check:migration-grants": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx scripts/db/check-migration-grants.ts",
		"audit:db-parity": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx scripts/db/dump-permissions.ts --diff-prod",
		"check:yaml": "uvx yamllint@1.38.0 . && actionlint",
		"db:start": "node ./node_modules/.bin/tsx scripts/db/start.ts",
		"db:stop": "supabase stop",
		"db:bootstrap": "node ./node_modules/.bin/tsx scripts/db/link-worktree-data.ts && node ./node_modules/.bin/tsx scripts/db/worktree-supabase.ts && npm run db:start && npm run db:reset && npm run db:doctor",
		"db:link-worktree-data": "node ./node_modules/.bin/tsx scripts/db/link-worktree-data.ts",
		"db:worktree-setup": "node ./node_modules/.bin/tsx scripts/db/worktree-supabase.ts",
		"db:doctor": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx scripts/db/doctor.ts",
		"db:reset": "node ./node_modules/.bin/tsx scripts/db/reset.ts",
		"db:gen-types": "supabase gen types typescript --local --schema public > src/lib/db/generated/database.types.ts.tmp && (printf '/*\n * This file is auto-generated by `npm run db:gen-types`\n * Do not edit manually - your changes will be overwritten\n *\n * To regenerate: npm run db:gen-types\n */\n' && cat src/lib/db/generated/database.types.ts.tmp) > src/lib/db/generated/database.types.ts && rm src/lib/db/generated/database.types.ts.tmp",
		"db:fetch-assets": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx scripts/db/fetch-us-assets.ts",
		"db:generate-seed": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx scripts/db/generate-seed.ts",
		"test:live:data": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts --live=massive,finnhub tests/lib/live-provider-apis.test.ts",
		"test:live:xai": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts --live=xai tests/lib/live-xai-apis.test.ts",
		"test:live:email": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts --live=email tests/lib/staged-notifications/deliver.test.ts tests/lib/market-notifications/flat-alerts/process.live.test.ts",
		"test:live:twilio": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts --live=twilio tests/lib/live-twilio-apis.test.ts",
		"test:live:all": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts --live=all"
	},
	"lint-staged": {
		"**/*.{ts,tsx,json,css,astro,html,vue}": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		],
		"**/*.md": [
			"markdownlint-cli2 --fix"
		],
		"supabase/migrations/*.sql": [
			"bash scripts/db/check-sql.sh"
		]
	},
	"dependencies": {
		"@astrojs/vercel": "^10.0.3",
		"@aws-sdk/client-sesv2": "^3.1041.0",
		"@aws-sdk/client-sqs": "^3.1063.0",
		"@supabase/supabase-js": "^2.105.3",
		"@vuepic/vue-datepicker": "^12.1.0",
		"@vueuse/core": "^14.2.1",
		"astro-icon": "^1.1.5",
		"libphonenumber-js": "^1.12.40",
		"luxon": "^3.7.2",
		"nodemailer": "^8.0.5",
		"twilio": "^5.13.1",
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/node": "^10.0.4",
		"@astrojs/sitemap": "^3.7.2",
		"@astrojs/ts-plugin": "^1.10.7",
		"@astrojs/vue": "^6.0.1",
		"@axe-core/playwright": "^4.11.1",
		"@biomejs/biome": "2.4.10",
		"@playwright/test": "^1.60.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/aws-lambda": "^8.10.161",
		"@types/luxon": "^3.7.1",
		"@types/nodemailer": "^8.0.0",
		"@types/pg": "^8.20.0",
		"astro": "^6.1.9",
		"chrome-launcher": "^1.2.1",
		"knip": "^6.2.0",
		"lighthouse": "^13.0.3",
		"lint-staged": "^16.4.0",
		"markdownlint-cli2": "^0.22.1",
		"pg": "^8.20.0",
		"squawk-cli": "^2.51.0",
		"supabase": "^2.105.0",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"twilio-cli": "^6.2.4",
		"typescript": "^5.9.3",
		"vercel": "^54.10.3",
		"vite": "^7.3.2",
		"vite-svg-loader": "^5.1.1",
		"vitest": "^4.1.2",
		"wrangler": "^4.99.0"
	}
}
