{
	"name": "app-quickstart",
	"type": "module",
	"version": "0.0.1",
	"license": "MIT",
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "npm run build && vercel deploy --prebuilt",
		"prepare": "if [ -z \"$CI\" ]; then husky; fi",
		"test": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts",
		"test:ci": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts",
		"test:smoke": "node --env-file-if-exists=.env.local ./node_modules/.bin/playwright test --config playwright.smoke.config.ts",
		"test:e2e": "node --env-file-if-exists=.env.local ./node_modules/.bin/playwright test",
		"test:all": "npm run test && npm run test:smoke && npm run test:e2e",
		"gha:local": "scripts/ci/run-local-actions.sh",
		"gha:local:lint": "scripts/ci/run-local-actions.sh --job lint",
		"gha:local:test-build": "scripts/ci/run-local-actions.sh --job test-and-build",
		"check:ts": "tsc --noEmit --skipLibCheck",
		"check:biome": "biome check --write --no-errors-on-unmatched",
		"check:knip": "knip",
		"check:yaml": "yamllint '.github/**/*.yml'",
		"db:start": "supabase start",
		"db:stop": "supabase stop",
		"db:reset": "supabase status && npm run db:generate-seed && supabase db reset && npm run db:gen-types",
		"db:gen-types": "supabase gen types typescript --local --schema public > src/lib/db/generated/database.types.ts.tmp && (printf '/*\n * This file is auto-generated by `npm run db:gen-types`\n * Do not edit manually - your changes will be overwritten\n *\n * To regenerate: npm run db:gen-types\n */\n' && cat src/lib/db/generated/database.types.ts.tmp) > src/lib/db/generated/database.types.ts && rm src/lib/db/generated/database.types.ts.tmp",
		"db:fetch-assets": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx scripts/db/fetch-us-assets.ts",
		"db:generate-seed": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx scripts/db/generate-seed.ts",
		"test:live:data": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts --live=massive,finnhub tests/lib/live-provider-apis.test.ts",
		"test:live:xai": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts --live=xai tests/lib/live-xai-apis.test.ts",
		"test:live:email": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts --live=email tests/lib/staged-notifications/deliver.test.ts",
		"test:live:sms": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts --live=sms tests/api/schedule/schedule-sms.test.ts",
		"test:live:all": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx tests/run-vitest.ts --live=all"
	},
	"lint-staged": {
		"**/*.{ts,tsx,json,css,md,astro,html,vue}": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		],
		".github/**/*.{yml,yaml}": [
			"yamllint"
		]
	},
	"dependencies": {
		"@astrojs/vercel": "^10.0.2",
		"@supabase/supabase-js": "^2.100.0",
		"@vuepic/vue-datepicker": "^12.1.0",
		"@vueuse/core": "^14.2.1",
		"astro-icon": "^1.1.5",
		"libphonenumber-js": "^1.12.40",
		"luxon": "^3.7.2",
		"resend": "^6.9.4",
		"twilio": "^5.13.1",
		"vue": "^3.5.30"
	},
	"overrides": {
		"lodash": "4.17.23"
	},
	"devDependencies": {
		"@astrojs/sitemap": "^3.7.1",
		"@astrojs/ts-plugin": "^1.10.7",
		"@astrojs/vue": "^6.0.1",
		"@axe-core/playwright": "^4.11.1",
		"@biomejs/biome": "2.4.7",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.2.1",
		"@types/luxon": "^3.7.1",
		"@types/pg": "^8.20.0",
		"astro": "^6.1.1",
		"husky": "^9.1.7",
		"knip": "^5.88.1",
		"lighthouse": "^13.0.3",
		"lint-staged": "^16.4.0",
		"pg": "^8.20.0",
		"supabase": "^2.83.0",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite-svg-loader": "^5.1.1",
		"vitest": "^4.1.1",
		"yaml-lint": "^1.7.0"
	}
}
