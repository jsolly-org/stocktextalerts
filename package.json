{
	"name": "app-quickstart",
	"type": "module",
	"version": "0.0.1",
	"license": "MIT",
	"engines": {
		"node": ">=22.17.1"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"prepare": "if [ -z \"$CI\" ]; then husky; fi",
		"test": "node --env-file-if-exists=.env.local ./node_modules/.bin/vitest --no-watch",
		"test:e2e": "node --env-file-if-exists=.env.local ./node_modules/.bin/playwright test",
		"test:all": "npm run test && npm run test:e2e",
		"check:ts": "tsc --noEmit",
		"check:biome": "biome check --write --no-errors-on-unmatched",
		"fix": "npm run check:biome && npm run check:ts && npm run test:all",
		"db:start": "supabase start",
		"db:stop": "supabase stop",
		"db:reset": "npm run db:generate-seed && supabase db reset && npm run db:gen-types",
		"db:gen-types": "supabase gen types typescript --local --schema public > src/lib/db/generated/database.types.ts.tmp && (printf '/*\n * This file is auto-generated by `npm run db:gen-types`\n * Do not edit manually - your changes will be overwritten\n *\n * To regenerate: npm run db:gen-types\n */\n' && cat src/lib/db/generated/database.types.ts.tmp) > src/lib/db/generated/database.types.ts && rm src/lib/db/generated/database.types.ts.tmp",
		"db:generate-seed": "node --env-file-if-exists=.env.local ./node_modules/.bin/tsx scripts/generate-seed.ts"
	},
	"lint-staged": {
		"**/*.{ts,tsx,json,css,md,astro,html}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@astrojs/vercel": "^9.0.4",
		"@heroicons/vue": "^2.2.0",
		"@supabase/supabase-js": "^2.91.0",
		"@vuepic/vue-datepicker": "^12.1.0",
		"@vueuse/core": "^14.1.0",
		"fuse.js": "^7.1.0",
		"libphonenumber-js": "^1.12.35",
		"luxon": "^3.7.2",
		"resend": "^6.6.0",
		"twilio": "^5.11.2",
		"vue": "^3.5.27"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.6",
		"@astrojs/sitemap": "^3.7.0",
		"@astrojs/ts-plugin": "^1.10.6",
		"@astrojs/vue": "^5.1.3",
		"@biomejs/biome": "2.3.11",
		"@playwright/test": "^1.57.0",
		"@tailwindcss/vite": "^4.1.18",
		"@types/luxon": "^3.7.1",
		"@types/pg": "^8.16.0",
		"astro": "^5.16.15",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"pg": "^8.17.2",
		"supabase": "^2.72.8",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
