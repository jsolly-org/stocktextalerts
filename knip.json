{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"entry": [
		"src/handlers/**/*.ts",
		"scripts/**/*.ts",
		"tests/run-vitest.ts",
		"tests/run-playwright.ts",
		"playwright.preview.config.ts"
	],
	"ignore": ["src/lib/db/generated/**"],
	"ignoreDependencies": ["lint-staged", "squawk-cli"],
	"ignoreBinaries": [
		"vercel",
		"printf",
		"scripts/ci/run-local-actions.sh",
		"yamllint",
		"actionlint"
	]
}
