{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"entry": [
		"src/handlers/**/*.ts",
		"scripts/**/*.ts",
		"tests/run-vitest.ts",
		"tests/run-playwright.ts",
		"tests/setup.ts",
		"playwright.preview.config.ts"
	],
	"ignore": [
		"src/lib/db/generated/**"
	],
	"ignoreDependencies": [
