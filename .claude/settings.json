{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit:*)",
            "command": "bash .agents/hooks/check-sam-deploy.sh",
            "timeout": 5,
            "statusMessage": "Checking for Lambda-related changes..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Edit(/.agents/**)",
      "Edit(/.github/workflows/fleet-lock-guard.yml)",
      "Edit(/scripts/cloud-fleet-sync-if-stale.sh)",
      "Edit(/scripts/update-agents-subtree.sh)",
      "Write(/.agents/**)",
      "Write(/.github/workflows/fleet-lock-guard.yml)",
      "Write(/scripts/cloud-fleet-sync-if-stale.sh)",
      "Write(/scripts/update-agents-subtree.sh)"
    ]
  }
}
